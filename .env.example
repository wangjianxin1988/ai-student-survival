# Supabase Configuration
# Get these values from your Supabase project dashboard: https://supabase.com/dashboard
PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Service role key (server-side only, never expose to client)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# TinaCMS Configuration
# Set to 'true' to enable TinaCMS in development
PUBLIC_TINA_ENABLED=false

# Tina Cloud credentials (for production with Tina Cloud)
# TINA_CLIENT_ID=your-tina-cloud-client-id
# TINA_TOKEN=your-tina-cloud-token