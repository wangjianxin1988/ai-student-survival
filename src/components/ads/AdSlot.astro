---
/**
 * Monetag In-Page Push Ad Slot Component
 * 
 * Renders a Monetag in-page push banner ad in existing ad slots.
 * Zone ID: 11076692 (In-Page Push format)
 *
 * Props:
 *  - className: extra CSS classes
 *  - label: optional label text above the ad
 */

interface Props {
  className?: string;
  label?: string;
}

const { className = '', label } = Astro.props;
---

<div class={`monetag-ad-container ${className}`}>
  {label && <p class="text-xs text-gray-400 mb-2 text-center">{label}</p>}
  <script is:inline set:html={`(function(s){s.dataset.zone='11076692',s.src='https://nap5k.com/tag.min.js'})([document.documentElement, document.body].filter(Boolean).pop().appendChild(document.createElement('script')))`} />
</div>
