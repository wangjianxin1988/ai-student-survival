---
/**
 * Ad Slot Component (Astro version)
 * 
 * Placeholder for future AdSense ads. Shows a clean placeholder until AdSense is approved.
 * Replace ca-pub-XXXXXXXXXX with real publisher ID after approval.
 *
 * Props:
 *  - format: 'auto' | 'horizontal' | 'vertical' | 'rectangle' (default: 'auto')
 *  - className: extra CSS classes
 *  - slot: ad slot ID
 */

interface Props {
  format?: 'auto' | 'horizontal' | 'vertical' | 'rectangle';
  className?: string;
  slot?: string;
}

const {
  format = 'auto',
  className = '',
  slot = '0000000000',
} = Astro.props;

// AdSense publisher ID — replace after approval
const AD_CLIENT = 'ca-pub-XXXXXXXXXX';
const isProduction = import.meta.env.PROD;
const isAdSenseReady = isProduction && AD_CLIENT !== 'ca-pub-XXXXXXXXXX';
---

{isAdSenseReady ? (
  <!-- Real AdSense ad unit (shown after approval) -->
  <div class={`adsense-container ${className}`}>
    <ins
      class="adsbygoogle"
      style="display:block"
      data-ad-client={AD_CLIENT}
      data-ad-slot={slot}
      data-ad-format={format}
      data-full-width-responsive="true"
    />
    <script is:inline>
      (window.adsbygoogle = window.adsbygoogle || []).push({});
    </script>
  </div>
) : (
  <!-- Placeholder (shown before AdSense approval) -->
  <div class={`ad-placeholder bg-gray-50 border border-dashed border-gray-200 rounded-lg flex items-center justify-center py-8 ${className}`}>
    <div class="text-center">
      <p class="text-xs text-gray-300 font-medium">广告位</p>
      <p class="text-[10px] text-gray-200 mt-1">Ad Space</p>
    </div>
  </div>
)}
