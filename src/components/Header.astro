---
import { type Locale, t as translate, defaultLocale } from '@/i18n';

interface Props {
  currentPath?: string;
  locale?: Locale;
}

const { currentPath = '/', locale = 'zh' as Locale } = Astro.props;

// Generate locale-aware hrefs
function getLocaleHref(path: string): string {
  if (locale === defaultLocale) {
    return path;
  }
  return `/${locale}${path}`;
}

const navLinks = [
  { href: '/tools', key: 'nav.aiTools', shortZh: '工具', shortEn: 'Tools' },
  { href: '/payment', key: 'nav.payment', shortZh: '支付', shortEn: 'Payment' },
  { href: '/policies', key: 'nav.policies', shortZh: '政策', shortEn: 'Policies' },
  { href: '/prompts', key: 'nav.prompts', shortZh: 'Prompt', shortEn: 'Prompts' },
  { href: '/offers', key: 'nav.offers', shortZh: 'Offer', shortEn: 'Offers' },
  { href: '/map', key: 'nav.map', shortZh: '地图', shortEn: 'Map' },
].map(link => ({
  ...link,
  href: getLocaleHref(link.href),
  short: locale === 'zh' ? link.shortZh : link.shortEn
}));
---

<nav class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-gray-200">
  <!-- Top bar: Auth & Search -->
  <div class="border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-10">
        <!-- Left: Logo with site name -->
        <a href="/" class="flex items-center gap-2 hover:opacity-80 transition-opacity">
          <div class="w-7 h-7 rounded-lg bg-gradient-to-br from-primary-500 to-secondary-500 flex items-center justify-center">
            <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <span class="font-semibold text-sm text-gray-900">{translate(locale, 'site.name')}</span>
        </a>

        <!-- Right: Search & User slot -->
        <div class="flex items-center gap-1">
          <!-- Search -->
          <button
            data-search-trigger
            class="p-2 rounded-lg text-gray-600 hover:text-gray-900 hover:bg-gray-100 transition-colors"
            title={translate(locale, 'common.search')}
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </button>

          <!-- User Menu slot - passed from parent -->
          <slot name="user-menu" />
        </div>
      </div>
    </div>
  </div>

  <!-- Main nav bar -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-12">
      <!-- Nav Links - Hidden on small screens, compact on medium+ -->
      <div class="hidden md:flex items-center gap-0.5">
        {navLinks.map(link => (
          <a
            href={link.href}
            class:list={[
              'nav-link px-3 py-1.5 rounded-md text-sm font-medium transition-colors whitespace-nowrap',
              currentPath.startsWith(link.href)
                ? 'bg-primary-50 text-primary-700'
                : 'text-gray-600 hover:text-gray-900 hover:bg-gray-100'
            ]}
          >
            {translate(locale, link.key)}
          </a>
        ))}
      </div>

      <!-- Right Actions (mobile only) -->
      <div class="flex items-center gap-1 md:hidden">
        <!-- Mobile menu button -->
        <button
          type="button"
          class="p-2 rounded-lg text-gray-600 hover:text-gray-900 hover:bg-gray-100"
          id="mobile-menu-btn"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div class="md:hidden hidden" id="mobile-menu">
      <div class="py-3 space-y-1 border-t border-gray-100">
        {navLinks.map(link => (
          <a
            href={link.href}
            class:list={[
              'block px-3 py-2 rounded-lg text-base font-medium transition-colors',
              currentPath.startsWith(link.href)
                ? 'bg-primary-50 text-primary-700'
                : 'text-gray-600 hover:text-gray-900 hover:bg-gray-100'
            ]}
          >
            {translate(locale, link.key)}
          </a>
        ))}
      </div>
    </div>
  </div>
</nav>

<script>
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  mobileMenuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>
