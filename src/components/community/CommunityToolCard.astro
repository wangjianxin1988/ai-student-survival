---
import type { CommunityPost } from '@/lib/community/types';

interface Props {
  post: CommunityPost;
}

const { post } = Astro.props;

// 提取 meta 信息
const meta = post.meta as Record<string, unknown> || {};
const pricing = meta.pricing as string || 'free';
const url = meta.url as string || '';
const features = (meta.features as string[]) || [];
const description = meta.description as string || post.content?.substring(0, 150) || '';

const PRICING_LABELS: Record<string, string> = {
  free: '免费',
  freemium: '免费+付费',
  paid: '付费',
};

const PRICING_CLASSES: Record<string, string> = {
  free: 'badge-free',
  freemium: 'badge-freemium',
  paid: 'badge-paid',
};
---

<article class="tool-card group bg-gradient-to-br from-blue-50 to-white border-2 border-blue-100 hover:border-blue-300">
  {url && (
    <a href={url} target="_blank" rel="noopener noreferrer" class="tool-card-image">
      <div class="w-full h-full bg-gradient-to-br from-blue-100 to-blue-50 flex items-center justify-center">
        <span class="text-4xl">🤖</span>
      </div>
    </a>
  )}
  {!url && (
    <div class="tool-card-image">
      <div class="w-full h-full bg-gradient-to-br from-blue-100 to-blue-50 flex items-center justify-center">
        <span class="text-4xl">🤖</span>
      </div>
    </div>
  )}
  <div class="tool-card-body">
    <div class="flex items-start justify-between mb-2">
      <h3 class="text-lg font-semibold group-hover:text-primary-600 transition-colors line-clamp-1">
        <a href={`/community/${post.id}`}>{post.title}</a>
      </h3>
      <span class="badge bg-green-100 text-green-700 text-xs">社区推荐</span>
    </div>
    <p class="text-gray-600 text-sm mb-3 line-clamp-2">{description}</p>

    {/* 工具特有信息 */}
    <div class="space-y-2 mb-3">
      {/* 定价 */}
      <div class="flex items-center gap-2 text-sm">
        <span class={`badge ${PRICING_CLASSES[pricing] || 'badge-free'}`}>
          {PRICING_LABELS[pricing] || pricing}
        </span>
      </div>

      {/* 功能列表 */}
      {features.length > 0 && (
        <div class="flex flex-wrap gap-1">
          {features.slice(0, 3).map((feature: string) => (
            <span class="text-xs px-2 py-0.5 bg-gray-100 text-gray-600 rounded">{feature}</span>
          ))}
          {features.length > 3 && (
            <span class="text-xs px-2 py-0.5 bg-gray-100 text-gray-500 rounded">+{features.length - 3}</span>
          )}
        </div>
      )}

      {/* 官网链接 */}
      {url && (
        <div class="text-xs text-blue-600 truncate">
          <a href={url} target="_blank" rel="noopener noreferrer" class="hover:underline">
            {url.replace(/^https?:\/\//, '').split('/')[0]}
          </a>
        </div>
      )}
    </div>

    <div class="flex items-center justify-between mt-auto pt-2 border-t border-gray-100">
      <div class="flex items-center gap-2 text-xs text-gray-500">
        <span>{post.userName || '匿名用户'}</span>
        <span>•</span>
        <span>{new Date(post.createdAt).toLocaleDateString('zh-CN')}</span>
      </div>
      <div class="flex items-center gap-3 text-xs text-gray-400">
        <span class="flex items-center gap-1">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
          </svg>
          {post.likesCount || 0}
        </span>
        <span class="flex items-center gap-1">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
          </svg>
          {post.commentsCount || 0}
        </span>
      </div>
    </div>
  </div>
</article>
