---
// Search Modal Component - Ctrl+K to open, ESC to close
import { type Locale, t as translate } from '@/i18n';

interface Props {
  locale?: Locale;
}

const { locale = 'zh' } = Astro.props;
---

<div id="search-modal" class="fixed inset-0 z-50 hidden" aria-hidden="false">
  <!-- Backdrop -->
  <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" id="search-backdrop"></div>

  <!-- Modal -->
  <div class="relative top-[10vh] max-w-2xl mx-auto bg-white rounded-2xl shadow-2xl overflow-hidden">
    <!-- Search Input -->
    <div class="flex items-center border-b border-gray-200 px-4">
      <svg class="w-5 h-5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
      <input
        type="text"
        id="search-input"
        placeholder={translate(locale, 'common.searchPlaceholder')}
        class="flex-1 px-4 py-4 text-lg outline-none placeholder-gray-400"
        autocomplete="off"
      />
      <button id="search-close-btn" class="p-2 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-lg transition-colors" aria-label="Close search">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
      <kbd class="hidden sm:inline-flex px-2 py-1 text-xs bg-gray-100 text-gray-500 rounded">ESC</kbd>
    </div>

    <!-- Search Results -->
    <div id="search-results" class="max-h-[60vh] overflow-y-auto">
      <!-- Initial State -->
      <div id="search-initial" class="p-6 text-center text-gray-500">
        <div id="search-history-section" class="mb-4">
          <div class="flex items-center justify-between mb-2">
            <p class="text-sm font-medium text-gray-700">{translate(locale, 'search.history')}</p>
            <button id="clear-history" class="text-xs text-gray-400 hover:text-gray-600">{translate(locale, 'search.clear')}</button>
          </div>
          <div id="search-history-list" class="flex flex-wrap justify-center gap-2 text-sm"></div>
        </div>
        <p class="mb-2 text-gray-400">{translate(locale, 'search.trending')}</p>
        <div class="flex flex-wrap justify-center gap-2 text-sm">
          <span class="px-2 py-1 bg-gray-100 rounded cursor-pointer hover:bg-gray-200 search-trending" data-trending={translate(locale, 'search.trendingChatGPT')}>ChatGPT</span>
          <span class="px-2 py-1 bg-gray-100 rounded cursor-pointer hover:bg-gray-200 search-trending" data-trending={translate(locale, 'search.trendingClaude')}>Claude</span>
          <span class="px-2 py-1 bg-gray-100 rounded cursor-pointer hover:bg-gray-200 search-trending" data-trending={translate(locale, 'search.trendingMidjourney')}>Midjourney</span>
          <span class="px-2 py-1 bg-gray-100 rounded cursor-pointer hover:bg-gray-200 search-trending" data-trending={translate(locale, 'search.trendingPayment')}>{locale === 'zh' ? '支付' : 'Payment'}</span>
          <span class="px-2 py-1 bg-gray-100 rounded cursor-pointer hover:bg-gray-200 search-trending" data-trending={translate(locale, 'search.trendingMIT')}>MIT</span>
          <span class="px-2 py-1 bg-gray-100 rounded cursor-pointer hover:bg-gray-200 search-trending" data-trending={translate(locale, 'search.trendingStanford')}>{locale === 'zh' ? '斯坦福' : 'Stanford'}</span>
          <span class="px-2 py-1 bg-gray-100 rounded cursor-pointer hover:bg-gray-200 search-trending" data-trending={translate(locale, 'search.trendingCopilot')}>GitHub Copilot</span>
          <span class="px-2 py-1 bg-gray-100 rounded cursor-pointer hover:bg-gray-200 search-trending" data-trending={translate(locale, 'search.trendingPrompts')}>{locale === 'zh' ? 'Prompt模板' : 'Prompt Templates'}</span>
        </div>
      </div>

      <!-- Loading State -->
      <div id="search-loading" class="hidden p-6 text-center text-gray-500">
        <div class="animate-spin w-6 h-6 border-2 border-primary-500 border-t-transparent rounded-full mx-auto"></div>
        <p class="mt-2">{translate(locale, 'search.searching')}</p>
      </div>

      <!-- Results Container -->
      <div id="search-results-container" class="hidden"></div>

      <!-- No Results -->
      <div id="search-no-results" class="hidden p-6 text-center text-gray-500">
        <p>{translate(locale, 'search.noResults')}</p>
      </div>
    </div>

    <!-- Footer -->
    <div class="border-t border-gray-200 px-4 py-3 bg-gray-50 flex items-center justify-between text-xs text-gray-500">
      <div class="flex items-center gap-4">
        <span><kbd class="px-1 py-0.5 bg-gray-200 rounded">{translate(locale, 'search.navigate')}</kbd> {translate(locale, 'search.navigateLabel')}</span>
        <span><kbd class="px-1 py-0.5 bg-gray-200 rounded">Enter</kbd> {translate(locale, 'search.select')}</span>
        <span><kbd class="px-1 py-0.5 bg-gray-200 rounded">ESC</kbd> {translate(locale, 'search.close')}</span>
      </div>
      <span>{translate(locale, 'site.name')}</span>
    </div>
  </div>
</div>

<style>
  #search-modal.active {
    display: block;
  }
  #search-modal.active[aria-hidden="false"] {
    display: flex;
  }
</style>

<script is:inline>
  // Listen for search button click (event delegation)
  document.addEventListener('click', function(e) {
    var target = e.target.closest('[data-search-trigger]');
    if (target) {
      var modal = document.getElementById('search-modal');
      var input = document.getElementById('search-input');
      if (modal) {
        modal.classList.add('active');
        modal.setAttribute('aria-hidden', 'false');
        if (input) input.focus();
        document.body.style.overflow = 'hidden';
      }
    }
  });

  // Search data sources — all tools, pages, blog posts, payment guides
  const searchData = {
    tools: [
      { name: 'ChatGPT', slug: 'chatgpt', category: '对话', description: 'OpenAI AI对话助手，Go/Plus/Pro多层级' },
      { name: 'Claude', slug: 'claude', category: '对话', description: 'Anthropic AI助手，Opus 4.8最新版' },
      { name: 'Midjourney', slug: 'midjourney', category: '设计', description: 'AI图像生成工具' },
      { name: 'GitHub Copilot', slug: 'github-copilot', category: '编程', description: 'AI编程助手，代码补全' },
      { name: 'GitHub Copilot App', slug: 'github-copilot-app', category: '编程', description: 'Agent原生桌面开发应用' },
      { name: 'Notion AI', slug: 'notion-ai', category: '写作', description: '集成在Notion中的AI助手' },
      { name: 'Perplexity', slug: 'perplexity', category: '研究', description: 'AI搜索引擎' },
      { name: 'Jasper', slug: 'jasper', category: '写作', description: '企业级AI写作助手' },
      { name: 'Copy.ai', slug: 'copyai', category: '写作', description: 'AI文案生成工具，100+模板' },
      { name: 'Grammarly', slug: 'grammarly', category: '写作', description: 'AI写作辅助，语法检查' },
      { name: 'QuillBot', slug: 'quillbot', category: '写作', description: 'AI改写和润色工具' },
      { name: 'Tabnine', slug: 'tabnine', category: '编程', description: 'AI代码补全插件' },
      { name: 'Cursor', slug: 'cursor', category: '编程', description: 'AI代码编辑器，GPT-4驱动' },
      { name: 'Replit', slug: 'replit', category: '编程', description: '在线AI编程平台' },
      { name: 'Figma', slug: 'figma', category: '设计', description: 'AI增强的UI设计工具' },
      { name: 'DALL-E 3', slug: 'dalle-3', category: '设计', description: 'OpenAI图像生成模型' },
      { name: 'Stable Diffusion', slug: 'stable-diffusion', category: '设计', description: '开源AI图像生成' },
      { name: 'Kimi', slug: 'kimi', category: '对话', description: '月之暗面AI助手，20万字上下文' },
      { name: 'Gemini', slug: 'gemini', category: '对话', description: 'Google AI助手' },
      { name: 'WebPilot', slug: 'webpilot', category: '研究', description: 'AI网页阅读助手' },
      { name: 'Elicit', slug: 'elicit', category: '研究', description: 'AI学术研究助手' },
      { name: 'OpenClaw', slug: 'openclaw', category: 'Agent', description: '开源AI Agent框架，300K+ Stars' },
      { name: 'Hermes Agent', slug: 'hermes-agent', category: 'Agent', description: '自进化AI Agent框架' },
      { name: 'Hermes Desktop', slug: 'hermes-desktop', category: 'Agent', description: 'Hermes桌面应用，跨平台' },
      { name: 'AutoGPT', slug: 'autogpt', category: 'Agent', description: '自主任务执行Agent' },
      { name: 'CrewAI', slug: 'crewai', category: 'Agent', description: '多Agent协作框架' },
      { name: 'LangChain', slug: 'langchain', category: 'Agent', description: 'LLM应用开发框架' },
      { name: 'Dify', slug: 'dify', category: 'Agent', description: '低代码LLM应用平台' },
      { name: 'Coze', slug: 'coze', category: 'Agent', description: '字节跳动Bot开发平台' },
      { name: 'Ollama', slug: 'ollama', category: '编程', description: '本地大模型运行工具' },
      { name: 'LM Studio', slug: 'lm-studio', category: '编程', description: '本地LLM运行平台' },
      { name: 'AnythingLLM', slug: 'anything-llm', category: 'Agent', description: '本地RAG知识库' },
      { name: 'DeepSeek', slug: 'deepseek', category: '对话', description: '国产开源大模型，API极低价' },
      { name: 'Qwen', slug: 'qwen', category: '对话', description: '阿里通义千问大模型' },
      { name: 'ChatGLM', slug: 'chatglm', category: '对话', description: '清华智谱AI大模型' },
      { name: 'Microsoft Scout', slug: 'microsoft-scout', category: 'Agent', description: '微软个人AI Agent' },
      { name: 'OpenAI Codex', slug: 'openai-codex', category: '编程', description: 'OpenAI编码Agent' },
      { name: 'Windsurf', slug: 'windsurf', category: '编程', description: 'Codeium AI代码编辑器' },
    ],
    pages: [
      { name: 'AI工具库', url: '/tools', description: '精选留学生常用的AI工具' },
      { name: '支付解决方案', url: '/payment', description: '一站式解决AI工具支付难题' },
      { name: '大学AI政策', url: '/policies', description: '首家全面收录海外大学AI使用政策' },
      { name: 'Prompt模板库', url: '/prompts', description: '精选留学生常用的Prompt模板' },
      { name: '工具对比', url: '/compare', description: '横向对比多个AI工具' },
      { name: '社区', url: '/community', description: '留学生AI工具使用社区' },
      { name: '问答', url: '/questions', description: 'AI工具使用问答' },
      { name: '生存指南', url: '/survival', description: '留学生AI生存指南' },
      { name: '优惠信息', url: '/offers', description: 'AI工具优惠和折扣信息' },
      { name: '博客', url: '/blog', description: 'AI工具评测、教程和资讯' },
    ],
    blog: [
      { name: 'ChatGPT Go怎么订阅？2026最新教程', slug: 'chatgpt-go-how-to-subscribe', description: 'ChatGPT Go订阅完整指南，含虚拟卡支付方法' },
      { name: 'Claude Opus 4.8评测：值得升级吗？', slug: 'claude-opus-48-review', description: 'Claude Opus 4.8详细评测，与GPT-5.5对比' },
      { name: 'EU AI Act对留学生有什么影响？', slug: 'eu-ai-act-student-guide', description: '2026年8月2日截止日全解读' },
      { name: '2026年最好用的AI编程工具Top 10', slug: 'best-ai-coding-tools-2026', description: 'Copilot、Cursor、Codex等10款工具对比' },
    ],
    payment: [
      { name: 'ChatGPT订阅支付指南', id: 'chatgpt-subscription', description: 'Go/Plus/Pro全层级支付教程' },
      { name: 'Depay虚拟卡', id: 'depay-virtual-card', description: 'USDT充值虚拟卡，无需KYC' },
      { name: 'WildCard虚拟卡', id: 'wildcard-virtual-card', description: '支付宝充值，专为国内用户设计' },
    ],
    // Dynamically loaded on first search
    community: null,
    policies: null,
  };

  // Lazy-load community posts and policies
  async function loadDynamicSearchData() {
    if (searchData.community === null) {
      try {
        const res = await fetch('/api/community?limit=30&sort=latest');
        const data = await res.json();
        if (data.success && data.data) {
          searchData.community = data.data.slice(0, 30).map((post: any) => ({
            name: post.title || post.content?.slice(0, 60) || '社区帖子',
            url: `/community/${post.id}`,
            description: post.content?.slice(0, 120) || '',
          }));
        }
      } catch { /* ignore */ }
    }
    if (searchData.policies === null) {
      try {
        const res = await fetch('/api/policies');
        const data = await res.json();
        if (data.success && data.data) {
          searchData.policies = data.data.slice(0, 20).map((policy: any) => ({
            name: policy.university || policy.name || '大学政策',
            url: `/policies/${policy.slug || policy.id}`,
            description: policy.summary || policy.ai_policy || '',
          }));
        }
      } catch { /* ignore */ }
    }
  }

  // Search History Management
  const SEARCH_HISTORY_KEY = 'demo_search_history';
  const MAX_HISTORY_ITEMS = 10;

  function getSearchHistory(): string[] {
    try {
      const stored = localStorage.getItem(SEARCH_HISTORY_KEY);
      return stored ? JSON.parse(stored) : [];
    } catch {
      return [];
    }
  }

  function addToSearchHistory(query: string) {
    if (!query.trim()) return;
    let history = getSearchHistory();
    // Remove if already exists
    history = history.filter(item => item !== query);
    // Add to front
    history.unshift(query);
    // Keep only max items
    if (history.length > MAX_HISTORY_ITEMS) {
      history = history.slice(0, MAX_HISTORY_ITEMS);
    }
    localStorage.setItem(SEARCH_HISTORY_KEY, JSON.stringify(history));
    renderSearchHistory();
  }

  function clearSearchHistory() {
    localStorage.removeItem(SEARCH_HISTORY_KEY);
    renderSearchHistory();
  }

  function renderSearchHistory() {
    const historyList = document.getElementById('search-history-list');
    const historySection = document.getElementById('search-history-section');
    if (!historyList || !historySection) return;

    const history = getSearchHistory();
    if (history.length === 0) {
      historySection.classList.add('hidden');
      return;
    }

    historySection.classList.remove('hidden');
    historyList.innerHTML = history.map(item => `
      <button class="px-2 py-1 bg-gray-100 rounded text-sm hover:bg-gray-200 cursor-pointer search-history-item">${item}</button>
    `).join('');

    // Add click handlers
    historyList.querySelectorAll('.search-history-item').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const text = e.target.textContent;
        var input = getInput();
        if (input) input.value = text;
        search(text);
      });
    });
  }

  // DOM Elements - always re-query to avoid stale references
  function getModal() { return document.getElementById('search-modal'); }
  function getInput() { return document.getElementById('search-input'); }
  function getBackdrop() { return document.getElementById('search-backdrop'); }
  function getInitialState() { return document.getElementById('search-initial'); }
  function getLoadingState() { return document.getElementById('search-loading'); }
  function getResultsContainer() { return document.getElementById('search-results-container'); }
  function getNoResults() { return document.getElementById('search-no-results'); }
  function getClearHistoryBtn() { return document.getElementById('clear-history'); }
  function getCloseBtn() { return document.getElementById('search-close-btn'); }

  let selectedIndex = -1;
  let currentResults: Array<{type: string, name: string, url: string, description: string, category?: string}> = [];

  function openModal() {
    var modal = getModal();
    var input = getInput();
    if (modal) {
      modal.classList.add('active');
      modal.setAttribute('aria-hidden', 'false');
    }
    if (input) input.focus();
    document.body.style.overflow = 'hidden';
    renderSearchHistory();
  }

  function closeModal() {
    var modal = getModal();
    var input = getInput();
    if (modal) {
      modal.classList.remove('active');
      modal.setAttribute('aria-hidden', 'true');
    }
    if (input) input.value = '';
    resetToInitialState();
    document.body.style.overflow = '';
    selectedIndex = -1;
  }

  function resetToInitialState() {
    getInitialState()?.classList.remove('hidden');
    getLoadingState()?.classList.add('hidden');
    getResultsContainer()?.classList.add('hidden');
    getNoResults()?.classList.add('hidden');
    var rc = getResultsContainer();
    if (rc) rc.innerHTML = '';
  }

  function showLoading() {
    getInitialState()?.classList.add('hidden');
    getLoadingState()?.classList.remove('hidden');
    getResultsContainer()?.classList.add('hidden');
    getNoResults()?.classList.add('hidden');
  }

  function showResults(results: typeof currentResults) {
    var loadingState = getLoadingState();
    var initialState = getInitialState();
    var noResultsEl = getNoResults();
    var resultsContainer = getResultsContainer();

    loadingState?.classList.add('hidden');
    initialState?.classList.add('hidden');
    noResultsEl?.classList.add('hidden');
    resultsContainer?.classList.remove('hidden');

    if (results.length === 0) {
      resultsContainer?.classList.add('hidden');
      noResults?.classList.remove('hidden');
      return;
    }

    currentResults = results;
    selectedIndex = -1;

    if (!resultsContainer) return;
    resultsContainer.innerHTML = `
      <div class="py-2">
        ${results.map((item, i) => `
          <a href="${item.url}"
             class="search-result flex items-start gap-3 px-4 py-3 hover:bg-gray-50 transition-colors"
             data-index="${i}">
            <div class="flex-shrink-0 w-8 h-8 rounded-lg bg-primary-100 text-primary-600 flex items-center justify-center">
              ${item.type === 'tool' ? `
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
                </svg>
              ` : item.type === 'community' ? `
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z" />
                </svg>
              ` : item.type === 'policy' ? `
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                </svg>
              ` : `
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
              `}
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2">
                <span class="font-medium text-gray-900">${item.name}</span>
                ${item.category ? `<span class="text-xs px-1.5 py-0.5 bg-gray-100 text-gray-600 rounded">${item.category}</span>` : ''}
                ${item.type === 'community' ? `<span class="text-xs px-1.5 py-0.5 bg-blue-50 text-blue-600 rounded">社区</span>` : ''}
                ${item.type === 'policy' ? `<span class="text-xs px-1.5 py-0.5 bg-green-50 text-green-600 rounded">政策</span>` : ''}
              </div>
              <p class="text-sm text-gray-500 truncate">${item.description}</p>
            </div>
            <svg class="w-4 h-4 text-gray-400 flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        `).join('')}
      </div>
    `;

    // Add hover effect for keyboard navigation
    updateSelection();
  }

  function updateSelection() {
    const items = document.querySelectorAll('.search-result');
    items.forEach((item, i) => {
      if (i === selectedIndex) {
        item.classList.add('bg-primary-50', 'border-l-2', 'border-primary-500');
      } else {
        item.classList.remove('bg-primary-50', 'border-l-2', 'border-primary-500');
      }
    });
  }

  async function search(query: string) {
    if (!query.trim()) {
      resetToInitialState();
      return;
    }

    showLoading();

    // Add to search history
    addToSearchHistory(query);

    // Load dynamic data (community posts, policies) on first search
    await loadDynamicSearchData();

    const q = query.toLowerCase();

    // Simulate a short delay for instant-appearing results
    setTimeout(() => {
      const results: typeof currentResults = [];

      // Search tools
      searchData.tools.forEach(tool => {
        if (
          tool.name.toLowerCase().includes(q) ||
          tool.description.toLowerCase().includes(q) ||
          tool.category.toLowerCase().includes(q)
        ) {
          results.push({ type: 'tool', ...tool, url: `/tools/${tool.slug}` });
        }
      });

      // Search pages
      searchData.pages.forEach(page => {
        if (
          page.name.toLowerCase().includes(q) ||
          page.description.toLowerCase().includes(q)
        ) {
          results.push({ type: 'page', ...page });
        }
      });

      // Search blog posts
      searchData.blog.forEach(post => {
        if (
          post.name.toLowerCase().includes(q) ||
          post.description.toLowerCase().includes(q)
        ) {
          results.push({ type: 'page', name: post.name, url: `/blog/${post.slug}`, description: post.description, category: '博客' });
        }
      });

      // Search payment solutions
      searchData.payment.forEach(item => {
        if (
          item.name.toLowerCase().includes(q) ||
          item.description.toLowerCase().includes(q)
        ) {
          results.push({ type: 'page', name: item.name, url: `/payment/${item.id}`, description: item.description, category: '支付' });
        }
      });

      // Search community posts
      if (searchData.community) {
        searchData.community.forEach(post => {
          if (
            post.name.toLowerCase().includes(q) ||
            post.description.toLowerCase().includes(q)
          ) {
            results.push({ type: 'community', ...post });
          }
        });
      }

      // Search university policies
      if (searchData.policies) {
        searchData.policies.forEach(policy => {
          if (
            policy.name.toLowerCase().includes(q) ||
            policy.description.toLowerCase().includes(q)
          ) {
            results.push({ type: 'policy', ...policy });
          }
        });
      }

      showResults(results.slice(0, 15));
    }, 200);
  }

  // Event Listeners
  document.addEventListener('keydown', (e) => {
    // Open modal with Ctrl+K or Cmd+K
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
      e.preventDefault();
      openModal();
    }

    // Close with ESC
    var modal = getModal();
    if (e.key === 'Escape' && modal?.classList.contains('active')) {
      closeModal();
    }

    // Keyboard navigation in modal
    if (modal?.classList.contains('active')) {
      const items = document.querySelectorAll('.search-result');

      if (e.key === 'ArrowDown') {
        e.preventDefault();
        selectedIndex = Math.min(selectedIndex + 1, items.length - 1);
        updateSelection();
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        selectedIndex = Math.max(selectedIndex - 1, -1);
        updateSelection();
      } else if (e.key === 'Enter' && selectedIndex >= 0) {
        e.preventDefault();
        items[selectedIndex]?.click();
      }
    }
  });

  // Click handlers - use event delegation for reliability
  document.addEventListener('click', (e) => {
    // Close button (X)
    if (e.target.closest('#search-close-btn')) {
      closeModal();
      return;
    }
    // Backdrop click
    if (e.target.id === 'search-backdrop') {
      closeModal();
      return;
    }
    // Clear history button
    if (e.target.closest('#clear-history')) {
      e.stopPropagation();
      clearSearchHistory();
      return;
    }
    // Trending search clicks
    if (e.target.closest('.search-trending')) {
      var btn = e.target.closest('.search-trending');
      var text = btn.textContent;
      var input = getInput();
      if (input) input.value = text;
      search(text);
      return;
    }
    // Search history item clicks
    if (e.target.closest('.search-history-item')) {
      var btn = e.target.closest('.search-history-item');
      var text = btn.textContent;
      var input = getInput();
      if (input) input.value = text;
      search(text);
      return;
    }
  });

  // Search input handler - use event delegation
  document.addEventListener('input', (e) => {
    if (e.target && e.target.id === 'search-input') {
      search((e.target as HTMLInputElement).value);
    }
  });

  // Expose open function for other components
  window.openSearch = openModal;
</script>
