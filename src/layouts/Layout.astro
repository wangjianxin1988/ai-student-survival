---
import '@/styles/global.css';
import SearchModal from '@/components/common/SearchModal.astro';
import Chatbot from '@/components/chatbot/Chatbot';
import { AuthProvider } from '@/components/auth/AuthProvider';
import ReactHeader from '@/components/ReactHeader';
import { type Locale, getLanguageSwitcherData, getAlternateUrl, t as translate, defaultLocale } from '@/i18n';

interface BreadcrumbItem {
  name: string;
  href?: string;
}

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  canonicalUrl?: string;
  jsonLd?: object | object[];
  faqItems?: Array<{ question: string; answer: string }>;
  locale?: Locale;
  breadcrumbs?: BreadcrumbItem[];
}

const {
  title,
  description,
  image = '/og-image.png',
  type = 'website',
  canonicalUrl = Astro.url.href,
  jsonLd,
  faqItems,
  locale = defaultLocale,
  breadcrumbs = [],
} = Astro.props;

const siteName = translate(locale, 'site.name');
const fullTitle = title === siteName ? title : `${title} | ${siteName}`;

// Language switcher data
const languageSwitcher = getLanguageSwitcherData(locale);

// Get alternate URL for language switching (uses path-based locale)
function getAlternatePath(loc: Locale): string {
  return getAlternateUrl(Astro.url, loc);
}
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <!-- Inline auth init: read Supabase session from localStorage before React hydrates. -->
    <!-- This prevents SSR/hydration mismatch where header shows "登录" briefly on load. -->
    <script is:inline>
    (function() {
      var demoRaw = null;
      try { demoRaw = sessionStorage.getItem('demo_session'); } catch(e) {}
      var user = null;
      if (demoRaw) {
        try { var d = JSON.parse(demoRaw); if (d && d.id) { user = { id: d.id, email: d.email || '', name: d.name, avatar_url: d.avatar }; } } catch(e) {}
      }
      if (!user) {
        // Scan all sb-* localStorage keys for Supabase auth token (Supabase v2.x uses this prefix)
        // Also check keys containing 'supabase' + 'auth' for older/supabase-admin-client format
        var keys = Object.keys(localStorage);
        for (var i = 0; i < keys.length; i++) {
          var k = keys[i];
          // Match: sb-* keys containing 'auth' or 'token', OR keys containing 'supabase' + 'auth'
          if (!k.startsWith('sb-')) continue;
          if (k.indexOf('auth') === -1 && k.indexOf('token') === -1) continue;
          var raw = null;
          try { raw = localStorage.getItem(k); } catch(e) {}
          if (!raw) continue;
          try {
            var p = JSON.parse(raw);
            var token = p.tokens && p.tokens.access_token || p.access_token;
            var refresh = p.tokens && p.tokens.refresh_token || p.refresh_token;
            if (token && refresh) {
              var parts = token.split('.');
              if (parts.length === 3) {
                var header = JSON.parse(atob(parts[0].replace(/-/g, '+').replace(/_/g, '/')));
                if (['ES256','RS256'].indexOf(header.alg) !== -1) {
                  var payload = JSON.parse(atob(parts[1].replace(/-/g, '+').replace(/_/g, '/')));
                  if (payload.sub) {
                    var u = p.user || (p.tokens && p.tokens.user);
                    if (u) { user = { id: u.id, email: u.email || '', name: u.user_metadata && (u.user_metadata.name || u.user_metadata.full_name) || '', avatar_url: u.user_metadata && (u.user_metadata.avatar_url || u.user_metadata.picture) || '' }; }
                    break;
                  }
                }
              }
            }
          } catch(e) {}
        }
      }
      // Also check for Supabase cookie-based session (Cloudflare Pages edge runtime)
      // Supabase stores session in a cookie named '__session' or 'sb-[ref]-auth-token' as cookie
      if (!user) {
        var cookieMap = {};
        if (document.cookie) {
          document.cookie.split(';').forEach(function(c) {
            var parts = c.trim().split('=');
            if (parts.length >= 2) {
              cookieMap[decodeURIComponent(parts[0])] = decodeURIComponent(parts.slice(1).join('='));
            }
          });
        }
        // Try Supabase cookie named 'sb-[ref]-auth-token' or '__session'
        var cookieNames = ['__session', 'sb-auth-token', 'supabase-auth-token'];
        for (var i = 0; i < cookieNames.length && !user; i++) {
          var cookieVal = cookieMap[cookieNames[i]];
          if (cookieVal) {
            try {
              // Cookie value is typically a JSON string with tokens
              var cookieData = JSON.parse(cookieVal);
              var cToken = cookieData.tokens && cookieData.tokens.access_token || cookieData.access_token;
              if (cToken) {
                var cParts = cToken.split('.');
                if (cParts.length === 3) {
                  var cHeader = JSON.parse(atob(cParts[0].replace(/-/g, '+').replace(/_/g, '/')));
                  if (['ES256', 'RS256'].indexOf(cHeader.alg) !== -1) {
                    var cPayload = JSON.parse(atob(cParts[1].replace(/-/g, '+').replace(/_/g, '/')));
                    if (cPayload.sub) {
                      var cUser = cookieData.user || (cookieData.tokens && cookieData.tokens.user);
                      if (cUser) {
                        user = { id: cUser.id, email: cUser.email || '', name: cUser.user_metadata && (cUser.user_metadata.name || cUser.user_metadata.full_name) || '', avatar_url: cUser.user_metadata && (cUser.user_metadata.avatar_url || cUser.user_metadata.picture) || '' };
                      }
                    }
                  }
                }
              }
            } catch(e) {}
          }
        }
      }
      window.__INITIAL_AUTH_USER__ = user;
    })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <title>{fullTitle}</title>
    <meta name="title" content={fullTitle} />
    <meta name="description" content={description} />
    <meta name="keywords" content={translate(locale, 'meta.keywords')} />
    <!-- Impact.com Site Verification -->
    <meta name="impact-site-verification" content="dfc72a07-7a08-4d08-b256-36c35a67bbd0" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content={locale === 'zh' ? 'zh_CN' : 'en_US'} />

    <!-- Alternate languages for SEO -->
    <link rel="alternate" hreflang="zh" href={getAlternatePath('zh')} />
    <link rel="alternate" hreflang="en" href={getAlternatePath('en')} />
    <link rel="alternate" hreflang="x-default" href={getAlternatePath('zh')} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalUrl} />
    <meta property="twitter:title" content={fullTitle} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={image} />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Google AdSense (activated after approval — replace ca-pub-XXXXXXXXXX with real ID) -->
    <script is:inline>
      (function() {
        var AD_CLIENT = 'ca-pub-XXXXXXXXXX'; // Replace with real publisher ID
        if (AD_CLIENT !== 'ca-pub-XXXXXXXXXX') {
          var s = document.createElement('script');
          s.async = true;
          s.crossOrigin = 'anonymous';
          s.src = 'https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=' + AD_CLIENT;
          document.head.appendChild(s);
        }
      })();
    </script>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <!-- Schema.org JSON-LD (page-specific) -->
    {Array.isArray(jsonLd) ? jsonLd.map(s => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    )) : jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    {/* BreadcrumbList JSON-LD */}
    {breadcrumbs.length > 0 && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": breadcrumbs.map((item, index) => ({
          "@type": "ListItem",
          "position": index + 1,
          "name": item.name,
          ...(item.href && { "item": item.href })
        }))
      })} />
    )}

    {/* FAQPage JSON-LD (injected from page-level faqItems prop) */}
    {faqItems && faqItems.length > 0 && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": faqItems.map(item => ({
          "@type": "Question",
          "name": item.question,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": item.answer
          }
        }))
      })} />
    )}

    <!-- Organization Schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "@id": "https://mi-to-ai.com/#org",
      "name": siteName,
      "url": "https://mi-to-ai.com",
      "logo": "https://mi-to-ai.com/favicon.svg",
      "description": locale === 'zh'
        ? "为海外留学生打造的AI工具导航、大学AI政策数据库和支付解决方案平台"
        : "AI tools navigator, university AI policy database, and payment solutions for international students",
      "sameAs": [
        "https://github.com/wangjianxin1988/ai-student-survival",
        "https://twitter.com/mitoai",
        "https://discord.gg/mitoai"
      ]
    })} />

  </head>
  <body class="min-h-screen bg-gray-50 text-gray-900 antialiased">

    <!-- AuthProvider wraps ALL components that need auth context. client:only skips SSR to avoid hydration mismatch. -->
    <!-- NOTE: ReactHeader has NO client directive so it renders inline within AuthProvider's island, -->
    <!-- sharing the same React context. UserMenu (inside ReactHeader) can access AuthProvider's auth state. -->
    <!-- Language switcher is rendered inside ReactHeader's top bar (not floating) for clean UX on all pages. -->
    <AuthProvider client:only="react">
      <ReactHeader
        locale={locale}
        currentPath={Astro.url.pathname}
        siteName={siteName}
        languageSwitcher={languageSwitcher}
        getAlternateUrl={getAlternatePath}
        client:only="react"
      />
      <!-- Astro components and slot content -->
      <slot />
      <SearchModal locale={locale} />
      <Chatbot client:load locale={locale} />
    </AuthProvider>

    <script is:inline>
      // Connect search trigger button to search modal
      document.querySelectorAll('[data-search-trigger]').forEach(btn => {
        btn.addEventListener('click', () => {
          var modal = document.getElementById('search-modal');
          var input = document.getElementById('search-input');
          if (modal) {
            modal.classList.add('active');
            modal.setAttribute('aria-hidden', 'false');
            if (input) input.focus();
            document.body.style.overflow = 'hidden';
          }
        });
      });
    </script>

    <!-- Monetag In-Page Push (全站浮动广告) -->
    <script is:inline>(function(s){s.dataset.zone='11076692',s.src='https://nap5k.com/tag.min.js'})([document.documentElement, document.body].filter(Boolean).pop().appendChild(document.createElement('script')))</script>
    <!-- 强制移动广告到左下角 + 去重（只处理 body 直接子元素） -->
    <script is:inline>
    (function() {
      var adKept = false;
      // 已知的本站固定元素（不动）
      var SAFE_IDS = /^chatbot|^search-modal|^ask-ai|^__next|^__layout|^astro/;
      var SAFE_CLS = /chatbot|search-modal|react-header|astro-island|language-switcher/i;
      
      function tryRelocate() {
        var kids = document.body.children;
        for (var i = 0; i < kids.length; i++) {
          var el = kids[i];
          var tag = el.tagName;
          // 只看 div/iframe/ins
          if (tag !== 'DIV' && tag !== 'IFRAME' && tag !== 'INS') continue;
          // 必须是 fixed
          var s = el.getAttribute('style') || '';
          if (s.indexOf('fixed') === -1 && s.indexOf('Fixed') === -1) continue;
          // 排除已知元素
          if (SAFE_IDS.test(el.id || '')) continue;
          if (SAFE_CLS.test(el.className && el.className.toString ? el.className.toString() : '')) continue;
          
          if (adKept) {
            el.style.setProperty('display', 'none', 'important');
            continue;
          }
          adKept = true;
          // 强制左下角
          el.style.setProperty('left', '16px', 'important');
          el.style.setProperty('bottom', '16px', 'important');
          el.style.setProperty('right', 'auto', 'important');
          el.style.setProperty('top', 'auto', 'important');
          // transform 兜底
          var rect = el.getBoundingClientRect();
          var dx = 16 - rect.left;
          var dy = window.innerHeight - rect.bottom - 16;
          el.style.setProperty('transform', 'translate(' + dx + 'px,' + dy + 'px)', 'important');
        }
      }
      
      // 定时扫描
      var timer = setInterval(tryRelocate, 500);
      setTimeout(function() { clearInterval(timer); }, 15000);
    })();
    </script>

  </body>
</html>

<style is:global>
  @tailwind base;
  @tailwind components;
  @tailwind utilities;

  /* Scrollbar styles */
  ::-webkit-scrollbar {
    width: 8px;
    height: 8px;
  }

  ::-webkit-scrollbar-track {
    background: #f1f1f1;
  }

  ::-webkit-scrollbar-thumb {
    background: #c1c1c1;
    border-radius: 4px;
  }

  /* Monetag 广告兜底：transform 绕过 inline style */
  /* 注意：如果 Monetag 用 iframe，这不会生效 */
  div[style*="position"][style*="fixed"][style*="z-index"],
  div[style*="position:fixed"][style*="z-index"],
  ins[style*="fixed"] {
    left: 16px !important;
    bottom: 16px !important;
    right: auto !important;
    top: auto !important;
  }

  ::-webkit-scrollbar-thumb:hover {
    background: #a1a1a1;
  }

  /* Focus styles */
  *:focus-visible {
    @apply outline-none ring-2 ring-primary-500 ring-offset-2;
  }

  /* Hide scrollbar utility */
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>