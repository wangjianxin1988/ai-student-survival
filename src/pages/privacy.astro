---
export const prerender = false;

import Layout from '@/layouts/Layout.astro';
import { type Locale, t as translate, getLocaleFromUrl, defaultLocale } from '@/i18n';

// Get locale from URL
const locale: Locale = getLocaleFromUrl(Astro.url);

// Helper to generate locale-aware hrefs
function getLocaleHref(path: string): string {
  if (locale === defaultLocale) {
    return path;
  }
  return `/${locale}${path}`;
}
---

<Layout
  title={translate(locale, 'nav.privacy')}
  description="MI TO AI留学生存指南的隐私政策，说明我们如何收集、使用和保护您的个人信息。"
  locale={locale}
>
  <!-- Hero Section -->
  <section class="hero-gradient text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-4xl lg:text-5xl font-bold mb-4">{translate(locale, 'privacy.hero.title')}</h1>
        <p class="text-xl text-primary-100">
          {translate(locale, 'privacy.hero.lastUpdate')}: 2026-01-01
        </p>
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="prose prose-lg max-w-none">
        <!-- Introduction -->
        <div class="mb-12">
          <h2 class="text-2xl font-bold mb-4">{translate(locale, 'privacy.intro.title')}</h2>
          <p class="text-gray-600">
            {translate(locale, 'privacy.intro.desc')}
          </p>
        </div>

        <!-- Information We Collect -->
        <div class="mb-12">
          <h2 class="text-2xl font-bold mb-4">{translate(locale, 'privacy.collect.title')}</h2>

          <div class="bg-gray-50 rounded-xl p-6 mb-6">
            <h3 class="text-lg font-semibold mb-3">{translate(locale, 'privacy.collect.personal.title')}</h3>
            <ul class="list-disc list-inside text-gray-600 space-y-2">
              <li>{translate(locale, 'privacy.collect.personal.items.email')}</li>
              <li>{translate(locale, 'privacy.collect.personal.items.name')}</li>
              <li>{translate(locale, 'privacy.collect.personal.items.avatar')}</li>
              <li>{translate(locale, 'privacy.collect.personal.items.preferences')}</li>
            </ul>
          </div>

          <div class="bg-gray-50 rounded-xl p-6 mb-6">
            <h3 class="text-lg font-semibold mb-3">{translate(locale, 'privacy.collect.usage.title')}</h3>
            <ul class="list-disc list-inside text-gray-600 space-y-2">
              <li>{translate(locale, 'privacy.collect.usage.items.usage')}</li>
              <li>{translate(locale, 'privacy.collect.usage.items.device')}</li>
              <li>{translate(locale, 'privacy.collect.usage.items.logs')}</li>
            </ul>
          </div>

          <div class="bg-gray-50 rounded-xl p-6">
            <h3 class="text-lg font-semibold mb-3">{translate(locale, 'privacy.collect.thirdParty.title')}</h3>
            <p class="text-gray-600 mb-4">{translate(locale, 'privacy.collect.thirdParty.desc')}</p>
            <ul class="list-disc list-inside text-gray-600 space-y-2">
              <li>{translate(locale, 'privacy.collect.thirdParty.items.analytics')}</li>
              <li>{translate(locale, 'privacy.collect.thirdParty.items.auth')}</li>
              <li>{translate(locale, 'privacy.collect.thirdParty.items.cdn')}</li>
            </ul>
          </div>
        </div>

        <!-- How We Use Information -->
        <div class="mb-12">
          <h2 class="text-2xl font-bold mb-4">{translate(locale, 'privacy.usage.title')}</h2>
          <ul class="list-disc list-inside text-gray-600 space-y-3">
            <li>{translate(locale, 'privacy.usage.items.service')}</li>
            <li>{translate(locale, 'privacy.usage.items.personalize')}</li>
            <li>{translate(locale, 'privacy.usage.items.improve')}</li>
            <li>{translate(locale, 'privacy.usage.items.communication')}</li>
            <li>{translate(locale, 'privacy.usage.items.security')}</li>
          </ul>
        </div>

        <!-- Data Protection -->
        <div class="mb-12">
          <h2 class="text-2xl font-bold mb-4">{translate(locale, 'privacy.protection.title')}</h2>
          <div class="bg-green-50 border border-green-200 rounded-xl p-6">
            <ul class="list-disc list-inside text-gray-700 space-y-3">
              <li>{translate(locale, 'privacy.protection.items.encryption')}</li>
              <li>{translate(locale, 'privacy.protection.items.access')}</li>
              <li>{translate(locale, 'privacy.protection.items.retention')}</li>
              <li>{translate(locale, 'privacy.protection.items.employees')}</li>
            </ul>
          </div>
        </div>

        <!-- Cookies -->
        <div class="mb-12">
          <h2 class="text-2xl font-bold mb-4">{translate(locale, 'privacy.cookies.title')}</h2>
          <p class="text-gray-600 mb-4">{translate(locale, 'privacy.cookies.desc')}</p>
          <div class="bg-gray-50 rounded-xl p-6">
            <h3 class="text-lg font-semibold mb-3">{translate(locale, 'privacy.cookies.types.title')}</h3>
            <ul class="list-disc list-inside text-gray-600 space-y-2">
              <li><strong>{translate(locale, 'privacy.cookies.types.essential.title')}</strong>: {translate(locale, 'privacy.cookies.types.essential.desc')}</li>
              <li><strong>{translate(locale, 'privacy.cookies.types.analytics.title')}</strong>: {translate(locale, 'privacy.cookies.types.analytics.desc')}</li>
              <li><strong>{translate(locale, 'privacy.cookies.types.preferences.title')}</strong>: {translate(locale, 'privacy.cookies.types.preferences.desc')}</li>
            </ul>
          </div>
        </div>

        <!-- User Rights -->
        <div class="mb-12">
          <h2 class="text-2xl font-bold mb-4">{translate(locale, 'privacy.rights.title')}</h2>
          <p class="text-gray-600 mb-4">{translate(locale, 'privacy.rights.desc')}</p>
          <div class="grid md:grid-cols-2 gap-4">
            <div class="bg-gray-50 rounded-lg p-4">
              <h4 class="font-semibold mb-2">{translate(locale, 'privacy.rights.access.title')}</h4>
              <p class="text-sm text-gray-600">{translate(locale, 'privacy.rights.access.desc')}</p>
            </div>
            <div class="bg-gray-50 rounded-lg p-4">
              <h4 class="font-semibold mb-2">{translate(locale, 'privacy.rights.correction.title')}</h4>
              <p class="text-sm text-gray-600">{translate(locale, 'privacy.rights.correction.desc')}</p>
            </div>
            <div class="bg-gray-50 rounded-lg p-4">
              <h4 class="font-semibold mb-2">{translate(locale, 'privacy.rights.deletion.title')}</h4>
              <p class="text-sm text-gray-600">{translate(locale, 'privacy.rights.deletion.desc')}</p>
            </div>
            <div class="bg-gray-50 rounded-lg p-4">
              <h4 class="font-semibold mb-2">{translate(locale, 'privacy.rights.portability.title')}</h4>
              <p class="text-sm text-gray-600">{translate(locale, 'privacy.rights.portability.desc')}</p>
            </div>
          </div>
        </div>

        <!-- Data Retention -->
        <div class="mb-12">
          <h2 class="text-2xl font-bold mb-4">{translate(locale, 'privacy.retention.title')}</h2>
          <p class="text-gray-600">
            {translate(locale, 'privacy.retention.desc')}
          </p>
        </div>

        <!-- Children's Privacy -->
        <div class="mb-12">
          <h2 class="text-2xl font-bold mb-4">{translate(locale, 'privacy.children.title')}</h2>
          <p class="text-gray-600">
            {translate(locale, 'privacy.children.desc')}
          </p>
        </div>

        <!-- Changes to Policy -->
        <div class="mb-12">
          <h2 class="text-2xl font-bold mb-4">{translate(locale, 'privacy.changes.title')}</h2>
          <p class="text-gray-600">
            {translate(locale, 'privacy.changes.desc')}
          </p>
        </div>

        <!-- Contact -->
        <div class="bg-primary-50 rounded-xl p-8">
          <h2 class="text-2xl font-bold mb-4">{translate(locale, 'privacy.contact.title')}</h2>
          <p class="text-gray-600 mb-4">
            {translate(locale, 'privacy.contact.desc')}
          </p>
          <p class="text-gray-600">
            Email: privacy@mi-to-ai.com
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Navigation -->
  <section class="py-8 bg-gray-50 border-t">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center">
        <a href={getLocaleHref('/terms')} class="text-primary-600 hover:text-primary-700 flex items-center">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          {translate(locale, 'nav.terms')}
        </a>
        <a href={getLocaleHref('/about')} class="text-primary-600 hover:text-primary-700 flex items-center">
          {translate(locale, 'nav.about')}
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</Layout>