---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import CampusMap from '@/components/map/CampusMap';
import AddMarkerForm from '@/components/map/AddMarkerForm';
import { universities } from '@/data/map-markers';

const currentPath = '/map/add';
---

<Layout title="添加校园标记 - MI TO AI留学生存指南">
  <Header currentPath={currentPath} locale="zh" slot="header" />

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Page Header -->
    <div class="mb-8">
      <div class="flex items-center gap-3 mb-2">
        <a href="/map" class="text-gray-500 hover:text-gray-700">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
        </a>
        <h1 class="text-3xl font-bold text-gray-900">添加校园标记</h1>
      </div>
      <p class="text-gray-600 ml-8">在地图上标记校园设施，帮助其他留学生找到需要的地方</p>
    </div>

    <!-- Info Banner -->
    <div class="mb-6 p-4 bg-blue-50 border border-blue-200 rounded-lg">
      <div class="flex gap-3">
        <svg class="w-5 h-5 text-blue-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <div class="text-sm text-blue-800">
          <p class="font-medium mb-1">标记说明</p>
          <ul class="list-disc list-inside space-y-1 text-blue-700">
            <li>标记提交后需要审核才会显示在地图上</li>
            <li>请确保标记信息准确反映实际位置</li>
            <li>点击地图选择标记位置</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <!-- Map Section -->
      <div class="space-y-4">
        <h2 class="text-lg font-semibold text-gray-900">选择位置</h2>
        <div id="map-container">
          <CampusMap
            client:only="react"
            markers={[]}
            height="450px"
            isAddMode={true}
            universities={universities}
            onMapClick={(lat, lng) => {
              window.dispatchEvent(new CustomEvent('coordinates-updated', {
                detail: { lat, lng }
              }));
            }}
          />
        </div>
        <p class="text-sm text-gray-500">
          <span class="text-primary-500">提示：</span>点击地图上的任意位置来设置标记坐标
        </p>
      </div>

      <!-- Form Section -->
      <div class="space-y-4">
        <h2 class="text-lg font-semibold text-gray-900">标记信息</h2>
        <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-200">
          <AddMarkerForm
            client:load
          />
        </div>
      </div>
    </div>

    <!-- Recent Submissions -->
    <div class="mt-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">我的提交</h2>
      <div id="my-submissions" class="space-y-3">
        <p class="text-gray-500 text-sm">暂无提交记录</p>
      </div>
    </div>
  </main>

  <script>
    import { saveUGCMarker, getUGCMarkers } from '@/lib/marker-storage';
    import { supabase, isSupabaseConfigured, createCampusMarker, getMyCampusMarkers, getCampusMarkers, DbCampusMarker } from '@/lib/supabase';
    import { CATEGORY_ICONS } from '@/lib/types';
    import type { MapMarker } from '@/lib/types';
    import { universities } from '@/data/map-markers';

    const MARKER_COST = 10; // 每次标记消耗10积分

    // Determine if we're in demo mode (no real auth)
    function isDemoUser(): boolean {
      try {
        const session = sessionStorage.getItem('demo_session');
        return !!session;
      } catch { return false; }
    }

    // 获取用户积分（从sessionStorage的demo用户）
    function getUserPoints() {
      try {
        const session = sessionStorage.getItem('demo_session');
        if (session) {
          const user = JSON.parse(session);
          return user.points || 0;
        }
      } catch (e) {}
      return 0;
    }

    // 扣除积分
    function deductPoints(amount: number) {
      try {
        const session = sessionStorage.getItem('demo_session');
        if (session) {
          const user = JSON.parse(session);
          user.points = (user.points || 0) - amount;
          sessionStorage.setItem('demo_session', JSON.stringify(user));
          return true;
        }
      } catch (e) {}
      return false;
    }

    // Listen for form submissions from AddMarkerForm
    document.addEventListener('marker-form-submit', async (e: CustomEvent) => {
      const markerData = e.detail;

      try {
        // In demo mode, check and deduct points from sessionStorage
        if (isDemoUser() && !isSupabaseConfigured) {
          const userPoints = getUserPoints();
          if (userPoints < MARKER_COST) {
            showNotification(`积分不足！需要${MARKER_COST}积分，您的余额为${userPoints}积分`, 'error');
            return;
          }
          deductPoints(MARKER_COST);
        }

        let saved: any;
        const university = universities.find(u => u.id === markerData.universityId);
        const markerWithUni = {
          ...markerData,
          universityName: university?.nameZh || university?.name || markerData.universityName || '',
        };

        // Try to save to Supabase first (real database)
        if (isSupabaseConfigured) {
          try {
            saved = await createCampusMarker({
              universityId: markerData.universityId,
              name: markerData.name,
              category: markerData.category,
              description: markerData.description || '',
              coordinates: markerData.coordinates,
              images: markerData.images || [],
              tags: markerData.tags || [],
            });
          } catch (err) {
            console.warn('Supabase insert failed, falling back to localStorage:', err);
          }
        }

        // Fall back to localStorage if Supabase insert failed or not configured
        if (!saved) {
          saved = saveUGCMarker(markerWithUni, 'approved');
        }

        // Show success message
        showNotification(`标记已发布！消耗${MARKER_COST}积分`, 'success');

        // Update submissions list
        updateSubmissionsList();

        // Redirect to map after short delay
        setTimeout(() => {
          window.location.href = '/map';
        }, 1500);
      } catch (error) {
        console.error('Failed to save marker:', error);
        showNotification('提交失败，请重试', 'error');
      }
    });

    // Show notification
    function showNotification(message: string, type: 'success' | 'error') {
      const notification = document.createElement('div');
      notification.className = `fixed bottom-4 right-4 px-6 py-3 rounded-lg shadow-lg z-50 ${
        type === 'success' ? 'bg-green-500 text-white' : 'bg-red-500 text-white'
      }`;
      notification.textContent = message;
      document.body.appendChild(notification);

      setTimeout(() => {
        notification.remove();
      }, 3000);
    }

    // Update submissions list
    async function updateSubmissionsList() {
      const container = document.getElementById('my-submissions');
      if (!container) return;

      let localMarkers: any[] = [];
      let dbMarkers: DbCampusMarker[] = [];

      // Always load localStorage markers (for demo mode)
      localMarkers = getUGCMarkers();

      // Try to load Supabase markers if configured
      if (isSupabaseConfigured) {
        try {
          dbMarkers = await getMyCampusMarkers();
        } catch (e) {
          console.warn('Could not fetch Supabase markers:', e);
        }
      }

      // Merge local and Supabase markers (deduplicate by id)
      const allMarkers = [
        ...dbMarkers.map(m => ({
          id: m.id,
          name: m.name,
          category: m.category,
          universityName: universities.find(u => u.id === m.university_id)?.nameZh || m.university_id,
          status: m.status,
          source: 'db' as const,
        })),
        ...localMarkers
          .filter(m => !dbMarkers.some(db => db.id === m.id))
          .map(m => ({
            id: m.id,
            name: m.name,
            category: m.category,
            universityName: m.universityName,
            status: m.status,
            source: 'local' as const,
          })),
      ];

      if (allMarkers.length === 0) {
        container.innerHTML = '<p class="text-gray-500 text-sm">暂无提交记录</p>';
        return;
      }

      container.innerHTML = allMarkers.slice(-5).reverse().map(marker => `
        <div class="bg-white p-4 rounded-lg shadow-sm border border-gray-200 flex items-center justify-between">
          <div class="flex items-center gap-3">
            <span class="text-2xl">${CATEGORY_ICONS[marker.category as keyof typeof CATEGORY_ICONS] || '📍'}</span>
            <div>
              <p class="font-medium text-gray-900">${marker.name}</p>
              <p class="text-sm text-gray-500">${marker.universityName}</p>
            </div>
          </div>
          <span class="px-2 py-1 text-xs font-medium rounded-full ${
            marker.status === 'pending' ? 'bg-yellow-100 text-yellow-700' :
            marker.status === 'approved' ? 'bg-green-100 text-green-700' :
            'bg-red-100 text-red-700'
          }">
            ${marker.status === 'pending' ? '待审核' :
              marker.status === 'approved' ? '已通过' : '已拒绝'}
          </span>
        </div>
      `).join('');
    }

    // Initial update
    updateSubmissionsList();
  </script>
</Layout>