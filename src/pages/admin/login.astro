---
import Layout from '@/layouts/Layout.astro';

export const prerender = false;

// Detect locale from URL path
const urlPath = Astro.url.pathname;
const locale = urlPath.startsWith('/en') ? 'en' : 'zh';

const titles = {
  zh: { title: '管理员登录', h1: '管理后台', subtitle: '请登录以访问管理后台' },
  en: { title: 'Admin Login', h1: 'Admin Panel', subtitle: 'Sign in to access the admin panel' },
};

const t = titles[locale];
---

<Layout title={t.title} description={t.subtitle} locale={locale}>
  <div class="min-h-screen flex items-center justify-center bg-gray-100 py-12 px-4">
    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <div class="inline-flex items-center justify-center w-16 h-16 bg-primary-100 rounded-full mb-4">
          <svg class="w-8 h-8 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
          </svg>
        </div>
        <h1 class="text-3xl font-bold text-gray-900">{t.h1}</h1>
        <p class="mt-2 text-gray-600">{t.subtitle}</p>
      </div>

      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8">
        <form id="loginForm" class="space-y-6">
          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-2">
              {locale === 'zh' ? '管理员邮箱' : 'Admin Email'}
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              autocomplete="email"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-colors"
              placeholder="admin@example.com"
            />
          </div>

          <div>
            <label for="password" class="block text-sm font-medium text-gray-700 mb-2">
              {locale === 'zh' ? '密码' : 'Password'}
            </label>
            <input
              type="password"
              id="password"
              name="password"
              required
              autocomplete="current-password"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-colors"
              placeholder="••••••••"
            />
          </div>

          <div id="errorMessage" class="hidden p-3 bg-red-50 border border-red-200 rounded-lg text-red-600 text-sm"></div>

          <div id="successMessage" class="hidden p-3 bg-green-50 border border-green-200 rounded-lg text-green-600 text-sm"></div>

          <button
            type="submit"
            id="submitBtn"
            class="w-full py-3 px-4 bg-primary-600 hover:bg-primary-700 text-white font-medium rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
          >
            <span id="btnText">{locale === 'zh' ? '登录' : 'Sign In'}</span>
            <span id="btnLoading" class="hidden">
              <svg class="animate-spin inline-block w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
              </svg>
              {locale === 'zh' ? '登录中...' : 'Signing in...'}
            </span>
          </button>
        </form>

        <div class="mt-6 p-4 bg-blue-50 border border-blue-200 rounded-lg">
          <h3 class="font-semibold text-blue-900 text-sm mb-2">
            {locale === 'zh' ? '演示账号' : 'Demo Accounts'}
          </h3>
          <div class="text-sm text-blue-800 space-y-1">
            <p><strong>Admin:</strong> admin@ai-student-survival.com / admin123</p>
            <p><strong>Editor:</strong> editor@ai-student-survival.com / editor123</p>
            <p class="text-xs text-blue-600 mt-2">{locale === 'zh' ? '（仅演示模式可用）' : '(Demo mode only)'}</p>
          </div>
        </div>

        <div class="mt-6 text-center">
          <a href={locale === 'zh' ? '/' : '/en/'} class="text-sm text-gray-600 hover:text-primary-600 transition-colors">
            ← {locale === 'zh' ? '返回首页' : 'Back to Home'}
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  // Admin credentials (demo mode - in production these should be server-side validated)
  const ADMIN_CREDENTIALS = [
    { email: 'admin@ai-student-survival.com', password: 'admin123', role: 'admin', name: 'Administrator' },
    { email: 'editor@ai-student-survival.com', password: 'editor123', role: 'editor', name: 'Editor' },
  ];

  const form = document.getElementById('loginForm') as HTMLFormElement;
  const emailInput = document.getElementById('email') as HTMLInputElement;
  const passwordInput = document.getElementById('password') as HTMLInputElement;
  const errorDiv = document.getElementById('errorMessage') as HTMLDivElement;
  const successDiv = document.getElementById('successMessage') as HTMLDivElement;
  const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
  const btnText = document.getElementById('btnText') as HTMLSpanElement;
  const btnLoading = document.getElementById('btnLoading') as HTMLSpanElement;

  // Check if already logged in
  const storedAdmin = sessionStorage.getItem('admin_session');
  if (storedAdmin) {
    window.location.href = '/admin';
  }

  function showError(msg) {
    errorDiv.textContent = msg;
    errorDiv.classList.remove('hidden');
    successDiv.classList.add('hidden');
  }

  function showSuccess(msg) {
    successDiv.textContent = msg;
    successDiv.classList.remove('hidden');
    errorDiv.classList.add('hidden');
  }

  function setLoading(loading) {
    submitBtn.disabled = loading;
    btnText.classList.toggle('hidden', loading);
    btnLoading.classList.toggle('hidden', !loading);
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    setLoading(true);
    showError('');
    successDiv.classList.add('hidden');

    const email = emailInput.value.trim();
    const password = passwordInput.value;

    // Simulate network delay
    await new Promise(resolve => setTimeout(resolve, 800));

    // Find matching admin credential
    const admin = ADMIN_CREDENTIALS.find(a => a.email === email && a.password === password);

    if (admin) {
      showSuccess(locale === 'zh' ? '登录成功，正在跳转...' : 'Login successful, redirecting...');

      // Store session
      const session = {
        email: admin.email,
        name: admin.name,
        role: admin.role,
        loginAt: new Date().toISOString(),
      };
      sessionStorage.setItem('admin_session', JSON.stringify(session));

      setTimeout(() => {
        window.location.href = '/admin';
      }, 500);
    } else {
      showError(locale === 'zh' ? '邮箱或密码错误' : 'Invalid email or password');
      setLoading(false);
    }
  });
</script>
