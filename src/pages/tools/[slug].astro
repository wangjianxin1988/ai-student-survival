        { title: '阿里云生态集成', description: '与钉钉、阿里云函数计算、PAI等阿里产品深度集成，企业用户可直接在阿里云环境部署Qwen应用' }
      ],
      tips: [
        '模型规模选择：7B适合简单问答和文案，14B可做复杂推理和多轮对话，72B/110B适合对质量要求高的创意任务',
        '中文优化：Qwen2.5预训练数据中中文占比高，日常中文场景比同等规模Llama模型效果更好',
        '工具调用：Qwen2.5支持ReAct模式的Tool Use，可接入搜索、数据库等外部工具构建Agent',
        '长上下文：Qwen2.5-Instruct支持32K上下文，处理长文档时比Llama更稳定，但长上下文会增加显存占用'
      ],
      updateNotes: '2026年更新: Qwen3系列发布(128K上下文)，Qwen2.5-72B开源最新版本。Qwen-Waabi端侧模型发布(1.5B/0.5B可在手机运行)。阿里云DashScope新增Qwen-VL多模态API'
    },
    updateSourceUrl: 'https://github.com/QwenLM/Qwen3/releases',
    updateSourceType: 'github',
  },
  'chatglm': {
    id: '48',
    name: 'ChatGLM',
    slug: 'chatglm',
    description: '清华智谱AI开发的千亿参数大模型，开源ChatGLM2-6B/GLM-4系列，中文理解能力强。ChatGLM是中国大模型发展的重要里程碑。',
    category: 'communication',
    subcategory: 'llm',
    pricing: 'free',
    priceDetail: { monthly: 0, yearly: 0, currency: 'USD' },
    url: 'https://chatglm.cn',
    imageUrl: 'https://placehold.co/800x400/10b981/ffffff?text=ChatGLM',
    rating: 4.5,
    ratingCount: 4800,
    dimensions: { easeOfUse: 4.3, features: 4.6, value: 4.7 },
    tags: ['大模型', '清华', '开源', '中文', '千亿参数'],
    features: ['千亿参数', '中文优化', '开源版本', '微调支持', '本地部署', '多模态'],
    alternatives: ['qwen', 'deepseek'],
    isNew: true,
    createdAt: '2024-06-01',
    updatedAt: '2024-05-18',
    details: {
      howToUse: [
        { step: 1, title: '选择部署方式', description: '本地部署: 下载ChatGLM3系列GGUF模型用Ollama/LM Studio。API调用: 智谱AI开放平台(glmnlp.com)申请API Key' },
        { step: 2, title: '本地模型运行', description: 'ollama pull chatglm3 或 ollama pull chatglm4。ChatGLM4-9B推荐配置12GB+显存，6B版本8GB可跑。支持INT4量化' },
        { step: 3, title: 'API集成', description: 'pip install zhipuai SDK。调用示例: client = ZhipuAI(api_key=\'your_key\'); response = client.chat.completions.create(model=\'glm-4\', messages=[...])' }
      ],
      useCases: [
        { title: '中文对话与问答', description: 'ChatGLM4在中文语义理解上有优势，适合智能客服、知识问答、文本生成等场景。GLM-4-AllTools版本支持网页搜索、代码执行' },
        { title: '长文档处理', description: 'ChatGLM4支持128K超长上下文，可用于长篇文档摘要、跨文档检索、论文精读等需要处理大量文本的任务' },
        { title: '金融/法律专业场景', description: '智谱提供行业微调版本(GLG-Finance等)，针对金融分析、法律咨询场景优化，API版本稳定性和SLA有保障' },
        { title: '多模态应用', description: 'GLM-4Vision支持图片理解和对话，可用于图文问答、视觉推理、海报设计等需要图片理解的应用' }
      ],
      tips: [
        'API vs 本地：API版本(glm-4)能力最强但有成本，本地6B/9B模型适合简单场景或隐私要求高的用例',
        '微调版本：智谱提供行业定制微调服务，适合企业有特定领域需求但缺乏微调能力的场景',
        'Token优化：中文对话建议开启cache.md功能，重复上下文不重复计费，有效降低成本',
        'Function Calling：GLM-4支持工具调用，适合构建Agent应用，可对接外部API、数据库、搜索等工具'
      ],
      updateNotes: '2026年更新: GLM-5系列内测中(新一代基座)，ChatGLM4性能持续优化。智谱AI新增企业版API支持私有化部署。GLM-4-AllTools正式版发布，集成代码解释器、网页搜索、DALL-E绘图'
    },
    updateSourceUrl: 'https://github.com/THUDM/ChatGLM3/releases',
    updateSourceType: 'github',
  },
};

const tool = toolsData[slug as string];

if (!tool) {
  return Astro.redirect('/tools');
}

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": ["Product", "SoftwareApplication"],
    "name": tool.name,
    "description": tool.description,
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "url": tool.url,
    "image": tool.imageUrl,
    "brand": {
      "@type": "Brand",
      "name": tool.name
    },
    "offers": {
      "@type": "Offer",
      "price": tool.priceDetail.monthly?.toString() || "0",
      "priceCurrency": tool.priceDetail.currency,
      "availability": "https://schema.org/InStock",
      "priceType": "starting from"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": tool.rating.toString(),
      "reviewCount": tool.ratingCount.toString(),
      "ratingExplanation": `${tool.rating} out of 5 stars based on ${tool.ratingCount} reviews`
    },
    "featureList": tool.features.join(', '),
    "keywords": tool.tags.join(', '),
    "category": tool.category,
    "additionalProperty": [
      {
        "@type": "PropertyValue",
        "name": "easeOfUse",
        "value": tool.dimensions.easeOfUse.toString()
      },
      {
        "@type": "PropertyValue",
        "name": "features",
        "value": tool.dimensions.features.toString()
      },
      {
        "@type": "PropertyValue",
        "name": "value",
        "value": tool.dimensions.value.toString()
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": `https://mi-to-ai.com/tools/${tool.slug}`
    },
    "headline": `${tool.name} - AI工具完全指南`,
    "description": tool.description,
    "author": {
      "@type": "Person",
      "name": "MI TO AI编辑团队"
    },
    "datePublished": tool.createdAt || "2025-01-15",
    "dateModified": tool.updatedAt || "2026-05-29",
    "publisher": {
      "@id": "https://mi-to-ai.com/#org"
    },
    "about": {
      "@type": "Product",
      "name": tool.name,
      "description": tool.description
    },
    "image": tool.imageUrl
  },
  // FAQPage Schema
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": `${tool.name}免费版和付费版有什么区别？`,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": tool.pricing === 'free'
            ? `${tool.name}目前完全免费使用。`
            : tool.pricing === 'freemium'
              ? `${tool.name}提供免费版和付费版。免费版包含基础功能，付费版（$${tool.priceDetail.monthly}/月起）解锁更多高级特性，包括更强的模型能力、更高的使用额度和优先访问权。`
              : `${tool.name}是付费工具，$${tool.priceDetail.monthly}/月起，提供完整功能体验。`
        }
      },
      {
        "@type": "Question",
        "name": `留学生可以使用${tool.name}吗？`,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": `是的，留学生可以使用${tool.name}。但请注意你所在大学的AI使用政策，部分课程可能限制AI工具的使用。建议查看学校的具体规定，在允许的范围内合理使用。`
        }
      },
      {
        "@type": "Question",
        "name": `${tool.name}的支付方式有哪些？`,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": tool.pricing === 'free'
            ? `${tool.name}免费使用，无需支付。`
            : `订阅${tool.name}可使用国际信用卡、虚拟卡（如Depay、Noble）、礼品卡等支付方式。中国用户还可通过低价区注册享受更优惠的价格。详见我们的支付解决方案页面。`
        }
      }
    ]
  },
  // HowTo Schema
  ...(tool.details?.howToUse ? [{
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": `如何使用${tool.name}`,
    "description": `一步步教你使用${tool.name}的完整指南`,
    "totalTime": "PT15M",
    "tool": [
      {
        "@type": "HowToTool",
        "name": tool.name
      }
    ],
    "step": tool.details.howToUse.map((step: {step: number; title: string; description: string}) => ({
      "@type": "HowToStep",
      "position": step.step,
      "name": step.title,
      "text": step.description
    }))
  }] : [])
];
---

<Layout
  title={tool.name}
  description={tool.description}
  image={tool.imageUrl}
  type="article"
  jsonLd={jsonLd}
  breadcrumbs={[
    { name: '首页', href: '/' },
    { name: 'AI工具库', href: '/tools' },
    { name: tool.name }
  ]}
>

  <!-- Breadcrumb -->
  <div class="bg-white border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <div class="flex items-center justify-between">
        <nav class="flex items-center gap-2 text-sm">
          <a href="/" class="text-gray-500 hover:text-gray-900">首页</a>
          <span class="text-gray-400">/</span>
          <a href="/tools" class="text-gray-500 hover:text-gray-900">AI工具库</a>
          <span class="text-gray-400">/</span>
          <span class="text-gray-900 font-medium">{tool.name}</span>
        </nav>
        <button
          id="back-to-tools"
          onclick="const isEn = window.location.pathname.startsWith('/en'); window.location.href = isEn ? '/en/tools' : '/tools';"
          class="inline-flex items-center gap-2 px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors text-sm font-medium"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          返回列表
        </button>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="grid lg:grid-cols-3 gap-8">
      <!-- Main Content -->
      <div class="lg:col-span-2">
        <!-- Hero Image -->
        <div class="rounded-xl overflow-hidden mb-8">
          <img src={tool.imageUrl} alt={tool.name} class="w-full h-auto" />
        </div>

        <!-- Title Section -->
        <div class="mb-8">
          <div class="flex items-center justify-between mb-3">
            <div class="flex items-center gap-3">
              <h1 class="text-3xl font-bold">{tool.name}</h1>
              {tool.isNew && <span class="badge bg-red-100 text-red-700">新收录</span>}
            </div>
            <FavoriteButton client:load targetType="tool" targetId={tool.id} locale="zh" />
            <ShareButton client:load title={tool.name} description={tool.description} />
            <button
              id="copy-link-btn"
              aria-label="复制链接"
              onclick="navigator.clipboard.writeText(window.location.href).then(() => { const btn = document.getElementById('copy-link-btn'); if(btn) { btn.textContent = '已复制!'; setTimeout(() => { if(btn) btn.textContent = '复制链接'; }, 2000); } })"
              class="p-2 rounded-lg text-gray-400 hover:text-gray-600 bg-gray-50 hover:bg-gray-100 transition-colors"
              title="复制链接"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
              </svg>
            </button>
          </div>
          <p class="text-lg text-gray-600">{tool.description}</p>
        </div>

        <!-- Features -->
        <section class="mb-8">
          <h2 class="text-xl font-semibold mb-4">核心功能</h2>
          <div class="grid sm:grid-cols-2 gap-3">
            {tool.features.map(feature => (
              <div class="flex items-center gap-2 p-3 bg-gray-50 rounded-lg">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-sm">{feature}</span>
              </div>
            ))}
          </div>
        </section>

        <!-- Rating Details -->
        <section class="mb-8">
          <h2 class="text-xl font-semibold mb-4">评分详情</h2>
          <div class="bg-white rounded-xl border border-gray-200 p-6">
            <div class="flex items-center gap-4 mb-6">
              <div class="text-5xl font-bold text-primary-600">{tool.rating}</div>
              <div>
                <div class="rating mb-2">
                  <StarRating client:load targetType="tool" targetId={tool.id} size="lg" />
                </div>
                <p class="text-sm text-gray-500">{tool.ratingCount} 条评价</p>
              </div>
            </div>

            <div class="space-y-3">
              <div class="flex items-center justify-between">
                <span class="text-sm font-medium">易用性</span>
                <div class="flex items-center gap-2">
                  <div class="w-32 h-2 bg-gray-200 rounded-full overflow-hidden">
                    <div class="h-full bg-primary-500 rounded-full" style={`width: ${tool.dimensions.easeOfUse * 20}%`}></div>
                  </div>
                  <span class="text-sm font-medium w-8">{tool.dimensions.easeOfUse}</span>
                </div>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-sm font-medium">功能丰富度</span>
                <div class="flex items-center gap-2">
                  <div class="w-32 h-2 bg-gray-200 rounded-full overflow-hidden">
                    <div class="h-full bg-secondary-500 rounded-full" style={`width: ${tool.dimensions.features * 20}%`}></div>
                  </div>
                  <span class="text-sm font-medium w-8">{tool.dimensions.features}</span>
                </div>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-sm font-medium">性价比</span>
                <div class="flex items-center gap-2">
                  <div class="w-32 h-2 bg-gray-200 rounded-full overflow-hidden">
                    <div class="h-full bg-green-500 rounded-full" style={`width: ${tool.dimensions.value * 20}%`}></div>
                  </div>
                  <span class="text-sm font-medium w-8">{tool.dimensions.value}</span>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- Alternatives -->
        {(() => {
          // Build a slug -> name lookup from all defined tools
          const altNames = {};
          Object.values(toolsData).forEach((t) => { altNames[t.slug] = t.name; });
          // Only show alternatives that exist in our data
          const validAlts = tool.alternatives.filter(a => altNames[a]);
          if (validAlts.length === 0) return null;
          return (
            <section>
              <h2 class="text-xl font-semibold mb-4">替代工具</h2>
              <div class="flex flex-wrap gap-2">
                {validAlts.map(alt => (
                  <a href={`/tools/${alt}`} class="btn-outline text-sm">
                    {altNames[alt]}
                  </a>
                ))}
              </div>
            </section>
          );
        })()}

        {/* Comments Section */}
        <section class="mt-12">
          <CommentSection client:load targetType="tool" targetId={tool.id} locale="zh" showRating={true} />
        </section>

        <!-- Capability Expansion -->
        <section class="mt-8">
          <h2 class="text-xl font-semibold mb-4">能力拓展</h2>
          <div class="bg-gradient-to-r from-primary-50 to-blue-50 rounded-xl border border-primary-100 p-6">
            <div class="grid sm:grid-cols-2 gap-4">
              {tool.features.slice(0, 4).map((feature, idx) => (
                <div class="flex items-start gap-3">
                  <div class="w-8 h-8 rounded-full bg-primary-100 text-primary-600 flex items-center justify-center flex-shrink-0">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                    </svg>
                  </div>
                  <div>
                    <h4 class="font-medium text-gray-900">{feature}</h4>
                    <p class="text-sm text-gray-600 mt-1">
                      {idx === 0 ? '点击了解该能力的详细应用场景' :
                       idx === 1 ? '查看该能力在实际使用中的表现' :
                       idx === 2 ? '探索该能力如何提升工作效率' :
                       '了解该能力的最新更新和优化'}
                    </p>
                  </div>
                </div>
              ))}
            </div>
            <div class="mt-4 pt-4 border-t border-primary-100">
              <p class="text-sm text-gray-600">
                <span class="font-medium text-primary-700">提示：</span>
                大多数AI工具支持API接入，您可以根据需要在第三方应用或自动化工作流中集成使用。
                {tool.pricing === 'free' || tool.pricing === 'freemium' ? '该工具提供免费版本，建议先体验再决定是否付费升级。' : '付费版本通常提供更高的使用限额和更多高级功能。'}
              </p>
            </div>
          </div>
        </section>

        <!-- Update Notes -->
        <section class="mt-8">
          <h2 class="text-xl font-semibold mb-4">更新说明</h2>
          <div class="bg-white rounded-xl border border-gray-200 p-6">
            <div class="flex items-center gap-4 mb-4">
              <div class="w-12 h-12 rounded-lg bg-green-100 text-green-600 flex items-center justify-center">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
              </div>
              <div>
                <p class="font-medium text-gray-900">最新更新</p>
              </div>
            </div>
            {tool.updateSourceUrl ? (
              <UpdateNotesClient
                client:load
                slug={tool.slug}
                sourceUrl={tool.updateSourceUrl}
                sourceType={tool.updateSourceType}
              />
            ) : tool.details?.updateNotes ? (
              <div class="space-y-3">
                <div class="flex items-start gap-3">
                  <div class="w-2 h-2 rounded-full bg-green-500 mt-2 flex-shrink-0"></div>
                  <p class="text-sm text-gray-700">{tool.details.updateNotes}</p>
                </div>
              </div>
            ) : (
              <div class="space-y-3">
                <div class="flex items-start gap-3">
                  <div class="w-2 h-2 rounded-full bg-green-500 mt-2 flex-shrink-0"></div>
                  <p class="text-sm text-gray-700">工具评分和评价数据基于用户反馈定期更新</p>
                </div>
                <div class="flex items-start gap-3">
                  <div class="w-2 h-2 rounded-full bg-blue-500 mt-2 flex-shrink-0"></div>
                  <p class="text-sm text-gray-700">功能列表和定价信息可能因官方更新而变化，建议以官网为准</p>
                </div>
                <div class="flex items-start gap-3">
                  <div class="w-2 h-2 rounded-full bg-purple-500 mt-2 flex-shrink-0"></div>
                  <p class="text-sm text-gray-700">如发现信息有误，欢迎通过评论区反馈给我们</p>
                </div>
              </div>
            )}
          </div>
        </section>

        <!-- How to Get Started -->
        <section class="mt-8">
          <h2 class="text-xl font-semibold mb-4">如何使用{tool.name}</h2>
          <div class="bg-white rounded-xl border border-gray-200 p-6">
            {tool.details?.howToUse ? (
              <div class="space-y-4">
                {tool.details.howToUse.map((step) => (
                  <div class="flex gap-4">
                    <div class="w-8 h-8 rounded-full bg-primary-100 text-primary-600 flex items-center justify-center font-semibold flex-shrink-0">{step.step}</div>
                    <div>
                      <h4 class="font-medium text-gray-900 mb-1">{step.title}</h4>
                      <p class="text-sm text-gray-600">{step.description}</p>
                    </div>
                  </div>
                ))}
              </div>
            ) : (
              <div class="space-y-4">
                <div class="flex gap-4">
                  <div class="w-8 h-8 rounded-full bg-primary-100 text-primary-600 flex items-center justify-center font-semibold flex-shrink-0">1</div>
                  <div>
                    <h4 class="font-medium text-gray-900 mb-1">注册账户</h4>
                    <p class="text-sm text-gray-600">访问{tool.name}官网，点击注册按钮创建账户。使用邮箱或Google/Apple账号快速注册。</p>
                  </div>
                </div>
                <div class="flex gap-4">
                  <div class="w-8 h-8 rounded-full bg-primary-100 text-primary-600 flex items-center justify-center font-semibold flex-shrink-0">2</div>
                  <div>
                    <h4 class="font-medium text-gray-900 mb-1">选择合适的套餐</h4>
                    <p class="text-sm text-gray-600">根据你的使用需求，选择免费版或付费版。{tool.pricing === 'free' ? '该工具提供完全免费使用。' : tool.pricing === 'freemium' ? '免费版本已有基础功能，付费版本解锁更多高级特性。' : '付费版本提供完整功能。'}</p>
                  </div>
                </div>
                <div class="flex gap-4">
                  <div class="w-8 h-8 rounded-full bg-primary-100 text-primary-600 flex items-center justify-center font-semibold flex-shrink-0">3</div>
                  <div>
                    <h4 class="font-medium text-gray-900 mb-1">开始使用</h4>
                    <p class="text-sm text-gray-600">登录后即可开始使用{tool.name}。{tool.features[0] ? `推荐从${tool.features[0]}功能开始体验。` : '探索各项功能，找到最适合你的使用方式。'}</p>
                  </div>
                </div>
              </div>
            )}
            <div class="mt-6 pt-6 border-t border-gray-200">
              <a href={tool.affiliateUrl || tool.url} target="_blank" rel="noopener noreferrer nofollow" class="btn-primary inline-flex items-center gap-2">
                <span>{tool.affiliateUrl ? '官方注册/下载' : '立即开始使用'}</span>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
              {tool.affiliateUrl && (
                <p class="text-xs text-gray-400 mt-2">此链接为推荐链接，我们可能获得佣金（不影响您的价格）</p>
              )}
            </div>
          </div>
        </section>

        <!-- Use Cases -->
        <section class="mt-8">
          <h2 class="text-xl font-semibold mb-4">适用场景</h2>
          <div class="grid sm:grid-cols-2 gap-4">
            {tool.details?.useCases ? (
              tool.details.useCases.map((useCase) => (
                <div class="bg-gradient-to-br from-gray-50 to-gray-100 rounded-xl p-5 border border-gray-200 hover:border-primary-300 transition-colors">
                  <div class="w-10 h-10 rounded-lg bg-primary-100 text-primary-600 flex items-center justify-center mb-3">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
                    </svg>
                  </div>
                  <h4 class="font-medium text-gray-900 mb-2">{useCase.title}</h4>
                  <p class="text-sm text-gray-600">{useCase.description}</p>
                </div>
              ))
            ) : (
              tool.features.slice(0, 4).map((feature, idx) => (
                <div class="bg-gradient-to-br from-gray-50 to-gray-100 rounded-xl p-5 border border-gray-200 hover:border-primary-300 transition-colors">
                  <div class="w-10 h-10 rounded-lg bg-primary-100 text-primary-600 flex items-center justify-center mb-3">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
                    </svg>
                  </div>
                  <h4 class="font-medium text-gray-900 mb-2">{feature}</h4>
                  <p class="text-sm text-gray-600">
                    {idx === 0 ? '适合日常任务和初级使用场景' :
                     idx === 1 ? '支持专业级应用和复杂任务' :
                     idx === 2 ? '提升工作和学习效率的利器' :
                     '探索AI的更多可能性'}
                  </p>
                </div>
              ))
            )}
          </div>
        </section>

        <!-- Tips & Best Practices -->
        <section class="mt-8">
          <h2 class="text-xl font-semibold mb-4">使用技巧</h2>
          <div class="bg-gradient-to-r from-amber-50 to-orange-50 rounded-xl border border-amber-100 p-6">
            <ul class="space-y-3">
              {tool.details?.tips ? (
                tool.details.tips.map((tip) => (
                  <li class="flex items-start gap-3">
                    <div class="w-6 h-6 rounded-full bg-amber-200 text-amber-700 flex items-center justify-center flex-shrink-0 mt-0.5">
                      <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                      </svg>
                    </div>
                    <p class="text-sm text-gray-700">{tip}</p>
                  </li>
                ))
              ) : (
                <>
                  <li class="flex items-start gap-3">
                    <div class="w-6 h-6 rounded-full bg-amber-200 text-amber-700 flex items-center justify-center flex-shrink-0 mt-0.5">
                      <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                      </svg>
                    </div>
                    <p class="text-sm text-gray-700">使用具体、清晰的提示词可以获得更准确的回答</p>
                  </li>
                  <li class="flex items-start gap-3">
                    <div class="w-6 h-6 rounded-full bg-amber-200 text-amber-700 flex items-center justify-center flex-shrink-0 mt-0.5">
                      <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                      </svg>
                    </div>
                    <p class="text-sm text-gray-700">充分利用上下文对话能力，在同一会话中连续追问</p>
                  </li>
                  <li class="flex items-start gap-3">
                    <div class="w-6 h-6 rounded-full bg-amber-200 text-amber-700 flex items-center justify-center flex-shrink-0 mt-0.5">
                      <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                      </svg>
                    </div>
                    <p class="text-sm text-gray-700">{tool.category === 'coding' ? '提供代码上下文和具体错误信息，更容易获得有效帮助' : '尝试不同的表达方式，找到最适合你的交互风格'}</p>
                  </li>
                  <li class="flex items-start gap-3">
                    <div class="w-6 h-6 rounded-full bg-amber-200 text-amber-700 flex items-center justify-center flex-shrink-0 mt-0.5">
                      <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                      </svg>
                    </div>
                    <p class="text-sm text-gray-700">{tool.pricing !== 'free' ? '利用免费额度充分体验后再决定是否付费' : '虽然是免费工具，但仍有使用限额，注意控制用量'}</p>
                  </li>
                </>
              )}
            </ul>
          </div>
        </section>

        <!-- Related Tools (More Comprehensive) -->
        {(() => {
          // Get tools in same category
          const sameCategoryTools = Object.values(toolsData).filter(t => t.category === tool.category && t.slug !== tool.slug).slice(0, 4);
          const hasRelated = sameCategoryTools.length > 0;
          if (!hasRelated) return null;
          return (
            <section class="mt-8">
              <h2 class="text-xl font-semibold mb-4">相关工具</h2>
              <div class="grid sm:grid-cols-2 gap-4">
                {sameCategoryTools.map(t => (
                  <a href={`/tools/${t.slug}`} class="block bg-white rounded-xl border border-gray-200 p-4 hover:border-primary-300 hover:shadow-md transition-all group">
                    <div class="flex items-center gap-3">
                      <img src={t.imageUrl} alt={t.name} class="w-12 h-12 rounded-lg object-cover" loading="lazy" />
                      <div class="flex-1 min-w-0">
                        <h4 class="font-medium text-gray-900 group-hover:text-primary-600 transition-colors truncate">{t.name}</h4>
                        <p class="text-sm text-gray-500 truncate">{t.description.slice(0, 40)}...</p>
                      </div>
                      <div class="flex items-center gap-1">
                        <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                        </svg>
                        <span class="text-sm font-medium">{t.rating}</span>
                      </div>
                    </div>
                  </a>
                ))}
              </div>
            </section>
          );
        })()}

        <!-- FAQ Section -->
        <section class="mt-8">
          <h2 class="text-xl font-semibold mb-4">常见问题</h2>
          <div class="space-y-4">
            <details class="bg-white rounded-xl border border-gray-200 group">
              <summary class="flex items-center justify-between p-5 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
                <span>{tool.name}免费版和付费版有什么区别？</span>
                <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <div class="px-5 pb-5 text-sm text-gray-600">
                {tool.pricing === 'free'
                  ? `${tool.name}目前完全免费使用。`
                  : tool.pricing === 'freemium'
                    ? `${tool.name}提供免费版和付费版。免费版包含基础功能，付费版（$${tool.priceDetail.monthly}/月起）解锁更多高级特性，包括更强的模型能力、更高的使用额度和优先访问权。`
                    : `${tool.name}是付费工具，$${tool.priceDetail.monthly}/月起，提供完整功能体验。`
                }
              </div>
            </details>
            <details class="bg-white rounded-xl border border-gray-200 group">
              <summary class="flex items-center justify-between p-5 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
                <span>留学生可以使用{tool.name}吗？</span>
                <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <div class="px-5 pb-5 text-sm text-gray-600">
                是的，留学生可以使用{tool.name}。但请注意你所在大学的AI使用政策，部分课程可能限制AI工具的使用。建议查看学校的具体规定，在允许的范围内合理使用。
              </div>
            </details>
            <details class="bg-white rounded-xl border border-gray-200 group">
              <summary class="flex items-center justify-between p-5 cursor-pointer font-medium text-gray-900 hover:text-primary-600">
                <span>{tool.name}的支付方式有哪些？</span>
                <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <div class="px-5 pb-5 text-sm text-gray-600">
                {tool.pricing === 'free'
                  ? `${tool.name}免费使用，无需支付。`
                  : `订阅${tool.name}可使用国际信用卡、虚拟卡（如Depay、Noble）、礼品卡等支付方式。中国用户还可通过低价区注册享受更优惠的价格。详见我们的<a href="/payment" class="text-primary-600 hover:underline">支付解决方案</a>页面。`
                }
              </div>
            </details>
          </div>
        </section>
      </div>

      <!-- Sidebar -->
      <aside class="lg:col-span-1">
        <div class="sticky top-24 space-y-6">

          <!-- Real-time Pricing -->
          <ToolPricingRealtime
            client:load
            toolSlug={tool.slug}
            toolName={tool.name}
            officialUrl={tool.url}
            locale="zh"
          />

          <!-- CTA Card: Promotion Link (below real-time pricing) -->
          <div class="bg-white rounded-xl border border-gray-200 p-6">
            <div class="text-center mb-6">
              <span class={`badge text-lg px-4 py-1 ${
                tool.pricing === 'free' ? 'badge-free' :
                tool.pricing === 'paid' ? 'badge-paid' : 'badge-freemium'
              }`}>
                {tool.pricing === 'free' ? '免费' :
                 tool.pricing === 'paid' ? `¥${tool.priceDetail.monthly}/月` : '免费+付费'}
              </span>
            </div>
            <a
              href={tool.affiliateUrl || tool.url}
              target="_blank"
              rel="noopener noreferrer nofollow"
              class="btn-primary w-full text-center"
            >
              {tool.affiliateUrl ? '🎁 官方注册' : '访问官网'}
            </a>
            <p class="text-xs text-gray-500 text-center mt-3">
              {tool.affiliateUrl
                ? '推荐链接 · 我们可能获得佣金（不影响您的价格）'
                : '链接为官方地址，点击后离开本站'}
            </p>
          </div>

          <!-- Compare Button -->
          <CompareButton
            client:load
            toolSlug={tool.slug}
            toolName={tool.name}
            toolImage={tool.imageUrl}
            locale="zh"
          />

          <!-- Compare Link -->
          <div class="bg-primary-50 rounded-xl border border-primary-200 p-4">
            <div class="flex items-center justify-between">
              <div>
                <h3 class="font-semibold text-primary-900 mb-1">对比工具</h3>
                <p class="text-xs text-primary-700">与其他工具多维度对比</p>
              </div>
              <a href="/compare" class="text-sm text-primary-600 hover:text-primary-700 font-medium">
                去对比 →
              </a>
            </div>
          </div>

          <!-- Quick Info -->
          <div class="bg-white rounded-xl border border-gray-200 p-6">
            <h3 class="font-semibold mb-4">基本信息</h3>
            <dl class="space-y-3 text-sm">
              <div class="flex justify-between">
                <dt class="text-gray-500">分类</dt>
                <dd class="font-medium">
                  {tool.category === 'agent' ? 'Agent' :
                   tool.category === 'writing' ? '写作' :
                   tool.category === 'coding' ? '编程' :
                   tool.category === 'design' ? '设计' :
                   tool.category === 'research' ? '研究' : '对话'}
                </dd>
              </div>
              <div class="flex justify-between">
                <dt class="text-gray-500">标签</dt>
                <dd class="font-medium text-right max-w-[150px]">
                  {tool.tags.slice(0, 3).join(', ')}
                </dd>
              </div>
            </dl>
          </div>

          <!-- Payment Solutions -->
          <div class="bg-secondary-50 rounded-xl border border-secondary-200 p-6">
            <h3 class="font-semibold mb-3 text-secondary-900">支付困难？</h3>
            <p class="text-sm text-secondary-700 mb-4">
              查看我们的支付解决方案，教你怎么轻松订阅
            </p>
            <a href="/payment" class="btn-secondary w-full text-center text-sm">
              支付指南
            </a>
          </div>

          <!-- University Policy -->
          <div class="bg-green-50 rounded-xl border border-green-200 p-6">
            <h3 class="font-semibold mb-3 text-green-900">大学让用吗？</h3>
            <p class="text-sm text-green-700 mb-4">
              查查看你学校的AI政策，避免违规
            </p>
            <a href="/policies" class="bg-green-600 text-white btn w-full text-center text-sm hover:bg-green-700">
              查询政策
            </a>
          </div>

        </div>
      </aside>
    </div>
  </div>
</Layout>
