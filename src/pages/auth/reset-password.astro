---
import Layout from '@/layouts/Layout.astro';

export const prerender = false;

const locale = Astro.url.pathname.startsWith('/en/') ? 'en' : 'zh';

const t = {
  title: '设置新密码',
  h1: '设置新密码',
  subtitle: '请输入您的新密码',
  newPassword: '新密码',
  confirmPassword: '确认密码',
  submit: '确认修改',
  success: '密码修改成功！正在跳转...',
  error: '修改失败，请重试',
  back: '返回登录',
  mismatch: '两次密码输入不一致',
  tooShort: '密码至少6个字符',
  noToken: '无效的重置链接，请重新申请',
};
---

<Layout title={t.title} description={t.subtitle} locale={locale}>
  <div class="min-h-[calc(100vh-200px)] flex items-center justify-center py-12 px-4">
    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <h1 class="text-3xl font-bold text-gray-900">
          {t.h1}
        </h1>
        <p class="mt-2 text-gray-600">
          {t.subtitle}
        </p>
      </div>

      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <div id="reset-password-form">
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">{t.newPassword}</label>
              <input
                type="password"
                id="new-password"
                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500"
                placeholder="••••••••"
                minlength="6"
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">{t.confirmPassword}</label>
              <input
                type="password"
                id="confirm-password"
                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500"
                placeholder="••••••••"
                minlength="6"
              />
            </div>
            <button
              id="reset-btn"
              type="button"
              class="w-full bg-primary-600 text-white py-2.5 px-4 rounded-lg hover:bg-primary-700 transition-colors font-medium disabled:opacity-50 disabled:cursor-not-allowed"
            >
              {t.submit}
            </button>
          </div>
          <div id="success-msg" class="hidden mt-4 p-4 bg-green-50 border border-green-200 rounded-lg text-green-700 text-sm text-center">
            {t.success}
          </div>
          <div id="error-msg" class="hidden mt-4 p-3 bg-red-50 border border-red-200 rounded-lg text-red-600 text-sm">
          </div>
        </div>
      </div>

      <div class="mt-6 text-center">
        <a href="/auth/login" class="text-sm text-gray-600 hover:text-primary-600 transition-colors">
          ← {t.back}
        </a>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { supabase } from '@/lib/supabase';

  const t = {
    success: '密码修改成功！正在跳转...',
    error: '修改失败，请重试',
    mismatch: '两次密码输入不一致',
    tooShort: '密码至少6个字符',
    noToken: '无效的重置链接，请重新申请密码重置',
    noSession: '链接已失效，请重新发起密码重置',
    loading: '验证中...',
    verifying: '验证重置链接中，请稍候...',
  };

  const btn = document.getElementById('reset-btn') as HTMLButtonElement;
  const successDiv = document.getElementById('success-msg') as HTMLDivElement;
  const errorDiv = document.getElementById('error-msg') as HTMLDivElement;
  const newPwdInput = document.getElementById('new-password') as HTMLInputElement;
  const confirmPwdInput = document.getElementById('confirm-password') as HTMLInputElement;

  function showError(msg: string) {
    if (errorDiv) {
      errorDiv.textContent = msg;
      errorDiv.classList.remove('hidden');
    }
  }

  function clearError() {
    if (errorDiv) {
      errorDiv.classList.add('hidden');
    }
  }

  function showSuccess() {
    if (successDiv) {
      successDiv.classList.remove('hidden');
    }
  }

  function setButtonLoading(loading: boolean) {
    if (btn) {
      btn.disabled = loading;
      btn.textContent = loading ? t.verifying : '确认修改';
    }
  }

  // Disable button initially while we verify the session
  if (btn) btn.disabled = true;
  setButtonLoading(true);

  /**
   * Parse recovery tokens from URL hash.
   * Supabase sends the password reset link with tokens in the hash fragment:
   *   /auth/reset-password#access_token=...&refresh_token=...&type=recovery
   */
  function parseHashTokens(): { access_token: string; refresh_token: string } | null {
    const hash = window.location.hash;
    if (!hash || hash.length < 2) return null;

    const params = new URLSearchParams(hash.substring(1));
    const access_token = params.get('access_token');
    const refresh_token = params.get('refresh_token');
    const type = params.get('type');

    if (access_token && refresh_token && type === 'recovery') {
      return { access_token, refresh_token };
    }
    return null;
  }

  /**
   * Try to manually set the session from URL hash tokens.
   * This is a fallback in case Supabase client doesn't auto-process the hash.
   */
  async function tryManualSessionSetup(): Promise<boolean> {
    const tokens = parseHashTokens();
    if (!tokens) return false;

    try {
      const { data, error } = await supabase.auth.setSession({
        access_token: tokens.access_token,
        refresh_token: tokens.refresh_token,
      });

      if (error) {
        console.error('[reset-password] setSession error:', error.message);
        return false;
      }

      if (data.session) {
        // Clear the hash from URL for security (don't leak tokens in browser history)
        window.history.replaceState(null, '', window.location.pathname);
        return true;
      }
    } catch (err) {
      console.error('[reset-password] setSession exception:', err);
    }
    return false;
  }

  /**
   * Wait for Supabase to detect/process the recovery session.
   * Supabase JS v2 auto-detects #access_token in URL and exchanges for a session.
   * We listen for PASSWORD_RECOVERY or SIGNED_IN events.
   */
  async function waitForAutoSession(maxWait = 5000): Promise<boolean> {
    // First, check if there's already a session
    const { data: { session } } = await supabase.auth.getSession();
    if (session) {
      window.history.replaceState(null, '', window.location.pathname);
      return true;
    }

    // Wait for onAuthStateChange to fire
    return new Promise((resolve) => {
      const timeout = setTimeout(() => {
        resolve(false);
      }, maxWait);

      const { data: { subscription } } = supabase.auth.onAuthStateChange((event, session) => {
        if (session || event === 'PASSWORD_RECOVERY') {
          clearTimeout(timeout);
          subscription.unsubscribe();
          // Clear hash for security
          window.history.replaceState(null, '', window.location.pathname);
          resolve(true);
        }
      });
    });
  }

  /**
   * Main session detection logic — tries multiple approaches:
   * 1. Wait for Supabase auto-detection (fastest if it works)
   * 2. Manual setSession from URL hash tokens (fallback)
   * 3. Retry auto-detection one more time
   */
  async function initializeSession(): Promise<boolean> {
    // Step 0: Check for token in query params (raw token format)
    const urlParams = new URLSearchParams(window.location.search);
    const rawToken = urlParams.get('token');
    const tokenHash = urlParams.get('token_hash');
    const tokenType = urlParams.get('type');
    const tokenEmail = urlParams.get('email');
    const tokenToVerify = rawToken || tokenHash;
    if (tokenToVerify && tokenType && tokenEmail) {
      console.log('[reset-password] Found token in query params, verifying...');
      const { error: verifyError } = await supabase.auth.verifyOtp({
        type: tokenType as 'recovery' | 'signup' | 'magiclink' | 'email',
        email: decodeURIComponent(tokenEmail),
        token: tokenToVerify,
      });
      if (!verifyError) {
        // Clear query params from URL for security
        window.history.replaceState(null, '', window.location.pathname);
        return true;
      }
      console.error('[reset-password] token verification failed:', verifyError.message);
      return false;
    }

    // Step 1: Check if hash has recovery tokens
    const tokens = parseHashTokens();
    if (!tokens) {
      // No tokens in hash — check if there's already a session (e.g. user refreshed page)
      const { data: { session } } = await supabase.auth.getSession();
      if (session) return true;
      // No tokens and no session — invalid link
      return false;
    }

    // Step 2: Try Supabase auto-detection first
    const autoDetected = await waitForAutoSession(4000);
    if (autoDetected) return true;

    // Step 3: Supabase auto-detection failed — try manual setSession
    console.log('[reset-password] Auto-detection failed, trying manual setSession...');
    const manualOk = await tryManualSessionSetup();
    if (manualOk) return true;

    // Step 4: One more retry of auto-detection (sometimes needs a second attempt)
    const retryOk = await waitForAutoSession(3000);
    return retryOk;
  }

  // Initialize session detection
  initializeSession().then((ok) => {
    setButtonLoading(false);
    if (ok) {
      if (btn) btn.disabled = false;
    } else {
      showError(t.noSession);
      if (btn) {
        btn.disabled = true;
        btn.textContent = t.noSession;
      }
    }
  });

  // Handle password update
  btn?.addEventListener('click', async () => {
    const newPwd = newPwdInput?.value || '';
    const confirmPwd = confirmPwdInput?.value || '';

    clearError();
    if (successDiv) successDiv.classList.add('hidden');

    if (newPwd.length < 6) {
      showError(t.tooShort);
      return;
    }
    if (newPwd !== confirmPwd) {
      showError(t.mismatch);
      return;
    }

    if (btn) btn.disabled = true;
    if (btn) btn.textContent = '修改中...';

    try {
      const { error: updateError } = await supabase.auth.updateUser({
        password: newPwd,
      });

      if (updateError) {
        showError(updateError.message || t.error);
        if (btn) btn.disabled = false;
        if (btn) btn.textContent = '确认修改';
        return;
      }

      showSuccess();
      // Sign out so user can re-login with new password
      await supabase.auth.signOut();
      setTimeout(() => {
        window.location.href = '/auth/login?reset_success=1';
      }, 1500);
    } catch {
      showError(t.error);
      if (btn) btn.disabled = false;
      if (btn) btn.textContent = '确认修改';
    }
  });
</script>
