---
import Layout from '@/layouts/Layout.astro';

export const prerender = false;

const locale = 'zh';

const t = {
  title: '设置新密码',
  h1: '设置新密码',
  subtitle: '请输入您的新密码',
  newPassword: '新密码',
  confirmPassword: '确认密码',
  submit: '确认修改',
  success: '密码修改成功！正在跳转...',
  error: '修改失败，请重试',
  back: '返回登录',
  mismatch: '两次密码输入不一致',
  tooShort: '密码至少6个字符',
  noToken: '无效的重置链接，请重新申请',
};
---

<Layout title={t.title} description={t.subtitle} locale={locale}>
  <div class="min-h-[calc(100vh-200px)] flex items-center justify-center py-12 px-4">
    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <h1 class="text-3xl font-bold text-gray-900">
          {t.h1}
        </h1>
        <p class="mt-2 text-gray-600">
          {t.subtitle}
        </p>
      </div>

      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <div id="reset-password-form">
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">{t.newPassword}</label>
              <input
                type="password"
                id="new-password"
                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500"
                placeholder="••••••••"
                minlength="6"
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">{t.confirmPassword}</label>
              <input
                type="password"
                id="confirm-password"
                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500"
                placeholder="••••••••"
                minlength="6"
              />
            </div>
            <button
              id="reset-btn"
              type="button"
              class="w-full bg-primary-600 text-white py-2.5 px-4 rounded-lg hover:bg-primary-700 transition-colors font-medium disabled:opacity-50 disabled:cursor-not-allowed"
            >
              {t.submit}
            </button>
          </div>
          <div id="success-msg" class="hidden mt-4 p-4 bg-green-50 border border-green-200 rounded-lg text-green-700 text-sm text-center">
            {t.success}
          </div>
          <div id="error-msg" class="hidden mt-4 p-3 bg-red-50 border border-red-200 rounded-lg text-red-600 text-sm">
          </div>
        </div>
      </div>

      <div class="mt-6 text-center">
        <a href="/auth/login" class="text-sm text-gray-600 hover:text-primary-600 transition-colors">
          ← {t.back}
        </a>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { supabase } from '@/lib/supabase';

  const t = {
    success: '密码修改成功！正在跳转...',
    error: '修改失败，请重试',
    mismatch: '两次密码输入不一致',
    tooShort: '密码至少6个字符',
    noToken: '无效的重置链接，请重新申请',
    noSession: '链接已失效，请重新发起密码重置',
    loading: '验证中...',
  };

  const btn = document.getElementById('reset-btn') as HTMLButtonElement;
  const successDiv = document.getElementById('success-msg') as HTMLDivElement;
  const errorDiv = document.getElementById('error-msg') as HTMLDivElement;
  const newPwdInput = document.getElementById('new-password') as HTMLInputElement;
  const confirmPwdInput = document.getElementById('confirm-password') as HTMLInputElement;

  function showError(msg: string) {
    if (errorDiv) {
      errorDiv.textContent = msg;
      errorDiv.classList.remove('hidden');
    }
    if (btn) {
      btn.disabled = true;
      btn.textContent = t.noSession;
    }
  }

  function showSuccess() {
    if (successDiv) {
      successDiv.classList.remove('hidden');
    }
  }

  // Wait for Supabase to process the recovery token from the URL hash
  // Supabase JS v2 automatically detects #access_token in the URL and exchanges it for a session
  // We need to wait for onAuthStateChange to fire with the session
  let sessionReady = false;

  async function waitForSession(maxWait = 5000): Promise<boolean> {
    // First, try to get an existing session
    const { data: { session } } = await supabase.auth.getSession();
    if (session) return true;

    // If no session yet, wait for onAuthStateChange to fire (Supabase processes URL hash)
    return new Promise((resolve) => {
      const timeout = setTimeout(() => {
        resolve(false);
      }, maxWait);

      const { data: { subscription } } = supabase.auth.onAuthStateChange((event, session) => {
        if (session || event === 'PASSWORD_RECOVERY') {
          clearTimeout(timeout);
          subscription.unsubscribe();
          resolve(true);
        }
      });
    });
  }

  waitForSession().then((ok) => {
    sessionReady = ok;
    if (ok && btn) {
      btn.disabled = false;
    } else {
      showError(t.noSession);
    }
  });

  btn?.addEventListener('click', async () => {
    const newPwd = newPwdInput?.value || '';
    const confirmPwd = confirmPwdInput?.value || '';

    if (errorDiv) errorDiv.classList.add('hidden');
    if (successDiv) successDiv.classList.add('hidden');

    if (newPwd.length < 6) {
      showError(t.tooShort);
      return;
    }
    if (newPwd !== confirmPwd) {
      showError(t.mismatch);
      return;
    }

    if (btn) btn.disabled = true;
    if (btn) btn.textContent = '修改中...';

    try {
      // Update password directly via Supabase client (uses the recovery session)
      const { error: updateError } = await supabase.auth.updateUser({
        password: newPwd,
      });

      if (updateError) {
        showError(updateError.message || t.error);
        if (btn) btn.disabled = false;
        if (btn) btn.textContent = '确认修改';
        return;
      }

      showSuccess();
      // Sign out so user can re-login with new password
      await supabase.auth.signOut();
      setTimeout(() => {
        window.location.href = '/auth/login?reset_success=1';
      }, 1500);
    } catch {
      showError(t.error);
      if (btn) btn.disabled = false;
      if (btn) btn.textContent = '确认修改';
    }
  });
</script>
