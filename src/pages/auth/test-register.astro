---
import Layout from '@/layouts/Layout.astro';
---

<Layout title="测试注册" locale="zh">
  <div class="min-h-screen flex items-center justify-center">
    <div class="bg-white p-8 rounded-lg shadow-lg max-w-md w-full">
      <h1 class="text-2xl font-bold mb-4">测试注册</h1>
      <form id="test-form">
        <input type="email" id="email" placeholder="邮箱" class="w-full border p-2 mb-2 rounded" />
        <input type="password" id="password" placeholder="密码" class="w-full border p-2 mb-2 rounded" />
        <input type="text" id="name" placeholder="昵称" class="w-full border p-2 mb-4 rounded" />
        <button type="submit" class="w-full bg-blue-500 text-white p-2 rounded">注册</button>
      </form>
      <div id="result" class="mt-4 p-2 rounded"></div>
    </div>
  </div>
</Layout>

<script>
const DEMO_USERS_KEY = 'demo_users';
const DEMO_SESSION_KEY = 'demo_session';

function generateId() {
  return 'demo-' + Math.random().toString(36).substring(2, 15);
}

function getDemoUsers() {
  const stored = localStorage.getItem(DEMO_USERS_KEY);
  return stored ? JSON.parse(stored) : {};
}

function saveDemoUsers(users) {
  localStorage.setItem(DEMO_USERS_KEY, JSON.stringify(users));
}

function saveDemoSession(user) {
  sessionStorage.setItem(DEMO_SESSION_KEY, JSON.stringify(user));
}

async function signUp(email, password, name) {
  await new Promise(resolve => setTimeout(resolve, 500));

  const users = getDemoUsers();
  const existing = Object.values(users).find(u => u.email === email);

  if (existing) {
    return { user: null, error: '该邮箱已被注册' };
  }

  const newUser = {
    id: generateId(),
    email,
    password,
    name: name || email.split('@')[0],
    created_at: new Date().toISOString(),
  };

  users[newUser.id] = newUser;
  saveDemoUsers(users);

  const { password: _, ...demoUser } = newUser;
  saveDemoSession(demoUser);
  return { user: demoUser, error: null };
}

document.getElementById('test-form').addEventListener('submit', async (e) => {
  e.preventDefault();
  const result = document.getElementById('result');
  result.textContent = '注册中...';
  result.className = 'mt-4 p-2 rounded bg-yellow-100';

  const email = document.getElementById('email').value;
  const password = document.getElementById('password').value;
  const name = document.getElementById('name').value;

  const res = await signUp(email, password, name);

  if (res.user) {
    result.textContent = '注册成功！user: ' + JSON.stringify(res.user);
    result.className = 'mt-4 p-2 rounded bg-green-100';
  } else {
    result.textContent = '注册失败: ' + res.error;
    result.className = 'mt-4 p-2 rounded bg-red-100';
  }
});
</script>
