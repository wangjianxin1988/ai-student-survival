---
import Layout from '@/layouts/Layout.astro';
import { supabase } from '@/lib/supabase';

export const prerender = false;

const locale = Astro.url.searchParams.get('locale') || 'zh';
const code = Astro.url.searchParams.get('code');
const error = Astro.url.searchParams.get('error');

// If there's an OAuth error, redirect to login with error
if (error) {
  return Astro.redirect(`/${locale === 'en' ? 'en/' : ''}auth/login?error=${encodeURIComponent(error)}`);
}

// Exchange the OAuth code for a session
if (code) {
  try {
    const { data, error: exchangeError } = await supabase.auth.exchangeCodeForSession(code);

    if (exchangeError) {
      console.error('OAuth code exchange error:', exchangeError);
      return Astro.redirect(`/${locale === 'en' ? 'en/' : ''}auth/login?error=${encodeURIComponent(exchangeError.message)}`);
    }

    // Set Supabase auth cookies for server-side session
    if (data.session) {
      const maxAge = data.session.expires_in ?? 3600;
      Astro.cookies.set('sb-access-token', data.session.access_token, {
        maxAge,
        path: '/',
        sameSite: 'lax',
        httpOnly: true,
        secure: true,
      });
      Astro.cookies.set('sb-refresh-token', data.session.refresh_token, {
        maxAge: maxAge * 2,
        path: '/',
        sameSite: 'lax',
        httpOnly: true,
        secure: true,
      });
      Astro.cookies.set('sb-auth-token', JSON.stringify({
        access_token: data.session.access_token,
        refresh_token: data.session.refresh_token,
      }), {
        maxAge,
        path: '/',
        sameSite: 'lax',
        httpOnly: true,
        secure: true,
      });
    }

    // Redirect to home after successful login
    return Astro.redirect(`/${locale === 'en' ? 'en/' : ''}?oauth_success=true`);
  } catch (err) {
    console.error('OAuth callback error:', err);
    return Astro.redirect(`/${locale === 'en' ? 'en/' : ''}auth/login?error=oauth_failed`);
  }
}

// No code provided, redirect to login
return Astro.redirect(`/${locale === 'en' ? 'en/' : ''}auth/login`);
---

<Layout title="Processing...">
  <div class="min-h-[60vh] flex items-center justify-center">
    <div class="text-center">
      <div class="w-12 h-12 border-4 border-primary-500 border-t-transparent rounded-full animate-spin mx-auto"></div>
      <p class="mt-4 text-gray-600">
        {locale === 'zh' ? '正在处理登录...' : 'Processing sign in...'}
      </p>
    </div>
  </div>
</Layout>
