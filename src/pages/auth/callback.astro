---
import Layout from '@/layouts/Layout.astro';

export const prerender = false;

const locale = Astro.url.searchParams.get('locale') || 'zh';
const error = Astro.url.searchParams.get('error');
const errorDescription = Astro.url.searchParams.get('error_description');

// If there's an OAuth error, redirect to login with error immediately
if (error || errorDescription) {
  const msg = error || errorDescription;
  return Astro.redirect(`/${locale === 'en' ? 'en/' : ''}auth/login?error=${encodeURIComponent(msg)}`);
}

// For all other cases (code exchange, magic link), handle client-side
// This ensures the client-side Supabase SDK can complete session setup
---

<Layout title="Processing...">
  <div class="min-h-[60vh] flex items-center justify-center">
    <div class="text-center">
      <div class="w-12 h-12 border-4 border-primary-500 border-t-transparent rounded-full animate-spin mx-auto"></div>
      <p class="mt-4 text-gray-600" id="status-text">
        {locale === 'zh' ? '正在处理登录...' : 'Processing sign in...'}
      </p>
    </div>
  </div>
</Layout>

<script>
  import { supabase } from '@/lib/supabase';
  import { onAuthStateChange } from '@/lib/auth';

  // Handle OAuth code exchange and magic link / OTP token client-side.
  // IMPORTANT: Wait for auth.ts's onAuthStateChange to fire before redirecting,
  // so that AuthProvider (which subscribes to auth.ts) is guaranteed to receive
  // the session update before the user lands on the next page.
  async function handleCallback() {
    const params = new URLSearchParams(window.location.search);
    const locale = params.get('locale') || 'zh';
    const langPrefix = locale === 'en' ? '/en' : '';
    const loginUrl = `${langPrefix}/auth/login`;

    // Get returnTo from sessionStorage (set before OAuth redirect)
    const returnTo = sessionStorage.getItem('oauth_return_to') || `${langPrefix}/user`;
    sessionStorage.removeItem('oauth_return_to');

    const updateStatus = (text: string) => {
      const el = document.getElementById('status-text');
      if (el) el.textContent = text;
    };

    try {
      const oauthError = params.get('error');
      if (oauthError) {
        window.location.href = `${loginUrl}?error=${encodeURIComponent(oauthError)}`;
        return;
      }

      // Handle hash fragment tokens (magic link / OTP redirect format).
      // Supabase may put tokens in the hash fragment: #access_token=...&refresh_token=...
      const hash = window.location.hash;
      let hashSessionSet = false;
      if (hash && hash.includes('access_token')) {
        updateStatus(locale === 'zh' ? '正在验证登录...' : 'Verifying sign in...');
        const hashParams = new URLSearchParams(hash.substring(1));
        const accessToken = hashParams.get('access_token');
        const refreshToken = hashParams.get('refresh_token');

        if (accessToken && refreshToken) {
          const { error: sessionError } = await supabase.auth.setSession({
            access_token: accessToken,
            refresh_token: refreshToken,
          });
          if (sessionError) {
            console.error('Hash session error:', sessionError);
            window.location.href = `${loginUrl}?error=${encodeURIComponent(sessionError.message)}`;
            return;
          }
          hashSessionSet = true;
          // Session set successfully — fall through to auth state change listener below
        }
      }

      // Handle magic link / OTP token (token param + type=email)
      const token = params.get('token');
      const type = params.get('type');
      const email = params.get('email');
      if (token && type === 'email' && email) {
        updateStatus(locale === 'zh' ? '正在验证邮箱...' : 'Verifying email...');
        const { error: otpError } = await supabase.auth.verifyOtp({
          type: 'email',
          email: decodeURIComponent(email),
          token: token,
        });
        if (otpError) {
          window.location.href = `${loginUrl}?error=${encodeURIComponent(otpError.message)}`;
          return;
        }
      }

      // Subscribe to auth.ts's onAuthStateChange BEFORE any async auth operations.
      // This prevents the race where auth event fires before we register our listener,
      // causing AuthProvider to miss the session update and the header to not show avatar.
      updateStatus(locale === 'zh' ? '登录成功，正在跳转...' : 'Signed in! Redirecting...');

      const redirectAfterAuth = () => {
        window.location.href = returnTo;
      };

      // Subscribe FIRST — before exchange — to catch the auth event reliably.
      // auth.ts's onAuthStateChange fires synchronously if currentUser is already set,
      // so we check currentUser immediately after subscribing.
      let redirected = false;
      const unsubscribe = onAuthStateChange((user) => {
        if (user && !redirected) {
          redirected = true;
          unsubscribe();
          // Small delay to let AuthProvider's listener register and receive the event
          setTimeout(redirectAfterAuth, 100);
        }
      });

      // If currentUser is already set (session existed), fire redirect immediately
      const { getCurrentUser } = await import('@/lib/auth');
      if (getCurrentUser() && !redirected) {
        redirected = true;
        unsubscribe();
        setTimeout(redirectAfterAuth, 100);
        return;
      }

      // Exchange code for session (OAuth)
      const code = params.get('code');
      if (code) {
        updateStatus(locale === 'zh' ? '正在完成登录...' : 'Completing sign in...');
        const { error: exchangeError } = await supabase.auth.exchangeCodeForSession(code);
        if (exchangeError) {
          console.error('Code exchange error:', exchangeError);
          unsubscribe();
          window.location.href = `${loginUrl}?error=${encodeURIComponent(exchangeError.message)}`;
          return;
        }
      }

      // No code/token — verify existing session (skip if we just set session from hash)
      if (!code && !token && !hashSessionSet) {
        const { data: { session }, error: sessionError } = await supabase.auth.getSession();
        if (sessionError || !session) {
          unsubscribe();
          window.location.href = loginUrl;
          return;
        }
      }

      // Ensure public.users row exists for this user (needed for points, favorites, ratings).
      // Use fetch with Authorization header to bypass RLS on users table.
      const { data: { session } } = await supabase.auth.getSession();
      if (session?.user) {
        const userData = {
          id: session.user.id,
          email: session.user.email || '',
          name: (session.user.user_metadata as Record<string, unknown>)?.name || null,
          avatar_url: (session.user.user_metadata as Record<string, unknown>)?.avatar_url || null,
        };
        const origin = window.location.origin;
        try {
          await fetch(`${origin}/api/auth/upsert-user`, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Authorization': `Bearer ${session.access_token || ''}`,
            },
            body: JSON.stringify(userData),
          });
        } catch (_) {
          // Non-blocking — user creation can be retried later
        }
      }

      // Safety: if not redirected within 3s, force redirect
      setTimeout(() => {
        if (!redirected) {
          redirected = true;
          unsubscribe();
          redirectAfterAuth();
        }
      }, 3000);

    } catch (err) {
      console.error('Callback error:', err);
      window.location.href = `${loginUrl}?error=oauth_failed`;
    }
  }

  handleCallback();
</script>
