---
import Layout from '@/layouts/Layout.astro';
import { supabase } from '@/lib/supabase';

export const prerender = false;

const locale = Astro.url.searchParams.get('locale') || 'zh';
const error = Astro.url.searchParams.get('error');
const errorDescription = Astro.url.searchParams.get('error_description');

// If there's an OAuth error, redirect to login with error immediately
if (error || errorDescription) {
  const msg = error || errorDescription;
  return Astro.redirect(`/${locale === 'en' ? 'en/' : ''}auth/login?error=${encodeURIComponent(msg)}`);
}

// For all other cases (code exchange, magic link), handle client-side
// This ensures the client-side Supabase SDK can complete session setup
---

<Layout title="Processing...">
  <div class="min-h-[60vh] flex items-center justify-center">
    <div class="text-center">
      <div class="w-12 h-12 border-4 border-primary-500 border-t-transparent rounded-full animate-spin mx-auto"></div>
      <p class="mt-4 text-gray-600" id="status-text">
        {locale === 'zh' ? '正在处理登录...' : 'Processing sign in...'}
      </p>
    </div>
  </div>
</Layout>

<script>
  // Handle OAuth code exchange and magic link token client-side
  // This ensures Supabase SDK completes session setup before redirect
  async function handleCallback() {
    const params = new URLSearchParams(window.location.search);
    const code = params.get('code');
    const locale = params.get('locale') || 'zh';
    const langPrefix = locale === 'en' ? '/en' : '';
    const loginUrl = `${langPrefix}/auth/login`;

    try {
      // If there's an error parameter, redirect to login
      const error = params.get('error');
      if (error) {
        window.location.href = `${loginUrl}?error=${encodeURIComponent(error)}`;
        return;
      }

      // Exchange code for session (handles both OAuth and magic link)
      if (code) {
        const { error: exchangeError } = await supabase.auth.exchangeCodeForSession(code);
        if (exchangeError) {
          console.error('Code exchange error:', exchangeError);
          window.location.href = `${loginUrl}?error=${encodeURIComponent(exchangeError.message)}`;
          return;
        }
      } else {
        // No code - try to get existing session (handles magic link tokens in URL)
        const { data: { session }, error: sessionError } = await supabase.auth.getSession();
        if (sessionError || !session) {
          // No session available, redirect to login
          window.location.href = loginUrl;
          return;
        }
      }

      // Get returnTo from sessionStorage (set before OAuth redirect)
      const returnTo = sessionStorage.getItem('oauth_return_to') || `${langPrefix}/user`;
      sessionStorage.removeItem('oauth_return_to');

      // Update status text
      const statusEl = document.getElementById('status-text');
      if (statusEl) {
        statusEl.textContent = locale === 'zh' ? '登录成功，正在跳转...' : 'Signed in! Redirecting...';
      }

      // Small delay for better UX, then redirect
      setTimeout(() => {
        window.location.href = returnTo;
      }, 500);

    } catch (err) {
      console.error('Callback error:', err);
      window.location.href = `${loginUrl}?error=oauth_failed`;
    }
  }

  handleCallback();
</script>
