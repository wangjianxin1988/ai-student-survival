---
import Layout from '@/layouts/Layout.astro';
import LoginForm from '@/components/auth/LoginForm';
import { getLanguageSwitcherData, getAlternateUrl, type Locale } from '@/i18n';

export const prerender = false;

// Detect locale from URL path
const urlPath = Astro.url.pathname;
const locale = urlPath.startsWith('/en') ? 'en' : 'zh';

const titles = {
  zh: { title: '登录', h1: '欢迎回来', subtitle: '登录到您的账户', back: '返回首页' },
  en: { title: 'Sign In', h1: 'Welcome Back', subtitle: 'Sign in to your account', back: 'Back to Home' },
};

const t = titles[locale];
const languageSwitcher = getLanguageSwitcherData(locale);
function getAlternatePath(loc: Locale): string {
  return getAlternateUrl(Astro.url, loc);
}
---

<Layout title={t.title} description={locale === 'zh' ? '登录到MI TO AI留学生存指南' : 'Sign in to MI TO AI Student Survival Guide'} locale={locale} isAuthPage={true}>
  <div class="min-h-[calc(100vh-200px)] flex items-center justify-center py-12 px-4">
    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <h1 class="text-3xl font-bold text-gray-900">
          {t.h1}
        </h1>
        <p class="mt-2 text-gray-600">
          {t.subtitle}
        </p>
      </div>

      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 relative">
        <!-- Language switcher inside card (top-right corner) -->
        <div class="absolute top-4 right-4 flex items-center gap-1">
          {languageSwitcher.map(item => (
            <a
              href={getAlternatePath(item.locale)}
              class:list={[
                'px-2 py-0.5 text-xs font-medium rounded transition-colors',
                item.current ? 'bg-primary-100 text-primary-700' : 'text-gray-500 hover:text-gray-700 hover:bg-gray-100'
              ]}
              aria-label={`Switch to ${item.label}`}
              aria-current={item.current ? 'true' : undefined}
            >
              {item.label}
            </a>
          ))}
        </div>
        <LoginForm
          locale={locale}
          client:load
        />
      </div>

      <div class="mt-6 text-center">
        <a href={locale === 'zh' ? '/' : '/en/'} class="text-sm text-gray-600 hover:text-primary-600 transition-colors">
          ← {t.back}
        </a>
      </div>
    </div>
  </div>
</Layout>