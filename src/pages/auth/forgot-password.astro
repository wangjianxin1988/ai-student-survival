---
import Layout from '@/layouts/Layout.astro';
import LoginForm from '@/components/auth/LoginForm';

export const prerender = false;

const locale = 'zh';

const t = {
  title: '忘记密码',
  h1: '重置密码',
  subtitle: '输入您的注册邮箱，我们会发送重置链接',
  back: '返回登录',
};
---

<Layout title={t.title} description={t.subtitle} locale={locale} isAuthPage={true}>
  <div class="min-h-[calc(100vh-200px)] flex items-center justify-center py-12 px-4">
    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <h1 class="text-3xl font-bold text-gray-900">
          {t.h1}
        </h1>
        <p class="mt-2 text-gray-600">
          {t.subtitle}
        </p>
      </div>

      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <!-- Forgot password state - show by default on this page -->
        <div id="forgot-password-form">
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">邮箱地址</label>
              <input
                type="email"
                id="forgot-email"
                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500"
                placeholder="your@email.com"
              />
            </div>
            <button
              id="send-reset-btn"
              type="button"
              class="w-full bg-primary-600 text-white py-2 px-4 rounded-lg hover:bg-primary-700 transition-colors font-medium"
            >
              发送重置链接
            </button>
          </div>
          <div id="forgot-success" class="hidden mt-4 p-4 bg-green-50 border border-green-200 rounded-lg text-green-700 text-sm">
            重置链接已发送到您的邮箱，请查收。
          </div>
          <div id="forgot-error" class="hidden mt-4 p-3 bg-red-50 border border-red-200 rounded-lg text-red-600 text-sm">
          </div>
        </div>
      </div>

      <div class="mt-6 text-center">
        <a href="/auth/login" class="text-sm text-gray-600 hover:text-primary-600 transition-colors">
          ← {t.back}
        </a>
      </div>
    </div>
  </div>
</Layout>

<script>
  document.getElementById('send-reset-btn')?.addEventListener('click', async () => {
    const email = (document.getElementById('forgot-email') as HTMLInputElement)?.value;
    const successDiv = document.getElementById('forgot-success');
    const errorDiv = document.getElementById('forgot-error');
    const btn = document.getElementById('send-reset-btn') as HTMLButtonElement;

    if (!email) {
      if (errorDiv) { errorDiv.textContent = '请输入邮箱地址'; errorDiv.classList.remove('hidden'); }
      return;
    }

    if (btn) btn.disabled = true;
    if (errorDiv) errorDiv.classList.add('hidden');
    if (successDiv) successDiv.classList.add('hidden');

    try {
      const res = await fetch('/api/auth/forgot-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });
      const data = await res.json();
      if (res.ok) {
        if (successDiv) successDiv.classList.remove('hidden');
      } else {
        if (errorDiv) { errorDiv.textContent = data.message || '发送失败'; errorDiv.classList.remove('hidden'); }
      }
    } catch {
      if (errorDiv) { errorDiv.textContent = '网络错误，请重试'; errorDiv.classList.remove('hidden'); }
    }

    if (btn) btn.disabled = false;
  });
</script>