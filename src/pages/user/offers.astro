---
import Layout from '@/layouts/Layout.astro';
import OffersList from '@/components/user/OffersList';

export const prerender = false;

const locale = Astro.url.pathname.startsWith('/en/') ? 'en' : 'zh';
---

<Layout title={locale === 'zh' ? '我的Offer' : 'My Offers'}>
  <OffersList locale={locale} client:load />
</Layout>
