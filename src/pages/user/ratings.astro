---
import Layout from '@/layouts/Layout.astro';
import RatingsList from '@/components/user/RatingsList';

export const prerender = false;

const locale = Astro.url.pathname.startsWith('/en/') ? 'en' : 'zh';
---

<Layout title={locale === 'zh' ? '我的评分' : 'My Ratings'}>
  <RatingsList locale={locale} client:load />
</Layout>
