---
import Layout from '@/layouts/Layout.astro';
import EnhancedSettings from '@/components/user/EnhancedSettings';

export const prerender = false;

const locale = Astro.url.pathname.startsWith('/en/') ? 'en' : 'zh';
---

<Layout title={locale === 'zh' ? '账户设置' : 'Account Settings'}>
  <EnhancedSettings locale={locale} client:load />
</Layout>
