---
import Layout from '@/layouts/Layout.astro';
import ProfilePage from '@/components/user/ProfilePage';

export const prerender = false;

const locale = Astro.url.pathname.startsWith('/en/') ? 'en' : 'zh';
---

<Layout title={locale === 'zh' ? '个人中心' : 'Profile'}>
  <ProfilePage locale={locale} client:load />
</Layout>
