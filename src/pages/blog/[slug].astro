---
export const prerender = false;

export function getStaticPaths() {
 return [];
}

import Layout from '@/layouts/Layout.astro';
import { type Locale, t as translate, getLocaleFromUrl } from '@/i18n';
import { blogPosts, findBlogPostBySlug, getRelatedBlogPosts } from '@/data/blogPosts';

const locale: Locale = getLocaleFromUrl(Astro.url);
const { slug } = Astro.params;

const post = findBlogPostBySlug(slug as string);

if (!post) {
 return Astro.redirect('/blog');
}

const relatedPosts = getRelatedBlogPosts(post, 3);

const categoryLabels: Record<string, { zh: string; en: string }> = {
 tutorials: { zh: '教程', en: 'Tutorials' },
 reviews: { zh: '评测', en: 'Reviews' },
 policy: { zh: '政策解读', en: 'Policy' },
 comparisons: { zh: '工具对比', en: 'Comparisons' },
};

// Simple markdown to HTML conversion for rendering
function markdownToHtml(md: string): string {
 let html = md
  // Headers
  .replace(/^### (.+)$/gm, '<h3>$1</h3>')
  .replace(/^## (.+)$/gm, '<h2>$1</h2>')
  .replace(/^# (.+)$/gm, '<h1>$1</h1>')
  // Blockquotes
  .replace(/^> (.+)$/gm, '<blockquote>$1</blockquote>')
  // Bold and italic
  .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
  .replace(/\*(.+?)\*/g, '<em>$1</em>')
  // Images (before links to avoid conflict)
  .replace(/!\[([^\]]*)\]\(([^)]+)\)/g, '<img src="$2" alt="$1" loading="lazy" />')
  // Links
  .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener noreferrer">$1</a>')
  // Inline code
  .replace(/`([^`]+)`/g, '<code>$1</code>')
  // Horizontal rule
  .replace(/^---$/gm, '<hr>')
  // Checkboxes
  .replace(/^- \[ \] (.+)$/gm, '<li class="checkbox">☐ $1</li>')
  .replace(/^- \[x\] (.+)$/gm, '<li class="checkbox checked">☑ $1</li>')
  // Unordered lists
  .replace(/^- (.+)$/gm, '<li>$1</li>')
  // Tables - basic support
  .replace(/\|[-\s|]+\|/g, '') // Remove separator rows
  .replace(/^\| (.+) \|$/gm, (match, content) => {
   const cells = content.split(' | ').map((c: string) => `<td>${c.trim()}</td>`).join('');
   return `<tr>${cells}</tr>`;
  })
  // Paragraphs (lines that aren't already wrapped in HTML tags)
  .split('\n\n')
  .map(block => {
   block = block.trim();
   if (!block) return '';
   if (block.startsWith('<')) return block;
   return `<p>${block}</p>`;
  })
  .join('\n');

 // Wrap consecutive <tr> in <table>
 html = html.replace(/(<tr>[\s\S]*?<\/tr>\n?)+/g, (match) => `<table>${match}</table>`);

 // Wrap consecutive <li> in <ul>
 html = html.replace(/(<li[^>]*>[\s\S]*?<\/li>\n?)+/g, (match) => `<ul>${match}</ul>`);

 return html;
}

const htmlContent = markdownToHtml(post.content);

// Generate FAQ items from blog post slug/topic for SEO
function generateFaqFromSlug(slug: string, title: string, locale: string): Array<{question: string, answer: string}> {
  const faqMap: Record<string, {zh: {q: string, a: string}[], en: {q: string, a: string}[]}> = {
    'chatgpt-go-how-to-subscribe': {
      zh: [
        {q: 'ChatGPT Go是什么套餐？', a: 'ChatGPT Go是OpenAI推出的低价订阅套餐，价格远低于ChatGPT Plus，适合预算有限的留学生使用AI工具。它提供基础的GPT-4访问权限和一定的使用额度。'},
        {q: '如何订阅ChatGPT Go？', a: '订阅ChatGPT Go需要使用支持的支付方式，包括国际信用卡或虚拟卡（如Depay、WildCard等）。部分地区的用户也可以通过礼品卡完成支付。'},
        {q: 'ChatGPT Go和Plus有什么区别？', a: '主要区别在于价格和功能限制。ChatGPT Go价格更低但使用额度有限，适合轻度使用；ChatGPT Plus提供更高的使用限制和优先访问GPT-4的权限。'}
      ],
      en: [
        {q: 'What is ChatGPT Go?', a: 'ChatGPT Go is a budget-friendly subscription plan from OpenAI, priced significantly lower than ChatGPT Plus. It provides basic GPT-4 access with usage limits, ideal for cost-conscious students.'},
        {q: 'How to subscribe to ChatGPT Go?', a: 'You can subscribe using supported payment methods including international credit cards or virtual cards like Depay and WildCard. Some regions may also support gift card payments.'},
        {q: 'What is the difference between ChatGPT Go and Plus?', a: 'The main differences are price and usage limits. ChatGPT Go is cheaper with limited usage quotas, while ChatGPT Plus offers higher limits and priority GPT-4 access.'}
      ]
    },
    'claude-opus-48-review': {
      zh: [
        {q: 'Claude Opus 4.8有什么新功能？', a: 'Claude Opus 4.8在推理能力、代码生成和长文本处理方面有显著提升，支持更大的上下文窗口，并在多项基准测试中表现优异。'},
        {q: 'Claude Opus 4.8适合学生使用吗？', a: '非常适合。Claude Opus 4.8在学术写作、论文分析和研究辅助方面表现出色，是留学生完成作业和研究的优秀工具。'},
        {q: 'Claude Opus 4.8的价格是多少？', a: 'Claude通过Anthropic平台提供订阅服务，Pro计划约$20/月，也可通过API按量计费。学生可以通过虚拟卡完成支付。'}
      ],
      en: [
        {q: 'What are the new features of Claude Opus 4.8?', a: 'Claude Opus 4.8 brings significant improvements in reasoning, code generation, and long-context processing, with a larger context window and strong benchmark performance.'},
        {q: 'Is Claude Opus 4.8 good for students?', a: 'Yes, it excels at academic writing, paper analysis, and research assistance, making it an excellent tool for international students.'},
        {q: 'How much does Claude Opus 4.8 cost?', a: 'Claude is available through Anthropic subscription service at around $20/month for Pro, or pay-per-use via API. Students can pay with virtual cards.'}
      ]
    },
    'eu-ai-act-student-guide': {
      zh: [
        {q: 'EU AI Act对学生使用AI有什么影响？', a: 'EU AI Act对学术场景中AI的使用提出了透明度要求，学生需要明确标注AI辅助完成的内容，但并未完全禁止在学习中使用AI工具。'},
        {q: '在欧洲留学还能用ChatGPT吗？', a: '可以使用，但需遵守各大学的具体政策。大多数欧洲大学允许在适当场景下使用AI工具，但要求学生保持学术诚信并披露AI使用情况。'},
        {q: 'EU AI Act什么时候正式生效？', a: 'EU AI Act于2024年正式通过，分阶段实施。大部分条款将在2025-2026年间逐步生效，各成员国将制定具体执行细则。'}
      ],
      en: [
        {q: 'How does the EU AI Act affect student AI usage?', a: 'The EU AI Act requires transparency in AI-assisted academic work. Students must disclose AI-generated content, but it does not completely ban AI tool usage in education.'},
        {q: 'Can I still use ChatGPT while studying in Europe?', a: 'Yes, but you must comply with your university specific policies. Most European universities allow AI tools in appropriate contexts, requiring academic integrity and disclosure.'},
        {q: 'When does the EU AI Act take effect?', a: 'The EU AI Act was formally adopted in 2024 with phased implementation. Most provisions will take effect between 2025-2026, with member states developing specific enforcement rules.'}
      ]
    },
    'best-ai-coding-tools-2026': {
      zh: [
        {q: '2026年最好的AI编程工具有哪些？', a: '2026年主流AI编程工具包括GitHub Copilot、Cursor、Replit等。其中Cursor因其深度AI集成和多文件编辑能力受到开发者广泛好评。'},
        {q: 'AI编程工具对学生免费吗？', a: '部分AI编程工具提供学生优惠。GitHub Copilot对学生免费，Replit有免费计划，Cursor提供免费试用。建议学生充分利用教育优惠。'},
        {q: 'AI编程工具会取代程序员吗？', a: 'AI编程工具是辅助工具而非替代品。它们能提高编码效率，但程序员的架构设计、问题分析和创新能力仍然不可替代。'}
      ],
      en: [
        {q: 'What are the best AI coding tools in 2026?', a: 'Top AI coding tools in 2026 include GitHub Copilot, Cursor, and Replit. Cursor is particularly popular for its deep AI integration and multi-file editing capabilities.'},
        {q: 'Are AI coding tools free for students?', a: 'Many offer student discounts. GitHub Copilot is free for students, Replit has a free tier, and Cursor offers free trials. Students should take advantage of education pricing.'},
        {q: 'Will AI coding tools replace programmers?', a: 'AI coding tools are assistants, not replacements. They boost coding efficiency, but programmers skills in architecture design, problem analysis, and innovation remain irreplaceable.'}
      ]
    }
  };

  const faqs = faqMap[slug];
  if (faqs) {
    const lang = locale === 'en' ? 'en' : 'zh';
    return faqs[lang].map(f => ({ question: f.q, answer: f.a }));
  }

  // Fallback: generate generic FAQ based on title
  if (locale === 'en') {
    return [
      { question: `What is ${title}?`, answer: `This article provides a comprehensive guide about ${title}, covering key concepts, practical tips, and recommendations for international students.` },
      { question: `How can this help international students?`, answer: `This guide helps students understand and navigate the topic effectively, with actionable advice tailored for the student experience.` },
      { question: `Where can I learn more?`, answer: `Visit mi-to-ai.com for more guides, tools, and resources designed specifically for international students using AI.` }
    ];
  }
  return [
    { question: `什么是${title}？`, answer: `本文提供了关于${title}的全面指南，涵盖关键概念、实用技巧和针对留学生的建议。` },
    { question: `这对留学生有什么帮助？`, answer: `本指南帮助学生有效理解和应对相关话题，提供针对学生群体的可操作建议。` },
    { question: `在哪里可以了解更多？`, answer: `访问mi-to-ai.com获取更多专为使用AI的留学生设计的指南、工具和资源。` }
  ];
}

const blogFaqItems = generateFaqFromSlug(
  post.slug as string,
  locale === 'en' ? post.titleEn : post.title,
  locale
);

const jsonLd = {
 "@context": "https://schema.org",
 "@type": "BlogPosting",
 "headline": locale === 'en' ? post.titleEn : post.title,
 "description": post.excerpt,
 "datePublished": post.createdAt,
 "dateModified": post.updatedAt,
 "url": `https://www.mi-to-ai.com/blog/${post.slug}`,
 "keywords": post.seoKeywords.join(', '),
 "author": {
  "@type": "Organization",
  "name": "留学生AI生存指南",
  "url": "https://www.mi-to-ai.com"
 },
 "publisher": {
  "@type": "Organization",
  "name": "留学生AI生存指南",
  "url": "https://www.mi-to-ai.com"
 },
 "mainEntityOfPage": {
  "@type": "WebPage",
  "@id": `https://www.mi-to-ai.com/blog/${post.slug}`
 },
};

const breadcrumbs = [
 { name: locale === 'en' ? 'Home' : '首页', href: '/' },
 { name: locale === 'en' ? 'Blog' : '博客', href: '/blog' },
 { name: locale === 'en' ? post.titleEn : post.title },
];
---

<Layout
 title={locale === 'en' ? post.titleEn : post.title}
 description={post.excerpt}
 type="article"
 canonicalUrl={`https://www.mi-to-ai.com/blog/${post.slug}`}
 jsonLd={jsonLd}
 breadcrumbs={breadcrumbs}
 faqItems={blogFaqItems}
>
 <main class="min-h-screen bg-gradient-to-b from-gray-50 to-white ">
  <!-- Breadcrumb -->
  <nav class="pt-20 pb-4 px-4">
   <div class="max-w-4xl mx-auto">
    <ol class="flex items-center gap-2 text-sm text-gray-500 ">
     <li><a href="/" class="hover:text-blue-600 :text-blue-400">{locale === 'en' ? 'Home' : '首页'}</a></li>
     <li>/</li>
     <li><a href="/blog" class="hover:text-blue-600 :text-blue-400">{locale === 'en' ? 'Blog' : '博客'}</a></li>
     <li>/</li>
     <li class="text-gray-900 truncate">{locale === 'en' ? post.titleEn : post.title}</li>
    </ol>
   </div>
  </nav>

  <!-- Article Header -->
  <header class="px-4 pb-8">
   <div class="max-w-4xl mx-auto">
    <!-- Category & Read Time -->
    <div class="flex items-center gap-3 mb-4">
     <span class="px-3 py-1 text-xs font-medium rounded-full bg-blue-100 text-blue-700 ">
      {categoryLabels[post.category]?.[locale === 'en' ? 'en' : 'zh'] || post.category}
     </span>
     <span class="text-sm text-gray-500 ">
      {post.readTime} {locale === 'en' ? 'min read' : '分钟阅读'}
     </span>
     <span class="text-sm text-gray-500 ">
      {locale === 'en' ? 'Updated' : '更新于'} {post.updatedAt}
     </span>
    </div>

    <!-- Title -->
    <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 mb-6 leading-tight">
     {locale === 'en' ? post.titleEn : post.title}
    </h1>

    <!-- Excerpt -->
    <p class="text-lg text-gray-600 mb-6">
     {post.excerpt}
    </p>

    <!-- Tags -->
    <div class="flex flex-wrap gap-2">
     {post.tags.map(tag => (
      <span class="px-3 py-1 text-sm rounded-full bg-gray-100 text-gray-600 ">
       #{tag}
      </span>
     ))}
    </div>
   </div>
  </header>

  <!-- Article Content -->
  <article class="px-4 pb-12">
   <div class="max-w-4xl mx-auto">
    <div class="blog-content prose prose-lg max-w-none"
     set:html={htmlContent}
    />
   </div>
  </article>

  <!-- Related Posts -->
  {relatedPosts.length > 0 && (
   <section class="px-4 pb-16">
    <div class="max-w-4xl mx-auto">
     <h2 class="text-2xl font-bold text-gray-900 mb-8">
      {locale === 'en' ? 'Related Articles' : '相关文章'}
     </h2>
     <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {relatedPosts.map(related => (
       <a href={`/blog/${related.slug}`} class="block bg-white rounded-xl shadow-sm hover:shadow-lg transition-shadow border border-gray-100 p-5">
        <span class="px-2 py-1 text-xs font-medium rounded-full bg-blue-100 text-blue-700 mb-3 inline-block">
         {categoryLabels[related.category]?.[locale === 'en' ? 'en' : 'zh'] || related.category}
        </span>
        <h3 class="text-base font-bold text-gray-900 mb-2 line-clamp-2">
         {locale === 'en' ? related.titleEn : related.title}
        </h3>
        <p class="text-sm text-gray-600 line-clamp-2">
         {related.excerpt}
        </p>
        <span class="text-sm text-gray-500 mt-3 block">
         {related.readTime} {locale === 'en' ? 'min read' : '分钟'}
        </span>
       </a>
      ))}
     </div>
    </div>
   </section>
  )}

  <!-- Back to Blog -->
  <section class="px-4 pb-16">
   <div class="max-w-4xl mx-auto text-center">
    <a
     href="/blog"
     class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-blue-600 text-white hover:bg-blue-700 transition-colors font-medium"
    >
     ← {locale === 'en' ? 'Back to Blog' : '返回博客'}
    </a>
   </div>
  </section>
 </main>
</Layout>

<style is:global>
 /* Additional styles for rendered markdown content */
 .blog-content {
  color: #1f2937;
 }
 .blog-content h1,
 .blog-content h2,
 .blog-content h3,
 .blog-content h4,
 .blog-content h5,
 .blog-content h6 {
  color: #111827;
  font-weight: 700;
  margin-top: 1.5em;
  margin-bottom: 0.75em;
 }
 .blog-content h1 { font-size: 2em; }
 .blog-content h2 { font-size: 1.5em; }
 .blog-content h3 { font-size: 1.25em; }
 .blog-content p {
  color: #374151;
  line-height: 1.8;
  margin-bottom: 1em;
 }
 .blog-content a {
  color: #2563eb;
  text-decoration: underline;
 }
 .blog-content a:hover {
  color: #1d4ed8;
 }
 .blog-content strong {
  color: #111827;
  font-weight: 700;
 }
 .blog-content em {
  color: #374151;
 }
 .blog-content code {
  background-color: #f3f4f6;
  padding: 0.15em 0.4em;
  border-radius: 4px;
  font-size: 0.875em;
  color: #dc2626;
 }
 .blog-content table {
   width: 100%;
   border-collapse: collapse;
   margin: 1.5rem 0;
   font-size: 0.9em;
   display: block;
   overflow-x: auto;
   -webkit-overflow-scrolling: touch;
 }
 .blog-content td,
 .blog-content th {
  border: 1px solid #e5e7eb;
  padding: 0.5rem 0.75rem;
  text-align: left;
 }
 .blog-content th {
  background-color: #f9fafb;
  font-weight: 600;
  color: #111827;
 }
 .blog-content tr:nth-child(even) {
  background-color: #f9fafb;
 }
 .blog-content td {
  color: #374151;
 }
 .blog-content ul {
  list-style-type: disc;
  padding-left: 1.5rem;
  margin: 1rem 0;
 }
 .blog-content ol {
  list-style-type: decimal;
  padding-left: 1.5rem;
  margin: 1rem 0;
 }
 .blog-content li {
  margin: 0.25rem 0;
  color: #374151;
 }
 .blog-content li.checkbox {
  list-style-type: none;
  margin-left: -1.5rem;
 }
 .blog-content blockquote {
  margin: 1.5rem 0;
  font-style: italic;
  border-left: 4px solid #3b82f6;
  background-color: #eff6ff;
  padding: 0.75rem 1rem;
  border-radius: 0 8px 8px 0;
  color: #1e40af;
 }
 .blog-content hr {
  margin: 2rem 0;
  border: 0;
  border-top: 1px solid #e5e7eb;
 }
 .blog-content img {
  max-width: 100%;
  border-radius: 8px;
  margin: 1rem 0;
 }
 /* Override any dark mode interference */
 .dark .blog-content {
  color: #1f2937 !important;
  background-color: transparent;
 }
 .dark .blog-content h1,
 .dark .blog-content h2,
 .dark .blog-content h3,
 .dark .blog-content strong {
  color: #111827 !important;
 }
 .dark .blog-content p,
 .dark .blog-content li,
 .dark .blog-content td {
  color: #374151 !important;
 }
 .dark .blog-content a {
  color: #3b82f6 !important;
 }
</style>
