// JSON-LD for comparison page
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "AI工具对比 - MI TO AI留学生存指南",
  "description": "对比留学生的20款主流AI工具，从易用性、功能、价格等多维度进行全面比较，帮助找到最适合自己的AI工具。",
  "url": "https://www.mi-to-ai.com/compare",
  "isPartOf": {
    "@type": "WebSite",
    "name": "MI TO AI留学生存指南",
    "url": "https://www.mi-to-ai.com"
  }
};

// Category mapping for display (using translation keys)
const categoryLabels: Record<string, string> = {
  writing: 'tools.categories.writing',
  coding: 'tools.categories.coding',
  design: 'tools.categories.design',
  research: 'tools.categories.research',
  communication: 'tools.categories.communication',
};

// Pricing mapping for display (using translation keys)
const pricingLabels: Record<string, string> = {
  free: 'tools.pricing.free',
  freemium: 'tools.pricing.freemium',
  paid: 'tools.pricing.paid',
};
---

<Layout
  title={translate(locale, 'compare.title')}
  description={translate(locale, 'compare.description')}
  jsonLd={jsonLd}
  locale={locale}
>
  <!-- Header -->
  <div class="bg-white border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <h1 class="text-3xl font-bold mb-2">{translate(locale, 'compare.title')}</h1>
      <p class="text-gray-600">{translate(locale, 'compare.description')}</p>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Tool Selection Panel -->
    <div class="mb-8">
      <div class="bg-white rounded-xl border border-gray-200 p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-semibold">{translate(locale, 'compare.selectTools')}</h2>
          <button
            id="clearAll"
            class="text-sm text-gray-500 hover:text-gray-700 transition-colors hidden"
          >
            {translate(locale, 'compare.clearAll')}
          </button>
        </div>

        <!-- Selected tools display -->
        <div id="selectedTools" class="flex flex-wrap gap-3 mb-4 min-h-[44px]">
          <span class="text-gray-500 text-sm flex items-center h-full" id="placeholder">
            {translate(locale, 'compare.selectPlaceholder')}
          </span>
        </div>

        <!-- Start Comparison Button -->
        <div class="mb-4">
          <button
            id="startCompareBtn"
            class="w-full py-3 px-4 bg-gradient-to-r from-primary-500 to-blue-500 text-white rounded-lg font-medium shadow-sm hover:from-primary-600 hover:to-blue-600 transition-all disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:from-primary-500 disabled:hover:to-blue-500 flex items-center justify-center gap-2"
            disabled
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
            <span id="compareBtnText">{translate(locale, 'compare.startCompare') || '开始对比'}</span>
            <span id="compareCount" class="bg-white/20 px-2 py-0.5 rounded-full text-sm hidden">0</span>
          </button>
        </div>

        <!-- Category filter for tool selection -->
        <div class="mb-4">
          <div class="flex flex-wrap gap-2">
            <button
              class="category-filter px-3 py-1.5 text-sm rounded-full bg-primary-100 text-primary-700 font-medium transition-colors"
              data-category=""
            >
              {translate(locale, 'compare.allCategories')}
            </button>
            {Object.entries(categoryLabels).map(([key, label]) => (
              <button
                class="category-filter px-3 py-1.5 text-sm rounded-full bg-gray-100 text-gray-600 hover:bg-gray-200 transition-colors"
                data-category={key}
              >
                {label}
              </button>
            ))}
          </div>
        </div>

        <!-- Tool selection grid -->
        <div id="toolGrid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3 max-h-[400px] overflow-y-auto">
          {allTools.map(tool => (
            <button
              class="tool-select-btn flex flex-col items-center p-3 rounded-lg border border-gray-200 hover:border-primary-300 hover:bg-primary-50 transition-all duration-200 text-left"
              data-tool-id={tool.id}
            >
              <img
                src={tool.imageUrl}
                alt={tool.name}
                class="w-16 h-16 rounded-lg object-cover mb-2"
                loading="lazy"
              />
              <span class="text-sm font-medium text-gray-900 text-center">{tool.name}</span>
              <span class={`text-xs mt-1 ${tool.pricing === 'free' ? 'text-green-600' : tool.pricing === 'paid' ? 'text-purple-600' : 'text-blue-600'}`}>
                {pricingLabels[tool.pricing]}
              </span>
            </button>
          ))}
        </div>
      </div>
    </div>

    <!-- Comparison Table -->
    <div id="comparisonSection" class="hidden">
      <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full min-w-[800px]">
            <thead class="bg-gray-50 border-b border-gray-200">
              <tr>
                <th class="sticky left-0 bg-gray-50 px-4 py-4 text-left font-semibold text-gray-700 min-w-[140px] z-10 shadow-[2px_0_4px_rgba(0,0,0,0.05)]">
                  <span class="hidden md:inline">{translate(locale, 'compare.compareDimensions')}</span>
                  <span class="md:hidden">{translate(locale, 'compare.compareDimensions')}</span>
                </th>
                {[1, 2, 3, 4, 5].map(n => (
                  <th class="px-4 py-4 text-center min-w-[160px] hidden" data-header-index={n - 1}>
                    <div class="flex flex-col items-center">
                      <img
                        src="https://placehold.co/400x200/gray/ffffff?text=..."
                        alt="Tool"
                        class="w-12 h-12 rounded-lg object-cover mb-2"
                        loading="lazy"
                      />
                      <span class="font-semibold text-gray-900">Tool Name</span>
                      <button
                        class="remove-tool-btn mt-2 text-xs text-red-500 hover:text-red-700 transition-colors hidden"
                        data-remove-index={n - 1}
                      >
                        {translate(locale, 'compare.remove')}
                      </button>
                    </div>
                  </th>
                ))}
              </tr>
            </thead>
            <tbody id="comparisonBody">
              <!-- Dynamic content will be inserted here by JS -->
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Empty state -->
    <div id="emptyState" class="text-center py-16">
      <svg class="w-20 h-20 mx-auto text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2" />
      </svg>
      <h3 class="text-lg font-semibold text-gray-700 mb-2">{translate(locale, 'compare.noSelection')}</h3>
      <p class="text-gray-500">{translate(locale, 'compare.selectToCompare')}</p>
    </div>
  </div>
</Layout>

<script define:vars={{ allTools, categoryLabels, pricingLabels, locale, translations }}>
  const MAX_COMPARE = 5;
  const MIN_COMPARE = 2;
  let selectedToolIds = [];

  // Translation helper
  function getNestedValue(obj, path) {
    return path.split('.').reduce((current, key) => current?.[key], obj);
  }
  function t(key, params) {
    const translation = getNestedValue(translations[locale], key)
      ?? getNestedValue(translations['zh'], key)
      ?? key;
    if (typeof translation !== 'string') return key;
    if (params) {
      return Object.entries(params).reduce((str, [k, v]) => {
        return str.replace(new RegExp(`\\{${k}\\}`, 'g'), String(v));
      }, translation);
    }
    return translation;
  }

  // DOM Elements
  const toolGrid = document.getElementById('toolGrid');
  const selectedToolsContainer = document.getElementById('selectedTools');
  const placeholder = document.getElementById('placeholder');
  const clearAllBtn = document.getElementById('clearAll');
  const comparisonSection = document.getElementById('comparisonSection');
  const emptyState = document.getElementById('emptyState');
  const categoryFilters = document.querySelectorAll('.category-filter');
  const toolSelectBtns = document.querySelectorAll('.tool-select-btn');
  const startCompareBtn = document.getElementById('startCompareBtn');
  const compareCountSpan = document.getElementById('compareCount');

  // Helper functions
  function getToolById(id) {
    return allTools.find(t => t.id === id);
  }

  function getToolBySlug(slug) {
    return allTools.find(t => t.slug === slug);
  }

  function getToolIdBySlug(slug) {
    const tool = getToolBySlug(slug);
    return tool ? tool.id : null;
  }

  function formatPrice(tool) {
    if (tool.pricing === 'free') return t('tools.free');
    const monthly = tool.priceDetail.monthly || 0;
    const currency = tool.priceDetail.currency === 'USD' ? '$' : '¥';
    return `${currency}${monthly}/月`;
  }

  function renderSelectedTools() {
    if (selectedToolIds.length === 0) {
      placeholder.classList.remove('hidden');
      clearAllBtn.classList.add('hidden');
      selectedToolsContainer.innerHTML = '';
      return;
    }

    placeholder.classList.add('hidden');
    clearAllBtn.classList.remove('hidden');

    const selectedToolsHtml = selectedToolIds.map(id => {
      const tool = getToolById(id);
      return `
        <div class="flex items-center gap-2 bg-primary-100 text-primary-700 px-3 py-1.5 rounded-full text-sm">
          <img src="${tool.imageUrl}" alt="${tool.name}" class="w-5 h-5 rounded object-cover" />
          <span>${tool.name}</span>
          <button class="remove-selected-btn hover:text-primary-900 transition-colors" data-remove-id="${id}">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      `;
    }).join('');

    selectedToolsContainer.innerHTML = selectedToolsHtml;

    // Add event listeners to remove buttons
    selectedToolsContainer.querySelectorAll('.remove-selected-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const removeId = btn.dataset.removeId;
        removeToolFromCompare(removeId);
      });
    });
  }

  function updateToolGridSelections() {
    toolSelectBtns.forEach(btn => {
      const toolId = btn.dataset.toolId;
      if (selectedToolIds.includes(toolId)) {
        btn.classList.add('border-primary-500', 'bg-primary-50');
        btn.classList.remove('hover:border-primary-300', 'hover:bg-primary-50');
      } else {
        btn.classList.remove('border-primary-500', 'bg-primary-50');
        btn.classList.add('hover:border-primary-300', 'hover:bg-primary-50');
      }

      // Disable if max reached and this tool is not selected
      if (selectedToolIds.length >= MAX_COMPARE && !selectedToolIds.includes(toolId)) {
        btn.classList.add('opacity-50', 'cursor-not-allowed');
      } else {
        btn.classList.remove('opacity-50', 'cursor-not-allowed');
      }
    });
  }

  function renderComparisonTable() {
    if (selectedToolIds.length < MIN_COMPARE) {
      comparisonSection.classList.add('hidden');
      emptyState.classList.remove('hidden');
      return;
    }

    comparisonSection.classList.remove('hidden');
    emptyState.classList.add('hidden');

    const tools = selectedToolIds.map(id => getToolById(id));

    // Update table headers
    const headerCells = comparisonSection.querySelectorAll('[data-header-index]');
    headerCells.forEach((cell, index) => {
      if (index < tools.length) {
        cell.innerHTML = `
          <div class="flex flex-col items-center">
            <img src="${tools[index].imageUrl}" alt="${tools[index].name}" class="w-12 h-12 rounded-lg object-cover mb-2" />
            <span class="font-semibold text-gray-900">${tools[index].name}</span>
            <button class="remove-tool-btn mt-2 text-xs text-red-500 hover:text-red-700 transition-colors" data-remove-index="${index}">
              ${t('compare.remove')}
            </button>
          </div>
        `;
        cell.classList.remove('hidden');
        const btn = cell.querySelector('.remove-tool-btn');
        if (btn) btn.classList.remove('hidden');
      } else {
        cell.classList.add('hidden');
        const btn = cell.querySelector('.remove-tool-btn');
        if (btn) btn.classList.add('hidden');
      }
    });

    // Build comparison rows
    const comparisonBody = document.getElementById('comparisonBody');
    const rows = [
      // Basic Info
      {
        category: t('compare.dimensions.basicInfo'),
        rows: [
          {
            label: t('compare.dimensions.category'),
            values: tools.map(tool => t(categoryLabels[tool.category]) || tool.category)
          },
          {
            label: t('compare.dimensions.pricingModel'),
            values: tools.map(tool => t(pricingLabels[tool.pricing]) || tool.pricing)
          },
          {
            label: t('compare.dimensions.price'),
            values: tools.map(t => formatPrice(t))
          },
        ]
      },
      // Ratings
      {
        category: t('compare.dimensions.ratings'),
        rows: [
          {
            label: t('compare.dimensions.overallRating'),
            values: tools.map(t => t.rating.toFixed(1)),
            suffix: t('compare.outOf'),
            highlight: true
          },
          {
            label: t('compare.dimensions.ratingCount'),
            values: tools.map(t => t.ratingCount.toLocaleString())
          },
        ]
      },
      // Dimensions
      {
        category: t('compare.dimensions.dimensionScores'),
        rows: [
          {
            label: t('compare.dimensions.easeOfUse'),
            values: tools.map(t => t.dimensions.easeOfUse),
            isScore: true
          },
          {
            label: t('compare.dimensions.features'),
            values: tools.map(t => t.dimensions.features),
            isScore: true
          },
          {
            label: t('compare.dimensions.value'),
            values: tools.map(t => t.dimensions.value),
            isScore: true
          },
        ]
      },
      // Features
      {
        category: t('compare.dimensions.coreFeatures'),
        rows: tools.map(t => ({
          label: t.name,
          values: t.features
        }))
      },
    ];

    // Render table body
    let tbodyHtml = '';

    rows.forEach(section => {
      tbodyHtml += `
        <tr class="bg-gray-50">
          <td colspan="${tools.length + 1}" class="px-4 py-2 text-sm font-semibold text-gray-700">
            ${section.category}
          </td>
        </tr>
      `;

      section.rows.forEach(row => {
        tbodyHtml += `<tr class="border-b border-gray-100 hover:bg-gray-50/50 transition-colors">`;
        tbodyHtml += `<td class="px-4 py-3 text-sm font-medium text-gray-600">${row.label}</td>`;

        row.values.forEach((value, idx) => {
          if (row.isScore) {
            const score = parseFloat(value);
            const percentage = (score / 5) * 100;
            const bestScore = Math.max(...row.values.map(v => parseFloat(v)));
            const isBest = score === bestScore;

            tbodyHtml += `
              <td class="px-4 py-3">
                <div class="flex flex-col items-center gap-1">
                  <div class="flex items-center gap-2">
                    <span class="text-sm font-medium ${isBest ? 'text-primary-600' : 'text-gray-900'}">${score.toFixed(1)}</span>
                    ${row.suffix || ''}
                    ${isBest ? '<span class="text-xs text-primary-600 font-medium">' + t('compare.best') + '</span>' : ''}
                  </div>
                  <div class="w-24 h-2 bg-gray-200 rounded-full overflow-hidden">
                    <div class="h-full bg-primary-500 rounded-full transition-all" style="width: ${percentage}%"></div>
                  </div>
                </div>
              </td>
            `;
          } else if (Array.isArray(value)) {
            tbodyHtml += `
              <td class="px-4 py-3">
                <div class="flex flex-wrap justify-center gap-1">
                  ${value.slice(0, 3).map(f => `<span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded">${f}</span>`).join('')}
                  ${value.length > 3 ? `<span class="text-xs text-gray-400">+${value.length - 3}</span>` : ''}
                </div>
              </td>
            `;
          } else {
            tbodyHtml += `<td class="px-4 py-3 text-center text-sm text-gray-700">${value}</td>`;
          }
        });

        tbodyHtml += `</tr>`;
      });
    });

    // Add action row
    tbodyHtml += `
      <tr class="bg-gray-50">
        <td class="px-4 py-3 text-sm font-medium text-gray-700">${t('compare.operation')}</td>
        ${tools.map(tool => `
          <td class="px-4 py-3 text-center">
            <a href="/tools/${tool.slug}" class="text-sm text-primary-600 hover:text-primary-700 font-medium">
              ${t('compare.viewDetails')} →
            </a>
          </td>
        `).join('')}
      </tr>
    `;

    comparisonBody.innerHTML = tbodyHtml;

    // Add remove button listeners
    comparisonSection.querySelectorAll('.remove-tool-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const cell = e.currentTarget.closest('th');
        const index = parseInt(cell.dataset.headerIndex);
        if (!isNaN(index) && selectedToolIds[index]) {
          removeToolFromCompare(selectedToolIds[index]);
        }
      });
    });
  }

  function addToolToCompare(toolId) {
    if (selectedToolIds.includes(toolId)) {
      removeToolFromCompare(toolId);
      return;
    }

    if (selectedToolIds.length >= MAX_COMPARE) {
      alert(t('compare.maxCompareAlert', { count: MAX_COMPARE }));
      return;
    }

    selectedToolIds.push(toolId);
    updateUI();
  }

  function removeToolFromCompare(toolId) {
    selectedToolIds = selectedToolIds.filter(id => id !== toolId);
    updateUI();
  }

  function clearAll() {
    selectedToolIds = [];
    // Clear localStorage
    localStorage.removeItem('compareToolIds');
    // Dispatch event to update CompareButton components
    window.dispatchEvent(new CustomEvent('compareListClearAll'));
    // Reset category filter to show all tools
    filterByCategory('');
    updateUI();
  }

  function scrollToComparison() {
    comparisonSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function updateUI() {
    renderSelectedTools();
    updateToolGridSelections();
    renderComparisonTable();

    // Update Start Comparison button state
    if (startCompareBtn && compareCountSpan) {
      if (selectedToolIds.length >= MIN_COMPARE) {
        startCompareBtn.disabled = false;
        compareCountSpan.textContent = selectedToolIds.length.toString();
        compareCountSpan.classList.remove('hidden');
      } else {
        startCompareBtn.disabled = true;
        compareCountSpan.classList.add('hidden');
      }
    }

    // Save to localStorage
    localStorage.setItem('compareToolIds', JSON.stringify(selectedToolIds));
  }

  function filterByCategory(category) {
    toolSelectBtns.forEach(btn => {
      if (!category) {
        btn.classList.remove('hidden');
      } else {
        const tool = getToolById(btn.dataset.toolId);
        if (tool.category === category) {
          btn.classList.remove('hidden');
        } else {
          btn.classList.add('hidden');
        }
      }
    });

    // Update active filter button
    categoryFilters.forEach(btn => {
      if (btn.dataset.category === category) {
        btn.classList.add('bg-primary-100', 'text-primary-700', 'font-medium');
        btn.classList.remove('bg-gray-100', 'text-gray-600', 'hover:bg-gray-200');
      } else {
        btn.classList.remove('bg-primary-100', 'text-primary-700', 'font-medium');
        btn.classList.add('bg-gray-100', 'text-gray-600', 'hover:bg-gray-200');
      }
    });
  }

  // Event Listeners
  toolSelectBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      addToolToCompare(btn.dataset.toolId);
    });
  });

  categoryFilters.forEach(btn => {
    btn.addEventListener('click', () => {
      filterByCategory(btn.dataset.category);
    });
  });

  clearAllBtn.addEventListener('click', clearAll);

  // Start Comparison button handler
  if (startCompareBtn) {
    startCompareBtn.addEventListener('click', () => {
      if (selectedToolIds.length >= MIN_COMPARE) {
        scrollToComparison();
      }
    });
  }

  // Initialize from URL parameters first, then fall back to localStorage
  function initializeFromUrl() {
    const urlParams = new URLSearchParams(window.location.search);
    const toolsParam = urlParams.get('tools');
    if (toolsParam) {
      const slugs = toolsParam.split(',').map(s => s.trim()).filter(Boolean);
      const ids = slugs.map(getToolIdBySlug).filter(Boolean);
      if (ids.length > 0) {
        return ids;
      }
    }
    return null;
  }

  function initCompareTools() {
    // First try URL parameters
    const urlToolIds = initializeFromUrl();
    if (urlToolIds && urlToolIds.length >= 2) {
      return urlToolIds;
    }

    // Then try localStorage
    const savedToolIds = localStorage.getItem('compareToolIds');
    if (savedToolIds) {
      try {
        const parsed = JSON.parse(savedToolIds);
        if (Array.isArray(parsed) && parsed.length >= 2) {
          return parsed;
        }
      } catch (e) {
        // ignore
      }
    }

    return [];
  }

  selectedToolIds = initCompareTools();

  // Listen for compare list changes from CompareButton components
  window.addEventListener('compareListChange', (e) => {
    const { toolSlug, isInCompare } = e.detail;
    const toolId = getToolIdBySlug(toolSlug);
    if (toolId) {
      if (isInCompare && !selectedToolIds.includes(toolId)) {
        selectedToolIds.push(toolId);
      } else if (!isInCompare) {
        selectedToolIds = selectedToolIds.filter(id => id !== toolId);
      }
      // Also update localStorage to keep in sync
      localStorage.setItem('compareToolIds', JSON.stringify(selectedToolIds));
      updateUI();
    }
  });

  // Also listen for compareListClearAll event to sync state when tools are cleared from other pages
  window.addEventListener('compareListClearAll', () => {
    // Re-read from localStorage in case it was cleared from another page
    const savedToolIds = localStorage.getItem('compareToolIds');
    if (savedToolIds) {
      try {
        const parsed = JSON.parse(savedToolIds);
        if (Array.isArray(parsed)) {
          selectedToolIds = parsed;
        } else {
          selectedToolIds = [];
        }
      } catch (e) {
        selectedToolIds = [];
      }
    } else {
      selectedToolIds = [];
    }
    updateUI();
  });

  // Initial render
  updateUI();
</script>

<style>
  /* Custom scrollbar for tool grid */
  #toolGrid::-webkit-scrollbar {
    width: 6px;
  }

  #toolGrid::-webkit-scrollbar-track {
    background: #f1f1f1;
    border-radius: 3px;
  }

  #toolGrid::-webkit-scrollbar-thumb {
    background: #c1c1c1;
    border-radius: 3px;
  }

  #toolGrid::-webkit-scrollbar-thumb:hover {
    background: #a1a1a1;
  }

  /* Table responsiveness */
  @media (max-width: 768px) {
    table {
      font-size: 0.875rem;
    }

    th, td {
      padding: 0.5rem;
    }
  }

  /* Sticky first column */
  th:first-child,
  td:first-child {
    position: sticky;
    left: 0;
    z-index: 10;
    background: white;
  }

  thead th:first-child {
    background: #f9fafb;
  }

  /* Animations */
  .tool-select-btn {
    animation: fadeIn 0.3s ease-out;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>