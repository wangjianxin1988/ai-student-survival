---
export const prerender = true;

import Layout from '@/layouts/Layout.astro';
import { type Locale, t as translate, getLocaleFromUrl, defaultLocale } from '@/i18n';

// Get locale from URL
const locale: Locale = getLocaleFromUrl(Astro.url);

// Helper to generate locale-aware hrefs
function getLocaleHref(path: string): string {
  if (locale === defaultLocale) {
    return path;
  }
  return `/${locale}${path}`;
}

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": "https://mi-to-ai.com/#website",
  "name": translate(locale, 'site.name'),
  "description": translate(locale, 'site.description'),
  "url": "https://mi-to-ai.com",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://mi-to-ai.com/tools?q={search_term_string}",
    "query-input": "required name=search_term_string"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "AI Tools for Students",
    "itemListElement": []
  }
};

// Homepage FAQPage Schema for GEO - AI Overviews boost
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What AI tools are available for international students?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "This platform provides a comprehensive database of 500+ AI tools including GPT-4, Claude, Midjourney, and many others, specifically curated for international students with information about pricing, payment methods, accessibility in China, and academic use cases."
      }
    },
    {
      "@type": "Question",
      "name": "How can students in China access Western AI tools?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Students in China can access Western AI tools through virtual cards (like Depax, AssistCard), gift cards, web-based tools that bypass restrictions, and specific China-friendly payment solutions. Our payment solutions section provides step-by-step guides."
      }
    },
    {
      "@type": "Question",
      "name": "What university policies should international students know about AI tool usage?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "University policies on AI tools vary by institution. Our policy database covers 200+ university AI guidelines, including restrictions on ChatGPT usage, academic integrity requirements, and approved tool lists. Always check your specific university's policy before using AI tools in coursework."
      }
    },
    {
      "@type": "Question",
      "name": "How do I choose the right AI tool for my academic needs?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Our platform provides detailed comparisons of AI tools across categories including writing, research, coding, image generation, and language learning. Each tool listing includes pricing, key features, China accessibility rating, and student reviews."
      }
    },
    {
      "@type": "Question",
      "name": "What payment methods work for international students subscribing to AI tools?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Payment methods include international credit cards, virtual cards (Depax, Wenjin virtual card), Alipay/WeChat Pay with foreign card linking, cryptocurrency, and region-specific gift cards. Our payment solutions database provides working methods tested by real international students."
      }
    },
    {
      "@type": "Question",
      "name": "Are AI tools allowed in academic work?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Policies vary by university and country. Many universities allow AI as a learning aid but require disclosure. Some prohibit it for exams or graded assignments. Our university policy database covers specific guidelines for 200+ institutions worldwide."
      }
    },
    {
      "@type": "Question",
      "name": "What AI tools work well without credit card verification?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Free AI tools that don't require credit card include Claude (free tier), Copilot (free with Microsoft account), Gemini, Poe, and various open-source models. Our tools database filters for free-accessibility in China and no-credit-card requirements."
      }
    },
    {
      "@type": "Question",
      "name": "How can students share and discover AI tool recommendations?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "This platform includes a community section where students can share tool reviews, survival guides, ask questions, and discover recommendations from fellow international students facing similar challenges."
      }
    }
  ]
};

// BreadcrumbList Schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://mi-to-ai.com"
    }
  ]
};

// Stats for display
const stats = [
  { value: '500+', label: translate(locale, 'home.painPoints.stats.tools'), href: getLocaleHref('/tools') },
  { value: '20+', label: translate(locale, 'home.painPoints.stats.paymentSolutions'), href: getLocaleHref('/payment') },
  { value: '200+', label: translate(locale, 'home.painPoints.stats.universityPolicies'), href: getLocaleHref('/policies') },
  { value: '1000+', label: translate(locale, 'home.painPoints.stats.promptTemplates'), href: getLocaleHref('/prompts') },
];

// Pain points data with locale-aware hrefs
const painPoints = [
  { key: '1', title: translate(locale, 'home.painPoints.points.1.title'), desc: translate(locale, 'home.painPoints.points.1.description'), href: getLocaleHref('/tools') },
  { key: '2', title: translate(locale, 'home.painPoints.points.2.title'), desc: translate(locale, 'home.painPoints.points.2.description'), href: getLocaleHref('/payment') },
  { key: '3', title: translate(locale, 'home.painPoints.points.3.title'), desc: translate(locale, 'home.painPoints.points.3.description'), href: getLocaleHref('/policies') },
  { key: '4', title: translate(locale, 'home.painPoints.points.4.title'), desc: translate(locale, 'home.painPoints.points.4.description'), href: getLocaleHref('/prompts') },
];

// Module cards data with locale-aware hrefs
const modules = [
  {
    href: getLocaleHref('/tools'),
    key: 'aiTools',
    color: 'primary',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />`
  },
  {
    href: getLocaleHref('/payment'),
    key: 'payment',
    color: 'secondary',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />`
  },
  {
    href: getLocaleHref('/policies'),
    key: 'policies',
    color: 'green',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />`
  },
  {
    href: getLocaleHref('/prompts'),
    key: 'prompts',
    color: 'orange',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />`
  },
];

// Footer links with locale-aware hrefs
const footerLinks = {
  coreFeatures: [
    { href: getLocaleHref('/tools'), label: translate(locale, 'nav.aiTools'), desc: '100+ AI工具收录' },
    { href: getLocaleHref('/payment'), label: translate(locale, 'nav.payment'), desc: '虚拟卡·礼品卡·地区定价' },
    { href: getLocaleHref('/policies'), label: translate(locale, 'nav.policies'), desc: '各校AI使用政策' },
    { href: getLocaleHref('/prompts'), label: translate(locale, 'nav.prompts'), desc: '高质量模板库' },
    { href: getLocaleHref('/offers'), label: translate(locale, 'nav.offers'), desc: '申请经验分享' },
    { href: getLocaleHref('/questions'), label: translate(locale, 'nav.questions'), desc: '留学生互助社区' },
  ],
  toolCategories: [
    { href: getLocaleHref('/tools?category=writing'), label: translate(locale, 'footer.writing') },
    { href: getLocaleHref('/tools?category=coding'), label: translate(locale, 'footer.coding') },
    { href: getLocaleHref('/tools?category=design'), label: translate(locale, 'footer.design') },
    { href: getLocaleHref('/tools?category=research'), label: translate(locale, 'footer.research') },
  ],
  resources: [
    { href: getLocaleHref('/faq'), label: translate(locale, 'nav.faq') },
    { href: getLocaleHref('/compare'), label: translate(locale, 'nav.compare') },
    { href: getLocaleHref('/map'), label: translate(locale, 'nav.map') },
    { href: getLocaleHref('/survival'), label: translate(locale, 'nav.survival') },
  ],
  company: [
    { href: '/about', label: translate(locale, 'nav.about') },
    { href: '/contact', label: translate(locale, 'nav.contact') },
    { href: '/about#guide', label: translate(locale, 'nav.useGuide') },
  ],
  legal: [
    { href: '/privacy', label: translate(locale, 'nav.privacy') },
    { href: '/terms', label: translate(locale, 'nav.terms') },
  ],
};
---

<Layout
  title={translate(locale, 'site.name')}
  description={translate(locale, 'site.description')}
  type="website"
  jsonLd={[jsonLd, faqSchema, breadcrumbSchema]}
  locale={locale}
>
  <!-- Hero Section - Killer Features Highlight -->
  <section class="hero-gradient text-white relative overflow-hidden">
    <!-- Background decoration -->
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-20 left-10 w-72 h-72 bg-purple-500 rounded-full blur-3xl"></div>
      <div class="absolute bottom-20 right-10 w-96 h-96 bg-blue-500 rounded-full blur-3xl"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-24 relative z-10">
      <div class="text-center mb-12">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold mb-6 animate-fade-in">
          {translate(locale, 'home.hero.title')}
        </h1>
        <p class="text-xl sm:text-2xl text-primary-100 mb-6 animate-slide-up">
          {translate(locale, 'home.hero.subtitle')}
        </p>
        <p class="text-lg text-primary-200 mb-10 max-w-2xl mx-auto animate-slide-up">
          {translate(locale, 'home.hero.description')}
        </p>

        <!-- Killer Features Stats -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-4xl mx-auto mb-10 animate-slide-up">
          <a href={getLocaleHref('/tools')} class="bg-white/10 backdrop-blur-sm rounded-xl p-4 hover:bg-white/20 transition-all hover:scale-105">
            <div class="text-3xl font-bold text-white mb-1">500+</div>
            <div class="text-sm text-primary-200">{translate(locale, 'home.hero.statTools')}</div>
          </a>
          <a href={getLocaleHref('/payment')} class="bg-white/10 backdrop-blur-sm rounded-xl p-4 hover:bg-white/20 transition-all hover:scale-105">
            <div class="text-3xl font-bold text-white mb-1">20+</div>
            <div class="text-sm text-primary-200">{translate(locale, 'home.hero.statPayment')}</div>
          </a>
          <a href={getLocaleHref('/policies')} class="bg-white/10 backdrop-blur-sm rounded-xl p-4 hover:bg-white/20 transition-all hover:scale-105">
            <div class="text-3xl font-bold text-white mb-1">200+</div>
            <div class="text-sm text-primary-200">{translate(locale, 'home.hero.statPolicies')}</div>
          </a>
          <a href={getLocaleHref('/prompts')} class="bg-white/10 backdrop-blur-sm rounded-xl p-4 hover:bg-white/20 transition-all hover:scale-105">
            <div class="text-3xl font-bold text-white mb-1">1000+</div>
            <div class="text-sm text-primary-200">{translate(locale, 'home.hero.statPrompts')}</div>
          </a>
        </div>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-slide-up">
          <a href={getLocaleHref('/tools')} class="btn bg-white text-primary-700 hover:bg-primary-50 px-8 py-3 text-lg font-semibold shadow-lg">
            {translate(locale, 'home.hero.exploreTools')}
          </a>
          <a href={getLocaleHref('/offers')} class="btn border-2 border-white/30 text-white hover:bg-white/10 px-8 py-3 text-lg">
            {translate(locale, 'home.hero.viewOffers')}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Core Modules -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold mb-4">{translate(locale, 'home.modules.title')}</h2>
        <p class="text-gray-600 max-w-2xl mx-auto">{translate(locale, 'home.modules.subtitle')}</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {modules.map(mod => (
          <a href={mod.href} class={`card p-6 hover:border-${mod.color}-300 group`}>
            <div class={`w-12 h-12 rounded-xl bg-${mod.color}-100 text-${mod.color}-600 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform`}>
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={mod.icon} />
            </div>
            <h3 class="text-xl font-semibold mb-2 group-hover:text-primary-600 transition-colors">
              {translate(locale, `home.modules.${mod.key}.title`)}
            </h3>
            <p class="text-gray-600 text-sm mb-4">
              {translate(locale, `home.modules.${mod.key}.description`)}
            </p>
            <div class={`flex items-center text-${mod.color}-600 text-sm font-medium`}>
              <span>{translate(locale, 'common.browse')}</span>
              <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Pain Point Section -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold mb-6">{translate(locale, 'home.painPoints.title')}</h2>
          <div class="space-y-4">
            {painPoints.map((point, index) => (
              <a href={point.href} class="flex items-start gap-4 p-2 rounded-lg hover:bg-white hover:shadow-md transition-all cursor-pointer">
                <div class="w-8 h-8 rounded-full bg-red-100 text-red-600 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <span class="text-sm font-bold">{index + 1}</span>
                </div>
                <div>
                  <h4 class="font-semibold mb-1">{point.title}</h4>
                  <p class="text-gray-600 text-sm">{point.desc}</p>
                </div>
              </a>
            ))}
          </div>
        </div>
        <div class="bg-white rounded-2xl shadow-xl p-8">
          <h3 class="text-xl font-semibold mb-6 text-center">{translate(locale, 'home.modules.title')}</h3>
          <div class="grid grid-cols-2 gap-4">
            {stats.map((stat, index) => (
              <a href={stat.href} class={`text-center p-4 rounded-xl ${
                index === 0 ? 'bg-green-50' :
                index === 1 ? 'bg-blue-50' :
                index === 2 ? 'bg-purple-50' : 'bg-orange-50'
              } hover:shadow-md transition-shadow block`}>
                <div class={`text-3xl font-bold mb-2 ${
                  index === 0 ? 'text-green-600' :
                  index === 1 ? 'text-blue-600' :
                  index === 2 ? 'text-purple-600' : 'text-orange-600'
                }`}>{stat.value}</div>
                <div class="text-sm text-gray-600">{stat.label}</div>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-gray-900 text-white">
    <!-- Main Footer -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8 mb-8">
        <!-- Brand & Description -->
        <div class="lg:col-span-1">
          <a href="/" class="flex items-center gap-2 mb-4">
            <img src="/logo.svg" alt={translate(locale, 'site.name')} class="w-10 h-10 rounded-lg" />
            <span class="font-semibold text-lg">{translate(locale, 'site.name')}</span>
          </a>
          <p class="text-gray-400 text-sm mb-4">
            {translate(locale, 'footer.tagline')}
          </p>
          <!-- Social Links -->
          <div class="flex items-center gap-4">
            <a href="https://twitter.com" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white transition-colors" aria-label="Twitter">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8.29 20.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0022 5.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.072 4.072 0 012.8 9.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 012 18.407a11.616 11.616 0 006.29 1.84"/>
              </svg>
            </a>
            <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white transition-colors" aria-label="GitHub">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path fillRule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clipRule="evenodd"/>
              </svg>
            </a>
            <a href="https://discord.com" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white transition-colors" aria-label="Discord">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c1.5148 1.271 3.1723 2.0526 4.8396 2.3696a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.3167 3.6096-1.0892 4.8391-2.3682.0358-.0285.0587-.0658.0826-.1055.0349-.0948.0526-.1963.0541-.3054-.0005-.0173-.0019-.0346-.0019-.0526.0007-.0189.0009-.0377.0009-.0566zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189z"/>
              </svg>
            </a>
          </div>
        </div>

        <!-- Core Features -->
        <div>
          <h4 class="font-semibold mb-4 text-white">{translate(locale, 'footer.coreFeatures') || '核心功能'}</h4>
          <ul class="space-y-2 text-sm">
            {footerLinks.coreFeatures.map(link => (
              <li><a href={link.href} class="text-gray-400 hover:text-white transition-colors">{link.label}</a></li>
            ))}
          </ul>
        </div>

        <!-- Resources -->
        <div>
          <h4 class="font-semibold mb-4 text-white">{translate(locale, 'footer.resources') || '资源'}</h4>
          <ul class="space-y-2 text-sm">
            {footerLinks.resources.map(link => (
              <li><a href={link.href} class="text-gray-400 hover:text-white transition-colors">{link.label}</a></li>
            ))}
            {footerLinks.toolCategories.map(link => (
              <li><a href={link.href} class="text-gray-400 hover:text-white transition-colors">{link.label}</a></li>
            ))}
          </ul>
        </div>

        <!-- Company & Legal -->
        <div>
          <h4 class="font-semibold mb-4 text-white">{translate(locale, 'nav.about')}</h4>
          <ul class="space-y-2 text-sm">
            {footerLinks.company.map(link => (
              <li><a href={link.href} class="text-gray-400 hover:text-white transition-colors">{link.label}</a></li>
            ))}
          </ul>
          <h4 class="font-semibold mb-4 mt-6 text-white">{translate(locale, 'nav.privacy')}</h4>
          <ul class="space-y-2 text-sm">
            {footerLinks.legal.map(link => (
              <li><a href={link.href} class="text-gray-400 hover:text-white transition-colors">{link.label}</a></li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Bottom Bar -->
      <div class="border-t border-gray-800 pt-8">
        <div class="flex flex-col md:flex-row items-center justify-between gap-4">
          <p class="text-sm text-gray-500">
            &copy; 2026 {translate(locale, 'site.name')}. All rights reserved.
            <span class="ml-2 px-2 py-0.5 bg-indigo-600/30 text-indigo-300 text-xs rounded">v1.0.0</span>
          </p>
          <div class="flex items-center gap-6 text-sm text-gray-500">
            <a href="/about" class="hover:text-white transition-colors">{translate(locale, 'nav.about')}</a>
            <a href="/contact" class="hover:text-white transition-colors">{translate(locale, 'nav.contact')}</a>
            <a href="/privacy" class="hover:text-white transition-colors">{translate(locale, 'nav.privacy')}</a>
            <a href="/terms" class="hover:text-white transition-colors">{translate(locale, 'nav.terms')}</a>
          </div>
        </div>
      </div>
    </div>
  </footer>
</Layout>