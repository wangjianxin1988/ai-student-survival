---
// Community posts are now managed via /questions/ page (Community tab).
// The PostDetail component for community posts is at /community/[id] which is served
// via this page — redirecting to /questions for unified experience.
export const prerender = false;
const { id } = Astro.params;
---
<Layout title="社区动态 - AI留学生存指南">
  <div class="min-h-screen bg-gray-50 py-8">
    <div class="max-w-4xl mx-auto px-4">
      <div class="mb-6">
        <a href="/questions" class="text-blue-600 hover:text-blue-700 flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          返回问答社区
        </a>
      </div>

      {id && (
        <div class="bg-white rounded-lg border border-gray-200 p-8 text-center">
          <p class="text-gray-600 mb-4">帖子详情已迁移至问答社区页面</p>
          <a href="/questions" class="inline-flex items-center gap-2 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">
            前往问答社区
          </a>
        </div>
      )}
    </div>
  </div>
</Layout>
