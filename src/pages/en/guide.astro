---
export const prerender = true;

import Layout from '@/layouts/Layout.astro';
import { type Locale, t as translate } from '@/i18n';

// Force English locale
const locale: Locale = 'en';
---

<Layout
  title={translate(locale, 'about.guide.title')}
  description="Learn how to use MI TO AI Student Survival Guide features, from tool recommendations to payment solutions."
  locale={locale}
>
  <!-- Hero Section -->
  <section class="hero-gradient text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-4xl lg:text-5xl font-bold mb-4">{translate(locale, 'about.guide.title')}</h1>
        <p class="text-xl text-primary-100 max-w-2xl mx-auto">
          {translate(locale, 'guide.hero.subtitle')}
        </p>
      </div>
    </div>
  </section>

  <!-- Quick Navigation -->
  <section class="py-8 bg-white border-b">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="#browse-tools" class="px-4 py-2 bg-primary-100 text-primary-700 rounded-lg hover:bg-primary-200 transition-colors">
          {translate(locale, 'guide.nav.tools')}
        </a>
        <a href="#payment" class="px-4 py-2 bg-green-100 text-green-700 rounded-lg hover:bg-green-200 transition-colors">
          {translate(locale, 'guide.nav.payment')}
        </a>
        <a href="#policies" class="px-4 py-2 bg-orange-100 text-orange-700 rounded-lg hover:bg-orange-200 transition-colors">
          {translate(locale, 'guide.nav.policies')}
        </a>
        <a href="#prompts" class="px-4 py-2 bg-purple-100 text-purple-700 rounded-lg hover:bg-purple-200 transition-colors">
          {translate(locale, 'guide.nav.prompts')}
        </a>
        <a href="#community" class="px-4 py-2 bg-blue-100 text-blue-700 rounded-lg hover:bg-blue-200 transition-colors">
          {translate(locale, 'guide.nav.community')}
        </a>
      </div>
    </div>
  </section>

  <!-- Browse Tools Guide -->
  <section id="browse-tools" class="py-16 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold mb-8 flex items-center">
        <span class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center mr-4">
          <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
          </svg>
        </span>
        {translate(locale, 'guide.tools.title')}
      </h2>

      <div class="bg-white rounded-xl p-6 shadow-sm mb-8">
        <h3 class="text-xl font-semibold mb-4">{translate(locale, 'guide.tools.search.title')}</h3>
        <p class="text-gray-600 mb-4">{translate(locale, 'guide.tools.search.desc')}</p>
        <div class="bg-gray-100 rounded-lg p-4 font-mono text-sm">
          <p class="text-gray-600">{translate(locale, 'guide.tools.search.step1')}</p>
          <p class="text-gray-600">{translate(locale, 'guide.tools.search.step2')}</p>
          <p class="text-gray-600">{translate(locale, 'guide.tools.search.step3')}</p>
        </div>
      </div>

      <div class="bg-white rounded-xl p-6 shadow-sm mb-8">
        <h3 class="text-xl font-semibold mb-4">{translate(locale, 'guide.tools.filter.title')}</h3>
        <p class="text-gray-600 mb-4">{translate(locale, 'guide.tools.filter.desc')}</p>
        <div class="grid md:grid-cols-4 gap-4">
          <div class="bg-primary-50 rounded-lg p-4 text-center">
            <div class="font-semibold text-primary-700">{translate(locale, 'footer.writing')}</div>
            <div class="text-sm text-gray-600">ChatGPT, Claude, Gemini</div>
          </div>
          <div class="bg-green-50 rounded-lg p-4 text-center">
            <div class="font-semibold text-green-700">{translate(locale, 'footer.coding')}</div>
            <div class="text-sm text-gray-600">GitHub Copilot, Cursor</div>
          </div>
          <div class="bg-orange-50 rounded-lg p-4 text-center">
            <div class="font-semibold text-orange-700">{translate(locale, 'footer.design')}</div>
            <div class="text-sm text-gray-600">Figma AI, Midjourney</div>
          </div>
          <div class="bg-purple-50 rounded-lg p-4 text-center">
            <div class="font-semibold text-purple-700">{translate(locale, 'footer.research')}</div>
            <div class="text-sm text-gray-600">Perplexity, Elicit</div>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-xl p-6 shadow-sm">
        <h3 class="text-xl font-semibold mb-4">{translate(locale, 'guide.tools.compare.title')}</h3>
        <p class="text-gray-600 mb-4">{translate(locale, 'guide.tools.compare.desc')}</p>
        <a href="/en/compare" class="inline-flex items-center text-primary-600 hover:text-primary-700 font-medium">
          {translate(locale, 'nav.compare')}
          <svg class="w-5 h-5 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Payment Guide -->
  <section id="payment" class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold mb-8 flex items-center">
        <span class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center mr-4">
          <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
          </svg>
        </span>
        {translate(locale, 'guide.payment.title')}
      </h2>

      <div class="space-y-6">
        <div class="bg-gray-50 rounded-xl p-6">
          <h3 class="text-lg font-semibold mb-3">{translate(locale, 'guide.payment.virtualCards.title')}</h3>
          <p class="text-gray-600 mb-4">{translate(locale, 'guide.payment.virtualCards.desc')}</p>
          <ul class="list-disc list-inside text-gray-600 space-y-2">
            <li>{translate(locale, 'guide.payment.virtualCards.step1')}</li>
            <li>{translate(locale, 'guide.payment.virtualCards.step2')}</li>
            <li>{translate(locale, 'guide.payment.virtualCards.step3')}</li>
          </ul>
        </div>

        <div class="bg-gray-50 rounded-xl p-6">
          <h3 class="text-lg font-semibold mb-3">{translate(locale, 'guide.payment.giftCards.title')}</h3>
          <p class="text-gray-600 mb-4">{translate(locale, 'guide.payment.giftCards.desc')}</p>
          <ul class="list-disc list-inside text-gray-600 space-y-2">
            <li>{translate(locale, 'guide.payment.giftCards.step1')}</li>
            <li>{translate(locale, 'guide.payment.giftCards.step2')}</li>
          </ul>
        </div>

        <div class="bg-gray-50 rounded-xl p-6">
          <h3 class="text-lg font-semibold mb-3">{translate(locale, 'guide.payment.regional.title')}</h3>
          <p class="text-gray-600 mb-4">{translate(locale, 'guide.payment.regional.desc')}</p>
          <a href="/en/payment" class="inline-flex items-center text-primary-600 hover:text-primary-700 font-medium">
            {translate(locale, 'nav.payment')}
            <svg class="w-5 h-5 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- University Policies Guide -->
  <section id="policies" class="py-16 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold mb-8 flex items-center">
        <span class="w-10 h-10 bg-orange-100 rounded-lg flex items-center justify-center mr-4">
          <svg class="w-5 h-5 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
          </svg>
        </span>
        {translate(locale, 'guide.policies.title')}
      </h2>

      <div class="bg-white rounded-xl p-6 shadow-sm">
        <p class="text-gray-600 mb-6">{translate(locale, 'guide.policies.desc')}</p>

        <div class="space-y-4">
          <div class="border-l-4 border-primary-500 pl-4">
            <h4 class="font-semibold">{translate(locale, 'guide.policies.step1.title')}</h4>
            <p class="text-gray-600 text-sm">{translate(locale, 'guide.policies.step1.desc')}</p>
          </div>
          <div class="border-l-4 border-green-500 pl-4">
            <h4 class="font-semibold">{translate(locale, 'guide.policies.step2.title')}</h4>
            <p class="text-gray-600 text-sm">{translate(locale, 'guide.policies.step2.desc')}</p>
          </div>
          <div class="border-l-4 border-orange-500 pl-4">
            <h4 class="font-semibold">{translate(locale, 'guide.policies.step3.title')}</h4>
            <p class="text-gray-600 text-sm">{translate(locale, 'guide.policies.step3.desc')}</p>
          </div>
        </div>

        <a href="/en/policies" class="inline-flex items-center text-primary-600 hover:text-primary-700 font-medium mt-6">
          {translate(locale, 'nav.policies')}
          <svg class="w-5 h-5 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Prompts Guide -->
  <section id="prompts" class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold mb-8 flex items-center">
        <span class="w-10 h-10 bg-purple-100 rounded-lg flex items-center justify-center mr-4">
          <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
          </svg>
        </span>
        {translate(locale, 'guide.prompts.title')}
      </h2>

      <div class="bg-gradient-to-br from-purple-50 to-primary-50 rounded-xl p-6 mb-8">
        <h3 class="text-xl font-semibold mb-4">{translate(locale, 'guide.prompts.howToUse.title')}</h3>
        <ol class="list-decimal list-inside text-gray-600 space-y-3">
          <li>{translate(locale, 'guide.prompts.howToUse.step1')}</li>
          <li>{translate(locale, 'guide.prompts.howToUse.step2')}</li>
          <li>{translate(locale, 'guide.prompts.howToUse.step3')}</li>
          <li>{translate(locale, 'guide.prompts.howToUse.step4')}</li>
        </ol>
      </div>

      <div class="bg-white rounded-xl p-6 shadow-sm border">
        <h3 class="text-lg font-semibold mb-4">{translate(locale, 'guide.prompts.example.title')}</h3>
        <div class="bg-gray-900 text-gray-100 rounded-lg p-4 font-mono text-sm overflow-x-auto">
          <p class="text-green-400">// {translate(locale, 'guide.prompts.example.context')}</p>
          <p class="mt-2">{translate(locale, 'guide.prompts.example.prompt')}</p>
        </div>
      </div>

      <a href="/en/prompts" class="inline-flex items-center text-primary-600 hover:text-primary-700 font-medium mt-6">
        {translate(locale, 'nav.prompts')}
        <svg class="w-5 h-5 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </section>

  <!-- Community Guide -->
  <section id="community" class="py-16 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold mb-8 flex items-center">
        <span class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center mr-4">
          <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </span>
        {translate(locale, 'guide.community.title')}
      </h2>

      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-white rounded-xl p-6 shadow-sm">
          <h3 class="text-lg font-semibold mb-4">{translate(locale, 'nav.questions')}</h3>
          <p class="text-gray-600 mb-4">{translate(locale, 'guide.community.questions.desc')}</p>
          <a href="/en/questions" class="inline-flex items-center text-primary-600 hover:text-primary-700 font-medium">
            {translate(locale, 'nav.questions')}
            <svg class="w-5 h-5 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-sm">
          <h3 class="text-lg font-semibold mb-4">{translate(locale, 'nav.offers')}</h3>
          <p class="text-gray-600 mb-4">{translate(locale, 'guide.community.offers.desc')}</p>
          <a href="/en/offers" class="inline-flex items-center text-green-600 hover:text-green-700 font-medium">
            {translate(locale, 'nav.offers')}
            <svg class="w-5 h-5 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-sm">
          <h3 class="text-lg font-semibold mb-4">{translate(locale, 'nav.survival')}</h3>
          <p class="text-gray-600 mb-4">{translate(locale, 'guide.community.survival.desc')}</p>
          <a href="/en/survival" class="inline-flex items-center text-orange-600 hover:text-orange-700 font-medium">
            {translate(locale, 'nav.survival')}
            <svg class="w-5 h-5 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-sm">
          <h3 class="text-lg font-semibold mb-4">{translate(locale, 'nav.map')}</h3>
          <p class="text-gray-600 mb-4">{translate(locale, 'guide.community.map.desc')}</p>
          <a href="/en/map" class="inline-flex items-center text-blue-600 hover:text-blue-700 font-medium">
            {translate(locale, 'nav.map')}
            <svg class="w-5 h-5 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl font-bold mb-4">{translate(locale, 'guide.cta.title')}</h2>
      <p class="text-gray-600 mb-8">{translate(locale, 'guide.cta.desc')}</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/en/tools" class="px-6 py-3 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors">
          {translate(locale, 'nav.aiTools')}
        </a>
        <a href="/en/contact" class="px-6 py-3 border-2 border-primary-600 text-primary-600 rounded-lg hover:bg-primary-50 transition-colors">
          {translate(locale, 'nav.contact')}
        </a>
      </div>
    </div>
  </section>
</Layout>