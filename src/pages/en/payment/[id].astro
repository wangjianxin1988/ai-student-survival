---
export const prerender = false;

import Layout from '@/layouts/Layout.astro';
import { paymentSolutionsData, getPaymentSolutionById, getRelatedSolutions, paymentCategories } from '@/data/paymentSolutions';
import FavoriteButton from '@/components/favorites/FavoriteButton';
import ShareButton from '@/components/common/ShareButton';
import LikeButton from '@/components/common/LikeButton';
import CommentSection from '@/components/user/CommentSection';

// Get solution ID from URL params
const { id } = Astro.params;
const solution = getPaymentSolutionById(id || '');

if (!solution) {
  return Astro.redirect('/en/payment');
}

// Get related solutions (same category)
const relatedSolutions = getRelatedSolutions(solution, 3);

// Category labels mapping (English)
const categoryLabels: Record<string, string> = {
  virtual_card: 'Virtual Card',
  gift_card: 'Gift Card',
  regional_pricing: 'Regional Pricing',
  troubleshooting: 'Troubleshooting'
};

// Category icons mapping
const categoryIcons: Record<string, string> = {
  virtual_card: '💳',
  gift_card: '🎁',
  regional_pricing: '🌍',
  troubleshooting: '❓'
};

// Difficulty labels (English)
const difficultyLabels: Record<string, string> = {
  easy: 'Easy',
  medium: 'Medium',
  hard: 'Complex'
};

// Reliability labels (English)
const reliabilityLabels: Record<string, string> = {
  high: 'High',
  medium: 'Medium',
  low: 'Low'
};

// Map difficulty to estimated time
const difficultyTimeMap: Record<string, string> = {
  'easy': 'PT15M',    // 15 minutes
  'medium': 'PT30M',  // 30 minutes
  'hard': 'PT60M'     // 1 hour
};

// Parse content into steps for HowTo schema
function extractSteps(content: string): { name: string; text: string }[] {
  const steps: { name: string; text: string }[] = [];
  const lines = content.split('\n');
  let currentStep = '';
  let currentStepName = '';
  let inStep = false;

  for (const line of lines) {
    // Match step headers like "### 1. Step Name" or "## Step Name"
    const stepMatch = line.match(/^#{1,3}\s*(\d+)?\.?\s*(.+)/);
    if (stepMatch) {
      if (currentStep && currentStepName) {
        steps.push({ name: currentStepName.trim(), text: currentStep.trim() });
      }
      currentStepName = stepMatch[2] || `Step ${steps.length + 1}`;
      currentStep = '';
      inStep = true;
    } else if (inStep && line.trim()) {
      currentStep += line + '\n';
    }
  }

  if (currentStep && currentStepName) {
    steps.push({ name: currentStepName.trim(), text: currentStep.trim() });
  }

  return steps.slice(0, 10); // Limit to 10 steps for schema
}

const steps = extractSteps(solution.content);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": ["Article", "HowTo"],
  "name": solution.title,
  "description": `Tutorial: ${solution.title}. Category: ${categoryLabels[solution.category]}.`,
  "url": `https://www.mi-to-ai.com/en/payment/${solution.id}`,
  "totalTime": difficultyTimeMap[solution.difficulty] || 'PT30M',
  "step": steps.map((step, index) => ({
    "@type": "HowToStep",
    "position": index + 1,
    "name": step.name,
    "text": step.text
  })),
  "tool": [
    {
      "@type": "HowToTool",
      "name": "Computer or Phone"
    },
    {
      "@type": "HowToTool",
      "name": "Internet Connection"
    },
    {
      "@type": "HowToTool",
      "name": categoryLabels[solution.category] || solution.category
    }
  ],
  "supply": [
    {
      "@type": "HowToSupply",
      "name": solution.category === 'virtual_card' ? 'Virtual Credit Card' :
              solution.category === 'gift_card' ? 'Gift Card' :
              solution.category === 'regional_pricing' ? 'Regional Account' : 'Payment Method'
    }
  ]
};

// Simple markdown to HTML converter for content rendering
function renderMarkdown(content: string): string {
  let html = content
    // Headers
    .replace(/^### (.+)$/gm, '<h3 class="text-lg font-semibold mt-6 mb-3 text-gray-800">$1</h3>')
    .replace(/^## (.+)$/gm, '<h2 class="text-xl font-bold mt-8 mb-4 text-gray-900">$1</h2>')
    .replace(/^# (.+)$/gm, '<h1 class="text-2xl font-bold mt-8 mb-4 text-gray-900">$1</h1>')
    // Bold and italic
    .replace(/\*\*(.+?)\*\*/g, '<strong class="font-semibold text-gray-900">$1</strong>')
    .replace(/\*(.+?)\*/g, '<em class="italic">$1</em>')
    // Code blocks
    .replace(/```(\w+)?\n([\s\S]+?)```/g, '<pre class="bg-gray-100 rounded-lg p-4 overflow-x-auto my-4"><code>$2</code></pre>')
    // Inline code
    .replace(/`(.+?)`/g, '<code class="bg-gray-100 px-1 py-0.5 rounded text-sm">$1</code>')
    // Lists
    .replace(/^- (.+)$/gm, '<li class="ml-4 list-disc list-inside text-gray-700 mb-1">$1</li>')
    .replace(/^(\d+)\. (.+)$/gm, '<li class="ml-4 list-decimal list-inside text-gray-700 mb-1">$2</li>')
    // Tables - simple approach
    .replace(/\|(.+)\|/g, (match) => {
      const cells = match.split('|').filter(c => c.trim());
      if (cells.every(c => c.trim().match(/^-+$/))) {
        return ''; // Skip separator rows
      }
      const isHeader = cells.some(c => c.trim().match(/^[A-Za-z\s]+$/));
      const cellTag = isHeader ? 'th' : 'td';
      const cellClass = isHeader ? 'font-semibold bg-gray-50' : '';
      return `<tr>${cells.map(c => `<${cellTag} class="${cellClass} border border-gray-200 px-4 py-2">${c.trim()}</${cellTag}>`).join('')}</tr>`;
    })
    // Paragraphs
    .replace(/\n\n/g, '</p><p class="text-gray-700 leading-relaxed mb-4">')
    // Line breaks
    .replace(/\n/g, '<br />');

  // Wrap in table if we have table rows
  if (html.includes('<tr>')) {
    html = html.replace(/(<tr>[\s\S]*?<\/tr>)+/g, '<table class="w-full border-collapse border border-gray-200 my-4 text-sm">$&</table>');
  }

  return `<p class="text-gray-700 leading-relaxed mb-4">${html}</p>`;
}

const renderedContent = renderMarkdown(solution.content);

// Payment category labels for sidebar
const paymentCategoryLabels: Record<string, string> = {
  virtual_card: 'Virtual Cards',
  gift_card: 'Gift Cards',
  regional_pricing: 'Regional Pricing',
  troubleshooting: 'Troubleshooting'
};
---

<Layout
  title={solution.title}
  description={solution.excerpt}
  jsonLd={jsonLd}
>
  <!-- Breadcrumb -->
  <div class="bg-white border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <nav class="flex items-center gap-2 text-sm">
        <a href="/en" class="text-gray-500 hover:text-gray-900">Home</a>
        <span class="text-gray-400">/</span>
        <a href="/en/payment" class="text-gray-500 hover:text-gray-900">Payment Solutions</a>
        <span class="text-gray-400">/</span>
        <span class="text-gray-900 font-medium truncate max-w-[200px]">{solution.title}</span>
      </nav>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="grid lg:grid-cols-3 gap-8">
      <!-- Main Content -->
      <article class="lg:col-span-2">
        <!-- Header -->
        <header class="mb-8">
          <div class="flex items-center gap-2 mb-3 flex-wrap">
            <span class={`badge ${
              solution.difficulty === 'easy' ? 'bg-green-100 text-green-700' :
              solution.difficulty === 'medium' ? 'bg-yellow-100 text-yellow-700' :
              'bg-red-100 text-red-700'
            }`}>
              {difficultyLabels[solution.difficulty]}
            </span>
            <span class="badge bg-gray-100 text-gray-700 flex items-center gap-1">
              {categoryIcons[solution.category]} {categoryLabels[solution.category]}
            </span>
            <span class={`badge ${
              solution.reliability === 'high' ? 'bg-blue-100 text-blue-700' :
              solution.reliability === 'medium' ? 'bg-gray-100 text-gray-700' :
              'bg-orange-100 text-orange-700'
            }`}>
              Reliability: {reliabilityLabels[solution.reliability]}
            </span>
          </div>
          <div class="flex items-center justify-between mb-4">
            <h1 class="text-3xl font-bold">{solution.title}</h1>
            <div class="flex items-center gap-2">
              <FavoriteButton client:load targetType="payment_solution" targetId={solution.id} locale="en" />
              <LikeButton client:load targetType="payment_solution" targetId={solution.id} locale="en" />
              <ShareButton client:load title={solution.title} description={solution.excerpt} targetType="payment_solution" targetId={solution.id} />
            </div>
          </div>
          <p class="text-gray-600 mb-4">{solution.excerpt}</p>
          <div class="flex items-center gap-4 text-sm text-gray-500">
            <div class="flex items-center gap-1">
              <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
              <span>{solution.rating} ({solution.ratingCount.toLocaleString()} ratings)</span>
            </div>
            <span>{solution.viewCount.toLocaleString()} views</span>
            <span>Updated {new Date(solution.updatedAt).toLocaleDateString('en-US')}</span>
          </div>
          <div class="flex items-center gap-2 mt-3 flex-wrap">
            {solution.tags.map(tag => (
              <span class="text-xs bg-gray-100 text-gray-600 px-2 py-1 rounded">{tag}</span>
            ))}
          </div>
        </header>

        <!-- Content -->
        <div class="prose prose-gray max-w-none mb-8">
          <div class="bg-white rounded-xl border border-gray-200 p-6 md:p-8">
            <div set:html={renderedContent} />
          </div>
        </div>

        <!-- Related Tools -->
        {solution.toolIds.length > 0 && (
          <div class="mb-8">
            <h3 class="text-lg font-semibold mb-4">Related Tools</h3>
            <div class="flex flex-wrap gap-2">
              {solution.toolIds.map(toolId => (
                <a href={`/en/tools/${toolId}`} class="px-4 py-2 bg-primary-50 text-primary-700 rounded-lg text-sm hover:bg-primary-100 transition-colors">
                  {toolId}
                </a>
              ))}
            </div>
          </div>
        )}

        <!-- Share Section -->
        <div class="bg-white rounded-xl border border-gray-200 p-6">
          <h3 class="font-semibold mb-4">Found this helpful? Share with your classmates!</h3>
          <div class="flex gap-3">
            <button onclick="navigator.clipboard.writeText(window.location.href)" class="btn-outline text-sm">
              Copy Link
            </button>
<ShareButton client:load title={solution.title} description={solution.excerpt} targetType="payment_solution" targetId={solution.id} />
            <CommentSection
        </div>

        <!-- Comments Section -->
        <CommentSection client:visible targetType="payment_solution" targetId={solution.id} locale="en" />
      </article>

      <!-- Sidebar -->
      <aside class="lg:col-span-1">
        <div class="sticky top-24 space-y-6">
          <!-- Quick Info -->
          <div class="bg-white rounded-xl border border-gray-200 p-6">
            <h3 class="font-semibold mb-4">Guide Info</h3>
            <dl class="space-y-3 text-sm">
              <div class="flex justify-between">
                <dt class="text-gray-500">Difficulty</dt>
                <dd class="font-medium">
                  {difficultyLabels[solution.difficulty]}
                </dd>
              </div>
              <div class="flex justify-between">
                <dt class="text-gray-500">Category</dt>
                <dd class="font-medium flex items-center gap-1">
                  {categoryIcons[solution.category]} {categoryLabels[solution.category]}
                </dd>
              </div>
              <div class="flex justify-between">
                <dt class="text-gray-500">Reliability</dt>
                <dd class="font-medium">
                  {reliabilityLabels[solution.reliability]}
                </dd>
              </div>
              <div class="flex justify-between">
                <dt class="text-gray-500">Rating</dt>
                <dd class="font-medium flex items-center gap-1">
                  <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                  {solution.rating}
                </dd>
              </div>
              <div class="flex justify-between">
                <dt class="text-gray-500">Reviews</dt>
                <dd class="font-medium">{solution.ratingCount.toLocaleString()}</dd>
              </div>
              <div class="flex justify-between">
                <dt class="text-gray-500">Views</dt>
                <dd class="font-medium">{solution.viewCount.toLocaleString()}</dd>
              </div>
              <div class="flex justify-between">
                <dt class="text-gray-500">Updated</dt>
                <dd class="font-medium">{new Date(solution.updatedAt).toLocaleDateString('en-US')}</dd>
              </div>
            </dl>
          </div>

          <!-- Related Solutions -->
          {relatedSolutions.length > 0 && (
            <div class="bg-white rounded-xl border border-gray-200 p-6">
              <h3 class="font-semibold mb-4">Related Guides</h3>
              <div class="space-y-3">
                {relatedSolutions.map(related => (
                  <a href={`/en/payment/${related.id}`} class="block p-3 rounded-lg hover:bg-gray-50 transition-colors cursor-pointer">
                    <div class="flex items-center gap-2 mb-1">
                      <span class="text-sm">{categoryIcons[related.category]}</span>
                      <span class="text-xs text-gray-500">{categoryLabels[related.category]}</span>
                    </div>
                    <span class="text-sm font-medium text-gray-900 line-clamp-2">
                      {related.title}
                    </span>
                  </a>
                ))}
              </div>
            </div>
          )}

          <!-- Category Links -->
          <div class="bg-white rounded-xl border border-gray-200 p-6">
            <h3 class="font-semibold mb-4">Browse More</h3>
            <div class="space-y-2">
              {paymentCategories.filter(cat => cat.value !== solution.category).map(cat => (
                <a href={`/en/payment?category=${cat.value}`} class="flex items-center gap-2 p-2 rounded-lg hover:bg-gray-50 transition-colors">
                  <span>{cat.icon}</span>
                  <span class="text-sm text-gray-700">{paymentCategoryLabels[cat.value] || cat.label}</span>
                </a>
              ))}
            </div>
          </div>

          <!-- Survival Guides -->
          <div class="bg-white rounded-xl border border-gray-200 p-6">
            <h3 class="font-semibold mb-4">Survival Guides</h3>
            <div class="space-y-2">
              <a href="/en/survival/category/scam" class="flex items-center gap-2 p-2 rounded-lg hover:bg-gray-50 transition-colors">
                <span>⚠️</span>
                <span class="text-sm text-gray-700">Scam Prevention</span>
              </a>
              <a href="/en/survival/category/safety" class="flex items-center gap-2 p-2 rounded-lg hover:bg-gray-50 transition-colors">
                <span>🔒</span>
                <span class="text-sm text-gray-700">Safety Tips</span>
              </a>
              <a href="/en/survival/category/legal" class="flex items-center gap-2 p-2 rounded-lg hover:bg-gray-50 transition-colors">
                <span>⚖️</span>
                <span class="text-sm text-gray-700">Legal Notice</span>
              </a>
              <a href="/en/survival" class="flex items-center gap-2 p-2 rounded-lg hover:bg-gray-50 transition-colors">
                <span>📌</span>
                <span class="text-sm text-gray-700">View All</span>
              </a>
            </div>
          </div>

          <!-- Back Link -->
          <a href="/en/payment" class="block text-center text-sm text-gray-500 hover:text-gray-700 transition-colors py-2">
            ← Back to Payment Solutions
          </a>
        </div>
      </aside>
    </div>
  </div>
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
