// Translate solution content to English
const translatedSolutions: PaymentSolutionData[] = paymentSolutionsData.map(solution => {
  const translation = solutionTranslations[solution.id];
  if (translation) {
    return {
      ...solution,
      title: translation.title,
      excerpt: translation.excerpt,
      tags: translation.tags
    };
  }
  return solution;
});

// Get category from URL params for filtering
const selectedCategory = Astro.url.searchParams.get('category') || '';

// Filter by category if selected
const categoryFilteredSolutions = selectedCategory
  ? translatedSolutions.filter(s => s.category === selectedCategory)
  : translatedSolutions;

// Category labels mapping
const categoryLabels: Record<string, string> = {
  virtual_card: 'Virtual Cards',
  gift_card: 'Gift Cards',
  regional_pricing: 'Regional Pricing',
  troubleshooting: 'Troubleshooting'
};

// Category icons mapping
const categoryIcons: Record<string, string> = {
  virtual_card: '💳',
  gift_card: '🎁',
  regional_pricing: '🌍',
  troubleshooting: '❓'
};

// Search functionality
const searchQuery = Astro.url.searchParams.get('q') || '';
const filteredSolutions = searchQuery
  ? categoryFilteredSolutions.filter(s =>
      s.title.toLowerCase().includes(searchQuery.toLowerCase()) ||
      s.excerpt.toLowerCase().includes(searchQuery.toLowerCase()) ||
      s.tags.some(tag => tag.toLowerCase().includes(searchQuery.toLowerCase()))
    )
  : categoryFilteredSolutions;

// Category counts (using translated solutions for English display)
const categoryCounts = {
  virtual_card: translatedSolutions.filter(s => s.category === 'virtual_card').length,
  gift_card: translatedSolutions.filter(s => s.category === 'gift_card').length,
  regional_pricing: translatedSolutions.filter(s => s.category === 'regional_pricing').length,
  troubleshooting: translatedSolutions.filter(s => s.category === 'troubleshooting').length,
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": ["CollectionPage", "FAQPage"],
  "name": "AI Tools Payment Solutions for International Students",
  "description": "One-stop solution for international students to pay for AI tools, including virtual cards, gift cards, regional pricing and more",
  "url": "https://www.mi-to-ai.com/en/payment",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How can international students pay for ChatGPT Plus?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Common payment methods for international students include: 1) Virtual card services (e.g., Depay, WildCard) 2) Gift card purchase 3) Regional pricing subscriptions (e.g., Turkey region) 4) Third-party platform purchase."
      }
    },
    {
      "@type": "Question",
      "name": "What are virtual cards? Can international students use them?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Virtual cards are prepaid cards without physical form that can be linked to various payment platforms. International students can use virtual cards to pay for most overseas AI tool services without needing a local bank card."
      }
    }
  ]
};
---

<Layout
  title={translate(locale, 'payment.title')}
  description={translate(locale, 'payment.description')}
  jsonLd={jsonLd}
  locale={locale}
>
  <!-- Header -->
  <div class="hero-gradient text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="max-w-3xl">
        <h1 class="text-4xl font-bold mb-4">{translate(locale, 'payment.title')}</h1>
        <p class="text-xl text-primary-100 mb-6">
          {translate(locale, 'payment.description')}
        </p>
        <div class="flex items-center gap-4 text-primary-200">
          <div class="flex items-center gap-2">
            <span class="text-3xl font-bold text-white">4.8</span>
            <span class="text-sm">{translate(locale, 'payment.painScore')}</span>
          </div>
          <span class="text-primary-300">|</span>
          <span>50,000+ {translate(locale, 'payment.helpedStudents')}</span>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Payment Solutions Filter Component (React) -->
    <PaymentSolutionsFilter
      client:load
      solutions={translatedSolutions}
      locale={locale}
    />

    <!-- CTA -->
    <section class="mt-12 bg-primary-50 rounded-2xl p-8 text-center">
      <h2 class="text-2xl font-bold mb-4">{translate(locale, 'payment.stillHaveQuestions')}</h2>
      <p class="text-gray-600 mb-6">
        {translate(locale, 'payment.askCommunity')}
      </p>
      <a href="/en/questions" class="btn-primary">
        {translate(locale, 'payment.askCommunity')}
      </a>
    </section>
  </div>
</Layout>
