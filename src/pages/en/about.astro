---
export const prerender = true;

import Layout from '@/layouts/Layout.astro';
import { type Locale, t as translate } from '@/i18n';

// Force English locale
const locale: Locale = 'en';
---

<Layout
  title={translate(locale, 'nav.about')}
  description="Learn about MI TO AI Student Survival Guide's mission, features, and team. We are dedicated to helping international students use AI tools effectively."
  locale={locale}
>
  <!-- Hero Section -->
  <section class="hero-gradient text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-4xl lg:text-5xl font-bold mb-4">{translate(locale, 'about.hero.title')}</h1>
        <p class="text-xl text-primary-100 max-w-2xl mx-auto">
          {translate(locale, 'about.hero.subtitle')}
        </p>
      </div>
    </div>
  </section>

  <!-- Mission Section -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold mb-6 text-gray-900">{translate(locale, 'about.mission.title')}</h2>
          <p class="text-lg text-gray-600 mb-4">
            {translate(locale, 'about.mission.desc1')}
          </p>
          <p class="text-lg text-gray-600 mb-4">
            {translate(locale, 'about.mission.desc2')}
          </p>
          <p class="text-lg text-gray-600">
            {translate(locale, 'about.mission.desc3')}
          </p>
        </div>
        <div class="bg-gradient-to-br from-primary-50 to-primary-100 rounded-2xl p-8">
          <div class="grid grid-cols-2 gap-6">
            <div class="text-center">
              <div class="text-4xl font-bold text-primary-600">500+</div>
              <div class="text-gray-600 mt-2">AI Tools</div>
            </div>
            <div class="text-center">
              <div class="text-4xl font-bold text-primary-600">20+</div>
              <div class="text-gray-600 mt-2">Payment Solutions</div>
            </div>
            <div class="text-center">
              <div class="text-4xl font-bold text-primary-600">200+</div>
              <div class="text-gray-600 mt-2">University Policies</div>
            </div>
            <div class="text-center">
              <div class="text-4xl font-bold text-primary-600">1000+</div>
              <div class="text-gray-600 mt-2">Prompt Templates</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-center mb-12">{translate(locale, 'about.features.title')}</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="bg-white rounded-xl p-6 shadow-sm">
          <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-2">{translate(locale, 'about.features.tools.title')}</h3>
          <p class="text-gray-600">{translate(locale, 'about.features.tools.desc')}</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm">
          <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-2">{translate(locale, 'about.features.payment.title')}</h3>
          <p class="text-gray-600">{translate(locale, 'about.features.payment.desc')}</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm">
          <div class="w-12 h-12 bg-orange-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-2">{translate(locale, 'about.features.policies.title')}</h3>
          <p class="text-gray-600">{translate(locale, 'about.features.policies.desc')}</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm">
          <div class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-2">{translate(locale, 'about.features.prompts.title')}</h3>
          <p class="text-gray-600">{translate(locale, 'about.features.prompts.desc')}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Team Section -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-center mb-12">{translate(locale, 'about.team.title')}</h2>
      <div class="max-w-3xl mx-auto text-center">
        <p class="text-lg text-gray-600 mb-8">
          {translate(locale, 'about.team.desc')}
        </p>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="text-center">
            <div class="w-24 h-24 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-12 h-12 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>
            <h3 class="text-xl font-semibold">{translate(locale, 'about.team.developer.title')}</h3>
            <p class="text-gray-600">{translate(locale, 'about.team.developer.desc')}</p>
          </div>
          <div class="text-center">
            <div class="w-24 h-24 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-12 h-12 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </div>
            <h3 class="text-xl font-semibold">{translate(locale, 'about.team.content.title')}</h3>
            <p class="text-gray-600">{translate(locale, 'about.team.content.desc')}</p>
          </div>
          <div class="text-center">
            <div class="w-24 h-24 bg-orange-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-12 h-12 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-semibold">{translate(locale, 'about.team.community.title')}</h3>
            <p class="text-gray-600">{translate(locale, 'about.team.community.desc')}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- User Guide Section (anchor: guide) -->
  <section id="guide" class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-center mb-12">{translate(locale, 'about.guide.title')}</h2>

        <div class="space-y-8">
          <!-- Getting Started -->
          <div class="bg-white rounded-xl p-6 shadow-sm">
            <h3 class="text-xl font-semibold mb-4 flex items-center">
              <span class="w-8 h-8 bg-primary-100 rounded-full flex items-center justify-center mr-3 text-primary-600 font-bold">1</span>
              {translate(locale, 'about.guide.started.title')}
            </h3>
            <p class="text-gray-600 mb-4">{translate(locale, 'about.guide.started.desc')}</p>
            <ul class="list-disc list-inside text-gray-600 space-y-2">
              <li>{translate(locale, 'about.guide.started.step1')}</li>
              <li>{translate(locale, 'about.guide.started.step2')}</li>
              <li>{translate(locale, 'about.guide.started.step3')}</li>
            </ul>
          </div>

          <!-- Using Tools -->
          <div class="bg-white rounded-xl p-6 shadow-sm">
            <h3 class="text-xl font-semibold mb-4 flex items-center">
              <span class="w-8 h-8 bg-primary-100 rounded-full flex items-center justify-center mr-3 text-primary-600 font-bold">2</span>
              {translate(locale, 'about.guide.tools.title')}
            </h3>
            <p class="text-gray-600 mb-4">{translate(locale, 'about.guide.tools.desc')}</p>
            <ul class="list-disc list-inside text-gray-600 space-y-2">
              <li>{translate(locale, 'about.guide.tools.step1')}</li>
              <li>{translate(locale, 'about.guide.tools.step2')}</li>
              <li>{translate(locale, 'about.guide.tools.step3')}</li>
            </ul>
          </div>

          <!-- Payment Solutions -->
          <div class="bg-white rounded-xl p-6 shadow-sm">
            <h3 class="text-xl font-semibold mb-4 flex items-center">
              <span class="w-8 h-8 bg-primary-100 rounded-full flex items-center justify-center mr-3 text-primary-600 font-bold">3</span>
              {translate(locale, 'about.guide.payment.title')}
            </h3>
            <p class="text-gray-600 mb-4">{translate(locale, 'about.guide.payment.desc')}</p>
            <ul class="list-disc list-inside text-gray-600 space-y-2">
              <li>{translate(locale, 'about.guide.payment.step1')}</li>
              <li>{translate(locale, 'about.guide.payment.step2')}</li>
              <li>{translate(locale, 'about.guide.payment.step3')}</li>
            </ul>
          </div>

          <!-- Community -->
          <div class="bg-white rounded-xl p-6 shadow-sm">
            <h3 class="text-xl font-semibold mb-4 flex items-center">
              <span class="w-8 h-8 bg-primary-100 rounded-full flex items-center justify-center mr-3 text-primary-600 font-bold">4</span>
              {translate(locale, 'about.guide.community.title')}
            </h3>
            <p class="text-gray-600 mb-4">{translate(locale, 'about.guide.community.desc')}</p>
            <div class="flex flex-wrap gap-4 mt-4">
              <a href="/en/questions" class="px-4 py-2 bg-primary-100 text-primary-700 rounded-lg hover:bg-primary-200 transition-colors">
                {translate(locale, 'nav.questions')}
              </a>
              <a href="/en/offers" class="px-4 py-2 bg-green-100 text-green-700 rounded-lg hover:bg-green-200 transition-colors">
                {translate(locale, 'nav.offers')}
              </a>
              <a href="/en/survival" class="px-4 py-2 bg-orange-100 text-orange-700 rounded-lg hover:bg-orange-200 transition-colors">
                {translate(locale, 'nav.survival')}
              </a>
            </div>
          </div>
        </div>

        <!-- Quick Start CTA -->
        <div class="mt-12 text-center">
          <a href="/en/map" class="inline-flex items-center px-6 py-3 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors">
            {translate(locale, 'about.guide.cta')}
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact CTA Section -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold mb-4">{translate(locale, 'about.cta.title')}</h2>
      <p class="text-lg text-gray-600 mb-8">{translate(locale, 'about.cta.desc')}</p>
      <a href="/en/contact" class="inline-flex items-center px-6 py-3 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors">
        {translate(locale, 'nav.contact')}
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
      </a>
    </div>
  </section>
</Layout>