---
import Layout from '@/layouts/Layout.astro';
import QuestionDetailClient from '@/components/questions/QuestionDetailClient';

export const prerender = false;

const { id } = Astro.params;
const locale = 'en';

if (!id) {
  return Astro.redirect('/en/questions');
}
---

<Layout title="Question Details" locale={locale} breadcrumbs={[
    { name: 'Home', href: '/en/' },
    { name: 'Q&A Community', href: '/en/questions' },
    { name: 'Question Details' }
  ]}
>
  <QuestionDetailClient questionId={id} locale={locale} client:load />
</Layout>
