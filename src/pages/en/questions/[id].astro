---
import Layout from '@/layouts/Layout.astro';
import QuestionPostDetail from '@/components/questions/QuestionPostDetail';

export const prerender = false;

const { id } = Astro.params;
const locale = 'en';

if (!id) {
  return Astro.redirect('/en/questions');
}
---

<Layout
  title="Question Details"
  breadcrumbs={[
    { name: 'Home', href: '/en/' },
    { name: 'Q&A Community', href: '/en/questions' },
    { name: 'Question Details' }
  ]}
>
  <QuestionPostDetail postId={id} locale={locale} client:load />
</Layout>
