---
import Layout from '@/layouts/Layout.astro';
import RegisterForm from '@/components/auth/RegisterForm';

export const prerender = false;

const titles = {
  zh: { title: '注册', h1: '创建账户', subtitle: '加入MI TO AI留学生存指南', back: '返回首页' },
  en: { title: 'Register', h1: 'Create Account', subtitle: 'Join MI TO AI Student Survival Guide', back: 'Back to Home' },
};

const locale = 'en';
const t = titles[locale];
---

<Layout title={t.title} description="Create an account for MI TO AI Student Survival Guide" locale={locale}>
  <div class="min-h-[calc(100vh-200px)] flex items-center justify-center py-12 px-4">
    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <h1 class="text-3xl font-bold text-gray-900">
          {t.h1}
        </h1>
        <p class="mt-2 text-gray-600">
          {t.subtitle}
        </p>
      </div>

      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <RegisterForm
          locale={locale}
          client:load
        />
      </div>

      <div class="mt-6 text-center">
        <a href="/" class="text-sm text-gray-600 hover:text-primary-600 transition-colors">
          ← {t.back}
        </a>
      </div>
    </div>
  </div>
</Layout>
