---
import Layout from '@/layouts/Layout.astro';

export const prerender = false;

const locale = 'en';

const t = {
  title: 'Reset Password',
  h1: 'Set New Password',
  subtitle: 'Please enter your new password',
  newPassword: 'New Password',
  confirmPassword: 'Confirm Password',
  submit: 'Confirm',
  success: 'Password changed successfully! Redirecting...',
  error: 'Failed to reset password',
  back: 'Back to Login',
  mismatch: 'Passwords do not match',
  tooShort: 'Password must be at least 6 characters',
};
---

<Layout title={t.title} description={t.subtitle} locale={locale}>
  <div class="min-h-[calc(100vh-200px)] flex items-center justify-center py-12 px-4">
    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <h1 class="text-3xl font-bold text-gray-900">
          {t.h1}
        </h1>
        <p class="mt-2 text-gray-600">
          {t.subtitle}
        </p>
      </div>

      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <div id="reset-password-form">
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">{t.newPassword}</label>
              <input
                type="password"
                id="new-password"
                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500"
                placeholder="••••••••"
                minlength="6"
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">{t.confirmPassword}</label>
              <input
                type="password"
                id="confirm-password"
                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500"
                placeholder="••••••••"
                minlength="6"
              />
            </div>
            <button
              id="reset-btn"
              type="button"
              class="w-full bg-primary-600 text-white py-2.5 px-4 rounded-lg hover:bg-primary-700 transition-colors font-medium disabled:opacity-50 disabled:cursor-not-allowed"
            >
              {t.submit}
            </button>
          </div>
          <div id="success-msg" class="hidden mt-4 p-4 bg-green-50 border border-green-200 rounded-lg text-green-700 text-sm text-center">
            {t.success}
          </div>
          <div id="error-msg" class="hidden mt-4 p-3 bg-red-50 border border-red-200 rounded-lg text-red-600 text-sm">
          </div>
        </div>
      </div>

      <div class="mt-6 text-center">
        <a href="/en/auth/login" class="text-sm text-gray-600 hover:text-primary-600 transition-colors">
          ← {t.back}
        </a>
      </div>
    </div>
  </div>
</Layout>

<script>
  const btn = document.getElementById('reset-btn') as HTMLButtonElement;
  const successDiv = document.getElementById('success-msg') as HTMLDivElement;
  const errorDiv = document.getElementById('error-msg') as HTMLDivElement;
  const newPwdInput = document.getElementById('new-password') as HTMLInputElement;
  const confirmPwdInput = document.getElementById('confirm-password') as HTMLInputElement;

  function showError(msg: string) {
    if (errorDiv) {
      errorDiv.textContent = msg;
      errorDiv.classList.remove('hidden');
    }
  }

  function showSuccess() {
    if (successDiv) successDiv.classList.remove('hidden');
  }

  btn?.addEventListener('click', async () => {
    const newPwd = newPwdInput?.value || '';
    const confirmPwd = confirmPwdInput?.value || '';

    if (errorDiv) errorDiv.classList.add('hidden');
    if (successDiv) successDiv.classList.add('hidden');

    if (newPwd.length < 6) {
      showError('Password must be at least 6 characters');
      return;
    }
    if (newPwd !== confirmPwd) {
      showError('Passwords do not match');
      return;
    }

    if (btn) btn.disabled = true;
    if (btn) btn.textContent = 'Resetting...';

    try {
      const res = await fetch('/api/auth/reset-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ newPassword: newPwd }),
      });
      const data = await res.json();

      if (res.ok && data.success) {
        showSuccess();
        setTimeout(() => {
          window.location.href = '/en/auth/login?reset_success=1';
        }, 1500);
      } else {
        showError(data.message || 'Failed to reset password');
        if (btn) btn.disabled = false;
        if (btn) btn.textContent = 'Confirm';
      }
    } catch {
      showError('Failed to reset password');
      if (btn) btn.disabled = false;
      if (btn) btn.textContent = 'Confirm';
    }
  });
</script>
