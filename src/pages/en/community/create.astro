---
import { CreatePostPage } from '@/components/community/CreatePostPage';
import Layout from '@/layouts/Layout.astro';
import { getCurrentUser } from '@/lib/auth';

const user = getCurrentUser();

if (!user) {
  return Astro.redirect('/auth/login?redirect=/en/community/create');
}
---

<Layout title="Create Post - AI Student Survival Guide">
  <div class="min-h-screen bg-gray-50 py-8">
    <div class="max-w-3xl mx-auto px-4">
      <div class="mb-6">
        <a href="/en/community" class="text-blue-600 hover:text-blue-700 flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Back to Community
        </a>
      </div>

      <CreatePostPage client:load userId={user.id} locale="en" />
    </div>
  </div>
</Layout>
