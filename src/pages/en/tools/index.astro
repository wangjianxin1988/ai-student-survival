// Get query params
const category = '';
const pricing = '';
const search = '';
const sortBy = 'rating';

// Use static data (same as zh/tools)
let allTools: Tool[] = staticTools;

const categories = [
  { value: '', key: 'tools.categories.all', label: 'All Categories' },
  { value: 'agent', key: 'tools.categories.agent', label: 'Agent' },
  { value: 'writing', key: 'tools.categories.writing', label: 'Writing' },
  { value: 'coding', key: 'tools.categories.coding', label: 'Coding' },
  { value: 'design', key: 'tools.categories.design', label: 'Design' },
  { value: 'research', key: 'tools.categories.research', label: 'Research' },
  { value: 'communication', key: 'tools.categories.communication', label: 'Communication' },
];

const pricingOptions = [
  { value: '', key: 'tools.pricing.all', label: 'All Prices' },
  { value: 'free', key: 'tools.pricing.free', label: 'Free' },
  { value: 'freemium', key: 'tools.pricing.freemium', label: 'Freemium' },
  { value: 'paid', key: 'tools.pricing.paid', label: 'Paid' },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "AI Tools for Students",
  "description": "Curated AI tools for international students",
  "numberOfItems": allTools.length,
  "itemListElement": allTools.map((tool, index) => ({
    "@type": "SoftwareApplication",
    "position": index + 1,
    "name": tool.name,
    "description": tool.description,
    "applicationCategory": "BusinessApplication",
    "offers": { "@type": "Offer", "price": tool.priceDetail.monthly?.toString() || "0", "priceCurrency": tool.priceDetail.currency },
    "aggregateRating": { "@type": "AggregateRating", "ratingValue": tool.rating.toString(), "reviewCount": tool.ratingCount.toString() }
  }))
};
const faqItems = [
  {
    question: "Which AI tools are free for international students?",
    answer: "Most AI tools offer free versions, including ChatGPT (GPT-3.5), Claude (free tier), Gemini, Kimi, Qwen, and more. Paid versions typically offer stronger model capabilities, higher limits, and advanced features."
  },
  {
    question: "What's the difference between ChatGPT Plus and the free version?",
    answer: "ChatGPT Plus uses GPT-4 model, supports more complex reasoning tasks, has higher usage limits, and can access DALL-E image generation and plugins. The free version uses GPT-3.5 with relatively basic features."
  },
  {
    question: "How can international students access AI tools from China?",
    answer: "Options for accessing AI tools from China include: 1) Using local alternatives like Kimi, Qwen, or Wenxin Yige 2) Using school-provided academic ChatGPT/Claude accounts 3) Accessing international versions via VPN."
  },
  {
    question: "Does GitHub Copilot offer student discounts?",
    answer: "Yes, GitHub Education offers free education verification. Verified students and teachers can use GitHub Copilot for free. Apply through the GitHub Education page to claim your academic benefit."
  },
  {
    question: "What should international students know about AI tool privacy policies?",
    answer: "When using AI tools: 1) Avoid entering personal private information or unpublished academic work 2) Sensitive data may be used for model training 3) For commercial use, review the specific tool's privacy terms 4) For academic use, follow your school's AI policy guidelines."
  }
];

---

<Layout
  title={translate(locale, 'tools.title')}
  description={translate(locale, 'tools.description')}
  jsonLd={jsonLd}
  faqItems={faqItems}
  locale={locale}
>
  <!-- Header -->
  <div class="bg-white border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <h1 class="text-3xl font-bold mb-2">{translate(locale, 'tools.title')}</h1>
      <p class="text-gray-600">{allTools.length} {translate(locale, 'common.results')}</p>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex flex-col lg:flex-row gap-8">
      <!-- Sidebar Filters -->
      <aside class="w-full lg:w-64 flex-shrink-0">
        <div class="bg-white rounded-xl border border-gray-200 p-4 sticky top-24">
          <h3 class="font-semibold mb-4">{translate(locale, 'common.filters')}</h3>

          <!-- Category Filter -->
          <div class="mb-6">
            <label class="block text-sm font-medium text-gray-700 mb-2">Category</label>
            <div class="space-y-2">
              {categories.map(cat => (
                <a
                  href={`/en/tools?category=${cat.value}`}
                  class={`block px-3 py-2 rounded-lg text-sm transition-colors ${
                    category === cat.value
                      ? 'bg-primary-100 text-primary-700 font-medium'
                      : 'bg-gray-100 text-gray-700 hover:bg-gray-200'
                  }`}
                >
                  {cat.label}
                </a>
              ))}
            </div>
          </div>

          <!-- Pricing Filter -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Price</label>
            <div class="space-y-2">
              {pricingOptions.map(opt => (
                <a
                  href={`/en/tools?pricing=${opt.value}`}
                  class={`block px-3 py-2 rounded-lg text-sm transition-colors ${
                    pricing === opt.value
                      ? 'bg-primary-100 text-primary-700 font-medium'
                      : 'bg-gray-100 text-gray-700 hover:bg-gray-200'
                  }`}
                >
                  {opt.label}
                </a>
              ))}
            </div>
          </div>
        </div>
      </aside>

      <!-- Tool Grid -->
      <main class="flex-1">
        <div class="flex items-center justify-between mb-6">
          <p class="text-gray-600">{translate(locale, 'tools.showResults', { count: allTools.length })}</p>
          <div class="flex items-center gap-4">
            <!-- Sort Dropdown -->
            <div class="flex items-center gap-2 flex-nowrap">
              <label class="text-sm text-gray-500 whitespace-nowrap">Sort:</label>
              <select class="input py-1.5 text-sm" id="sortSelect" onchange="window.location.href=this.value">
                <option value="/en/tools?sort=rating" selected>Rating</option>
                <option value="/en/tools?sort=name">Name A-Z</option>
              </select>
            </div>
            <a href="/en/compare" class="text-sm text-primary-600 hover:text-primary-700 font-medium">{translate(locale, 'tools.compareTools')}</a>
          </div>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {allTools.map(tool => (
            <article class="tool-card group">
              <div class="tool-card-image">
                <img src={tool.imageUrl} alt={tool.name} class="w-full h-full object-cover" loading="lazy" />
              </div>
              <div class="tool-card-body">
                <div class="flex items-start justify-between mb-2">
                  <h3 class="text-lg font-semibold group-hover:text-primary-600 transition-colors">
                    <a href={`/en/tools/${tool.slug}`}>{tool.name}</a>
                  </h3>
                  {tool.isNew && <span class="badge bg-red-100 text-red-700">New</span>}
                </div>
                <p class="text-gray-600 text-sm mb-4 line-clamp-2">{tool.description}</p>

                <div class="flex flex-wrap gap-1 mb-4">
                  {tool.tags.slice(0, 3).map(tag => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>

                <div class="mt-auto">
                  <div class="flex items-center gap-2 mb-3">
                    <div class="rating">
                      {[1, 2, 3, 4, 5].map(star => (
                        <svg class={`rating-star ${star <= Math.round(tool.rating) ? 'text-yellow-400' : 'text-gray-300'}`} viewBox="0 0 20 20" fill="currentColor">
                          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                        </svg>
                      ))}
                    </div>
                    <span class="text-sm font-medium">{tool.rating}</span>
                    <span class="text-xs text-gray-500">({tool.ratingCount})</span>
                  </div>

                  <div class="flex items-center justify-between">
                    <span class={`badge ${tool.pricing === 'free' ? 'badge-free' : tool.pricing === 'paid' ? 'badge-paid' : 'badge-freemium'}`}>
                      {tool.pricing === 'free' ? translate(locale, 'tools.free') : tool.pricing === 'paid' ? `$${tool.priceDetail.monthly}/mo` : translate(locale, 'tools.freePlus')}
                    </span>
                    <a href={`/en/tools/${tool.slug}`} class="text-sm text-primary-600 hover:text-primary-700 font-medium">{translate(locale, 'common.viewDetails')}</a>
                  </div>
                </div>
              </div>
            </article>
          ))}
        </div>
      </main>
    </div>
  </div>
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
