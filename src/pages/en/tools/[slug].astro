const tool = toolsData[slug as string];

if (!tool) {
  return Astro.redirect('/en/tools');
}

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": ["Product", "SoftwareApplication"],
    "name": tool.name,
    "description": tool.description,
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "url": tool.url,
    "image": tool.imageUrl,
    "brand": {
      "@type": "Brand",
      "name": tool.name
    },
    "offers": {
      "@type": "Offer",
      "price": tool.priceDetail.monthly?.toString() || "0",
      "priceCurrency": tool.priceDetail.currency,
      "availability": "https://schema.org/InStock",
      "priceType": "starting from"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": tool.rating.toString(),
      "reviewCount": tool.ratingCount.toString(),
      "ratingExplanation": `${tool.rating} out of 5 stars based on ${tool.ratingCount} reviews`
    },
    "featureList": tool.features.join(', '),
    "keywords": tool.tags.join(', '),
    "category": tool.category,
    "additionalProperty": [
      {
        "@type": "PropertyValue",
        "name": "easeOfUse",
        "value": tool.dimensions.easeOfUse.toString()
      },
      {
        "@type": "PropertyValue",
        "name": "features",
        "value": tool.dimensions.features.toString()
      },
      {
        "@type": "PropertyValue",
        "name": "value",
        "value": tool.dimensions.value.toString()
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": `${tool.name} In-Depth Review`,
    "description": tool.description,
    "author": {
      "@type": "Organization",
      "name": "MI TO AI"
    },
    "datePublished": tool.createdAt || "2026-05-01",
    "dateModified": tool.updatedAt || new Date().toISOString().split('T')[0],
    "publisher": {
      "@type": "Organization",
      "name": "MI TO AI Student Survival Guide",
      "url": "https://mi-to-ai.com"
    },
    "about": {
      "@type": "Product",
      "name": tool.name,
      "description": tool.description
    },
    "image": tool.imageUrl
  }
];
---

<Layout
  title={tool.name}
  description={tool.description}
  image={tool.imageUrl}
  type="article"
  jsonLd={jsonLd}
  breadcrumbs={[
    { name: 'Home', href: '/en/' },
    { name: 'AI Tools', href: '/en/tools' },
    { name: tool.name }
  ]}
>
  <!-- Breadcrumb -->
  <div class="bg-white border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <nav class="flex items-center gap-2 text-sm">
        <a href="/en" class="text-gray-500 hover:text-gray-900">Home</a>
        <span class="text-gray-400">/</span>
        <a href="/en/tools" class="text-gray-500 hover:text-gray-900">AI Tools</a>
        <span class="text-gray-400">/</span>
        <span class="text-gray-900 font-medium">{tool.name}</span>
      </nav>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="grid lg:grid-cols-3 gap-8">
      <!-- Main Content -->
      <div class="lg:col-span-2">
        <!-- Hero Image -->
        <div class="rounded-xl overflow-hidden mb-8">
          <img src={tool.imageUrl} alt={tool.name} class="w-full h-auto" />
        </div>

        <!-- Title Section -->
        <div class="mb-8">
          <div class="flex items-center justify-between mb-3">
            <div class="flex items-center gap-3">
              <h1 class="text-3xl font-bold">{tool.name}</h1>
              {tool.isNew && <span class="badge bg-red-100 text-red-700">New</span>}
            </div>
            <FavoriteButton client:load targetType="tool" targetId={tool.slug} locale="en" />
            <ShareButton client:load title={tool.name} description={tool.description} />
            <button
              id="copy-link-btn"
              aria-label="Copy link"
              onclick="navigator.clipboard.writeText(window.location.href).then(() => { const btn = document.getElementById('copy-link-btn'); if(btn) { btn.textContent = 'Copied!'; setTimeout(() => { if(btn) btn.textContent = 'Copy Link'; }, 2000); } })"
              class="p-2 rounded-lg text-gray-400 hover:text-gray-600 bg-gray-50 hover:bg-gray-100 transition-colors"
              title="Copy Link"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
              </svg>
            </button>
          </div>
          <p class="text-lg text-gray-600">{tool.description}</p>
        </div>

        <!-- Features -->
        <section class="mb-8">
          <h2 class="text-xl font-semibold mb-4">Key Features</h2>
          <div class="grid sm:grid-cols-2 gap-3">
            {tool.features.map(feature => (
              <div class="flex items-center gap-2 p-3 bg-gray-50 rounded-lg">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-sm">{feature}</span>
              </div>
            ))}
          </div>
        </section>

        <!-- Rating Details -->
        <section class="mb-8">
          <h2 class="text-xl font-semibold mb-4">Rating Details</h2>
          <div class="bg-white rounded-xl border border-gray-200 p-6">
            <div class="flex items-center gap-4 mb-6">
              <div class="text-5xl font-bold text-primary-600">{tool.rating}</div>
              <div>
                <div class="rating mb-2">
                  <StarRating client:load targetType="tool" targetId={tool.slug} size="lg" />
                </div>
                <p class="text-sm text-gray-500">{tool.ratingCount} reviews</p>
              </div>
            </div>

            <div class="space-y-3">
              <div class="flex items-center justify-between">
                <span class="text-sm font-medium">Ease of Use</span>
                <div class="flex items-center gap-2">
                  <div class="w-32 h-2 bg-gray-200 rounded-full overflow-hidden">
                    <div class="h-full bg-primary-500 rounded-full" style={`width: ${tool.dimensions.easeOfUse * 20}%`}></div>
                  </div>
                  <span class="text-sm font-medium w-8">{tool.dimensions.easeOfUse}</span>
                </div>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-sm font-medium">Features</span>
                <div class="flex items-center gap-2">
                  <div class="w-32 h-2 bg-gray-200 rounded-full overflow-hidden">
                    <div class="h-full bg-secondary-500 rounded-full" style={`width: ${tool.dimensions.features * 20}%`}></div>
                  </div>
                  <span class="text-sm font-medium w-8">{tool.dimensions.features}</span>
                </div>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-sm font-medium">Value</span>
                <div class="flex items-center gap-2">
                  <div class="w-32 h-2 bg-gray-200 rounded-full overflow-hidden">
                    <div class="h-full bg-green-500 rounded-full" style={`width: ${tool.dimensions.value * 20}%`}></div>
                  </div>
                  <span class="text-sm font-medium w-8">{tool.dimensions.value}</span>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- Alternatives -->
        {(() => {
          // Build a slug -> name lookup from all defined tools
          const altNames = {};
          Object.values(toolsData).forEach((t) => { altNames[t.slug] = t.name; });
          // Only show alternatives that exist in our data
          const validAlts = tool.alternatives.filter(a => altNames[a]);
          if (validAlts.length === 0) return null;
          return (
            <section>
              <h2 class="text-xl font-semibold mb-4">Alternative Tools</h2>
              <div class="flex flex-wrap gap-2">
                {validAlts.map(alt => (
                  <a href={`/en/tools/${alt}`} class="btn-outline text-sm">
                    {altNames[alt]}
                  </a>
                ))}
              </div>
            </section>
          );
        })()}

        {/* Comments Section */}
        <section class="mt-12">
          <CommentSection client:load targetType="tool" targetId={tool.slug} locale="en" showRating={true} />
        </section>

        <!-- Capability Expansion -->
        <section class="mt-8">
          <h2 class="text-xl font-semibold mb-4">Capability Expansion</h2>
          <div class="bg-gradient-to-r from-primary-50 to-blue-50 rounded-xl border border-primary-100 p-6">
            <div class="grid sm:grid-cols-2 gap-4">
              {tool.features.slice(0, 4).map((feature, idx) => (
                <div class="flex items-start gap-3">
                  <div class="w-8 h-8 rounded-full bg-primary-100 text-primary-600 flex items-center justify-center flex-shrink-0">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                    </svg>
                  </div>
                  <div>
                    <h4 class="font-medium text-gray-900">{feature}</h4>
                    <p class="text-sm text-gray-600 mt-1">
                      {idx === 0 ? 'Click to learn detailed application scenarios for this capability' :
                       idx === 1 ? 'See how this capability performs in real usage' :
                       idx === 2 ? 'Explore how this capability improves work efficiency' :
                       'Learn about the latest updates and optimizations for this capability'}
                    </p>
                  </div>
                </div>
              ))}
            </div>
            <div class="mt-4 pt-4 border-t border-primary-100">
              <p class="text-sm text-gray-600">
                <span class="font-medium text-primary-700">Tip:</span>
                Most AI tools support API access, allowing you to integrate them into third-party applications or automated workflows.
                {tool.pricing === 'free' || tool.pricing === 'freemium' ? 'This tool offers a free version, try it out before deciding whether to upgrade.' : 'Paid versions usually offer higher usage limits and more advanced features.'}
              </p>
            </div>
          </div>
        </section>

        <!-- Update Notes -->
        <section class="mt-8">
          <h2 class="text-xl font-semibold mb-4">Update Notes</h2>
          <div class="bg-white rounded-xl border border-gray-200 p-6">
            <div class="flex items-center gap-4 mb-4">
              <div class="w-12 h-12 rounded-lg bg-green-100 text-green-600 flex items-center justify-center">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
              </div>
              <div>
                <p class="font-medium text-gray-900">Latest Update</p>
                <p class="text-sm text-gray-500">Last updated: {new Date(tool.updatedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
              </div>
            </div>
            <div class="space-y-3">
              <div class="flex items-start gap-3">
                <div class="w-2 h-2 rounded-full bg-green-500 mt-2 flex-shrink-0"></div>
                <p class="text-sm text-gray-700">Tool ratings and review data are regularly updated based on user feedback</p>
              </div>
              <div class="flex items-start gap-3">
                <div class="w-2 h-2 rounded-full bg-blue-500 mt-2 flex-shrink-0"></div>
                <p class="text-sm text-gray-700">Feature lists and pricing information may change due to official updates; refer to the official website for accuracy</p>
              </div>
              <div class="flex items-start gap-3">
                <div class="w-2 h-2 rounded-full bg-purple-500 mt-2 flex-shrink-0"></div>
                <p class="text-sm text-gray-700">If you find any inaccurate information, feel free to provide feedback through the comment section</p>
              </div>
            </div>
          </div>
        </section>

        <!-- How to Get Started -->
        <section class="mt-8">
          <h2 class="text-xl font-semibold mb-4">How to Get Started with {tool.name}</h2>
          <div class="bg-white rounded-xl border border-gray-200 p-6">
            <div class="space-y-4">
              <div class="flex gap-4">
                <div class="w-8 h-8 rounded-full bg-primary-100 text-primary-600 flex items-center justify-center font-semibold flex-shrink-0">1</div>
                <div>
                  <h4 class="font-medium text-gray-900 mb-1">Create an Account</h4>
                  <p class="text-sm text-gray-600">Visit the {tool.name} official website and click the register button to create an account. Use email or Google/Apple account for quick registration.</p>
                </div>
              </div>
              <div class="flex gap-4">
                <div class="w-8 h-8 rounded-full bg-primary-100 text-primary-600 flex items-center justify-center font-semibold flex-shrink-0">2</div>
                <div>
                  <h4 class="font-medium text-gray-900 mb-1">Choose a Suitable Plan</h4>
                  <p class="text-sm text-gray-600">Based on your usage needs, choose the free or paid version. {tool.pricing === 'free' ? 'This tool is completely free to use.' : tool.pricing === 'freemium' ? 'The free version already has basic features; paid versions unlock more advanced features.' : 'The paid version provides complete features.'}</p>
                </div>
              </div>
              <div class="flex gap-4">
                <div class="w-8 h-8 rounded-full bg-primary-100 text-primary-600 flex items-center justify-center font-semibold flex-shrink-0">3</div>
                <div>
                  <h4 class="font-medium text-gray-900 mb-1">Start Using</h4>
                  <p class="text-sm text-gray-600">Log in to start using {tool.name}. {tool.features[0] ? `Recommended to start with the ${tool.features[0]} feature.` : 'Explore various features to find the usage style that suits you best.'}</p>
                </div>
              </div>
            </div>
            <div class="mt-6 pt-6 border-t border-gray-200">
              <a href={tool.url} target="_blank" rel="noopener noreferrer" class="btn-primary inline-flex items-center gap-2">
                <span>Get Started Now</span>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            </div>
          </div>
        </section>

        <!-- Use Cases -->
        <section class="mt-8">
          <h2 class="text-xl font-semibold mb-4">Use Cases</h2>
          <div class="grid sm:grid-cols-2 gap-4">
            {tool.features.slice(0, 4).map((feature, idx) => (
              <div class="bg-gradient-to-br from-gray-50 to-gray-100 rounded-xl p-5 border border-gray-200 hover:border-primary-300 transition-colors">
                <div class="w-10 h-10 rounded-lg bg-primary-100 text-primary-600 flex items-center justify-center mb-3">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
                  </svg>
                </div>
                <h4 class="font-medium text-gray-900 mb-2">{feature}</h4>
                <p class="text-sm text-gray-600">
                  {idx === 0 ? 'Suitable for daily tasks and beginner usage scenarios' :
                   idx === 1 ? 'Supports professional-level applications and complex tasks' :
                   idx === 2 ? 'A powerful tool to improve work and study efficiency' :
                   'Explore more possibilities with AI'}
                </p>
              </div>
            ))}
          </div>
        </section>

        <!-- Tips & Best Practices -->
        <section class="mt-8">
          <h2 class="text-xl font-semibold mb-4">Tips & Best Practices</h2>
          <div class="bg-gradient-to-r from-amber-50 to-orange-50 rounded-xl border border-amber-100 p-6">
            <ul class="space-y-3">
              <li class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full bg-amber-200 text-amber-700 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                </div>
                <p class="text-sm text-gray-700">Using specific and clear prompts可以获得更准确的回答</p>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full bg-amber-200 text-amber-700 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                </div>
                <p class="text-sm text-gray-700">Make full use of context dialogue capability - continue asking questions in the same session</p>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full bg-amber-200 text-amber-700 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                </div>
                <p class="text-sm text-gray-700">{tool.category === 'coding' ? 'Providing code context and specific error messages makes it easier to get effective help' : 'Try different expressions to find the interaction style that works best for you'}</p>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full bg-amber-200 text-amber-700 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                </div>
                <p class="text-sm text-gray-700">{tool.pricing !== 'free' ? 'Make full use of the free quota before deciding whether to upgrade' : 'Although this is a free tool, there are still usage limits - keep an eye on your usage'}</p>
              </li>
            </ul>
          </div>
        </section>

        <!-- Related Tools (More Comprehensive) -->
        {(() => {
          // Get tools in same category
          const sameCategoryTools = Object.values(toolsData).filter(t => t.category === tool.category && t.slug !== tool.slug).slice(0, 4);
          const hasRelated = sameCategoryTools.length > 0;
          if (!hasRelated) return null;
          return (
            <section class="mt-8">
              <h2 class="text-xl font-semibold mb-4">Related Tools</h2>
              <div class="grid sm:grid-cols-2 gap-4">
                {sameCategoryTools.map(t => (
                  <a href={`/en/tools/${t.slug}`} class="block bg-white rounded-xl border border-gray-200 p-4 hover:border-primary-300 hover:shadow-md transition-all group">
                    <div class="flex items-center gap-3">
                      <img src={t.imageUrl} alt={t.name} class="w-12 h-12 rounded-lg object-cover" loading="lazy" />
                      <div class="flex-1 min-w-0">
                        <h4 class="font-medium text-gray-900 group-hover:text-primary-600 transition-colors truncate">{t.name}</h4>
                        <p class="text-sm text-gray-500 truncate">{t.description.slice(0, 40)}...</p>
                      </div>
                      <div class="flex items-center gap-1">
                        <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                        </svg>
                        <span class="text-sm font-medium">{t.rating}</span>
                      </div>
                    </div>
                  </a>
                ))}
              </div>
            </section>
          );
        })()}
      </div>

      <!-- Sidebar -->
      <aside class="lg:col-span-1">
        <div class="sticky top-24 space-y-6">
          <!-- CTA Card -->
          <div class="bg-white rounded-xl border border-gray-200 p-6">
            <div class="text-center mb-6">
              <span class={`badge text-lg px-4 py-1 ${
                tool.pricing === 'free' ? 'badge-free' :
                tool.pricing === 'paid' ? 'badge-paid' : 'badge-freemium'
              }`}>
                {tool.pricing === 'free' ? 'Free' :
                 tool.pricing === 'paid' ? `$${tool.priceDetail.monthly}/mo` : 'Free + Paid'}
              </span>
            </div>
            <a
              href={tool.url}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-primary w-full text-center"
            >
              Visit Website
            </a>
            <p class="text-xs text-gray-500 text-center mt-3">
              This link leads to the official website
            </p>
          </div>

          <!-- Real-time Pricing -->
          <ToolPricingRealtime
            client:load
            toolSlug={tool.slug}
            toolName={tool.name}
            officialUrl={tool.url}
            locale="en"
          />

          <!-- Compare Button -->
          <CompareButton
            client:load
            toolSlug={tool.slug}
            toolName={tool.name}
            toolImage={tool.imageUrl}
            locale="en"
          />

          <!-- Compare Link -->
          <div class="bg-primary-50 rounded-xl border border-primary-200 p-4">
            <div class="flex items-center justify-between">
              <div>
                <h3 class="font-semibold text-primary-900 mb-1">Compare Tools</h3>
                <p class="text-xs text-primary-700">Multi-dimensional comparison with other tools</p>
              </div>
              <a href="/en/compare" class="text-sm text-primary-600 hover:text-primary-700 font-medium">
                Compare →
              </a>
            </div>
          </div>

          <!-- Quick Info -->
          <div class="bg-white rounded-xl border border-gray-200 p-6">
            <h3 class="font-semibold mb-4">Basic Information</h3>
            <dl class="space-y-3 text-sm">
              <div class="flex justify-between">
                <dt class="text-gray-500">Category</dt>
                <dd class="font-medium">
                  {tool.category === 'agent' ? 'Agent' :
                   tool.category === 'writing' ? 'Writing' :
                   tool.category === 'coding' ? 'Coding' :
                   tool.category === 'design' ? 'Design' :
                   tool.category === 'research' ? 'Research' : 'Communication'}
                </dd>
              </div>
              <div class="flex justify-between">
                <dt class="text-gray-500">Tags</dt>
                <dd class="font-medium text-right max-w-[150px]">
                  {tool.tags.slice(0, 3).join(', ')}
                </dd>
              </div>
            </dl>
          </div>

          <!-- Payment Solutions -->
          <div class="bg-secondary-50 rounded-xl border border-secondary-200 p-6">
            <h3 class="font-semibold mb-3 text-secondary-900">Payment Issues?</h3>
            <p class="text-sm text-secondary-700 mb-4">
              Check out our payment solutions guide
            </p>
            <a href="/en/payment" class="btn-secondary w-full text-center text-sm">
              Payment Guide
            </a>
          </div>

          <!-- University Policy -->
          <div class="bg-green-50 rounded-xl border border-green-200 p-6">
            <h3 class="font-semibold mb-3 text-green-900">Allowed at Your University?</h3>
            <p class="text-sm text-green-700 mb-4">
              Check your school's AI policy to avoid violations
            </p>
            <a href="/en/policies" class="bg-green-600 text-white btn w-full text-center text-sm hover:bg-green-700">
              Check Policy
            </a>
          </div>
        </div>
      </aside>
    </div>
  </div>
</Layout>
