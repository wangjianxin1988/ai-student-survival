---
import Layout from '@/layouts/Layout.astro';
import SurvivalDetailClient from '@/components/survival/SurvivalDetailClient';
import { type Locale } from '@/i18n';

export const prerender = false;

// Required for dynamic route validation in hybrid mode
export function getStaticPaths() {
  return [];
}

const { id } = Astro.params;
const locale: Locale = 'en';
---

<Layout
  title="Guide Details"
  description="View survival guide details"
  breadcrumbs={[
    { name: 'Home', href: '/en/' },
    { name: 'Survival Guides', href: '/en/survival' },
    { name: 'Guide Details' }
  ]}
>
  <SurvivalDetailClient guideId={id} locale={locale} client:load />
</Layout>
