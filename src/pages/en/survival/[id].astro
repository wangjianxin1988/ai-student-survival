---
import Layout from '@/layouts/Layout.astro';
import SurvivalDetailClient from '@/components/survival/SurvivalDetailClient';
import { type Locale } from '@/i18n';

export const prerender = false;

// Required for dynamic route validation in hybrid mode
export function getStaticPaths() {
  return [];
}

const { id } = Astro.params;
const locale: Locale = 'en';
---

<Layout
  title="Guide Details"
  description="View survival guide details"
>
  <SurvivalDetailClient guideId={id} locale={locale} client:only="react" />
</Layout>
