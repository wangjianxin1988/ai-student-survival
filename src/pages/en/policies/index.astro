---
export const prerender = true;

import Layout from '@/layouts/Layout.astro';
import { type Locale, t as translate } from '@/i18n';
import { policiesData, getAllCountries, getAllRegions, type UniversityPolicy } from '@/data/policies';

// Force English locale
const locale: Locale = 'en';

// Use static data
const policies = policiesData;
const countries = getAllCountries();
const regions = getAllRegions();
const totalCount = policies.length;

function getPolicyColor(policy: string | null) {
  switch (policy) {
    case 'allowed': return 'bg-green-500';
    case 'restricted': return 'bg-yellow-500';
    case 'prohibited': return 'bg-red-500';
    default: return 'bg-blue-500';
  }
}

function getPolicyBadgeBg(policy: string | null) {
  switch (policy) {
    case 'allowed': return 'bg-green-100 text-green-800 border-green-200';
    case 'restricted': return 'bg-yellow-100 text-yellow-800 border-yellow-200';
    case 'prohibited': return 'bg-red-100 text-red-800 border-red-200';
    default: return 'bg-blue-100 text-blue-800 border-blue-200';
  }
}

const pageJsonLd = {
  "@context": "https://schema.org",
  "@type": ["CollectionPage", "FAQPage"],
  "name": "University AI Policy Database",
  "description": `Comprehensive database of AI usage policies from ${totalCount} universities worldwide`,
  "url": "https://ai-student-survival.example.com/en/policies"
};
---

<Layout
  title={translate(locale, 'policies.title')}
  description={translate(locale, 'policies.description')}
  jsonLd={pageJsonLd}
  locale={locale}
>
  <!-- Header -->
  <div class="bg-gradient-to-br from-green-600 to-teal-600 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="max-w-3xl">
        <h1 class="text-4xl font-bold mb-4">
          {translate(locale, 'policies.title')}
        </h1>
        <p class="text-xl text-green-100 mb-6">
          Find out how top universities worldwide approach AI tool usage in academics
        </p>
        <div class="flex flex-wrap items-center gap-4 text-green-200 text-sm">
          <span class="bg-white/20 px-3 py-1 rounded-full">{totalCount} Universities</span>
          <span class="bg-white/20 px-3 py-1 rounded-full">{countries.length} Countries</span>
          <span class="bg-white/20 px-3 py-1 rounded-full">{regions.length} Regions</span>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Enhanced Search & Filter -->
    <div class="bg-white rounded-xl border border-gray-200 p-4 mb-8">
      <div class="flex flex-col lg:flex-row gap-4">
        <!-- Search -->
        <div class="flex-1">
          <div class="relative">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input
              type="text"
              placeholder="Search universities..."
              class="input pl-10 w-full"
              id="searchInput"
            />
          </div>
        </div>

        <!-- Filters Row -->
        <div class="flex flex-wrap gap-3">
          <!-- Country Filter -->
          <select class="input w-auto min-w-[140px]" id="countryFilter">
            <option value="">All Countries</option>
            {countries.map(country => (
              <option value={country}>{country}</option>
            ))}
          </select>

          <!-- Region Filter -->
          <select class="input w-auto min-w-[140px]" id="regionFilter">
            <option value="">All Regions</option>
            {regions.map(region => (
              <option value={region}>{region}</option>
            ))}
          </select>

          <!-- Policy Type Filter -->
          <select class="input w-auto min-w-[140px]" id="policyFilter">
            <option value="">All Policies</option>
            <option value="allowed">Allowed</option>
            <option value="restricted">Restricted</option>
            <option value="prohibited">Prohibited</option>
            <option value="case_by_case">Case by Case</option>
          </select>
        </div>
      </div>

      <!-- Quick Filter Chips -->
      <div class="flex flex-wrap gap-2 mt-4 pt-4 border-t border-gray-100">
        <span class="text-sm text-gray-500 mr-2">Quick filters:</span>
        <button class="quick-filter px-3 py-1 text-xs rounded-full bg-gray-100 text-gray-600 hover:bg-primary-100 hover:text-primary-700 transition-colors" data-country="美国">🇺🇸 US</button>
        <button class="quick-filter px-3 py-1 text-xs rounded-full bg-gray-100 text-gray-600 hover:bg-primary-100 hover:text-primary-700 transition-colors" data-country="英国">🇬🇧 UK</button>
        <button class="quick-filter px-3 py-1 text-xs rounded-full bg-gray-100 text-gray-600 hover:bg-primary-100 hover:text-primary-700 transition-colors" data-country="加拿大">🇨🇦 Canada</button>
        <button class="quick-filter px-3 py-1 text-xs rounded-full bg-gray-100 text-gray-600 hover:bg-primary-100 hover:text-primary-700 transition-colors" data-country="澳大利亚">🇦🇺 Australia</button>
        <button class="quick-filter px-3 py-1 text-xs rounded-full bg-green-100 text-green-700 hover:bg-green-200 transition-colors" data-policy="allowed">Allowed</button>
        <button class="quick-filter px-3 py-1 text-xs rounded-full bg-red-100 text-red-700 hover:bg-red-200 transition-colors" data-policy="prohibited">Prohibited</button>
      </div>
    </div>

    <!-- Legend -->
    <div class="flex flex-wrap items-center gap-4 mb-6 text-sm">
      <div class="flex items-center gap-2">
        <span class="w-3 h-3 rounded-full bg-green-500"></span>
        <span>Allowed</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="w-3 h-3 rounded-full bg-yellow-500"></span>
        <span>Restricted</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="w-3 h-3 rounded-full bg-red-500"></span>
        <span>Prohibited</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="w-3 h-3 rounded-full bg-blue-500"></span>
        <span>Case by Case</span>
      </div>
      <div class="ml-auto text-sm text-gray-500">
        <span id="visibleCount">{totalCount}</span> results
      </div>
    </div>

    <!-- University List -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4" id="policyList">
      {policies.map((policy: UniversityPolicy) => (
        <article
          class="card p-4 hover:shadow-md transition-shadow cursor-pointer policy-card"
          data-id={policy.id}
          data-country={policy.country}
          data-region={policy.region}
          data-name={policy.universityNameEn.toLowerCase()}
          data-name-zh={policy.universityName}
          data-policy={policy.overallPolicy}
          data-qs-rank={policy.qsRank || ''}
          onclick={`window.location.href='/en/policies/${policy.id}'`}
        >
          <div class="flex items-start gap-3 mb-3">
            <span class="text-2xl flex-shrink-0">{policy.flagEmoji}</span>
            <div class="flex-1 min-w-0">
              <h3 class="font-semibold truncate" title={policy.universityName}>{policy.universityName}</h3>
              <p class="text-xs text-gray-400">{policy.universityNameEn}</p>
              <p class="text-sm text-gray-500">{policy.country} · {policy.city}</p>
            </div>
            {policy.qsRank && (
              <span class="text-xs bg-gray-100 text-gray-600 px-2 py-1 rounded-full flex-shrink-0">QS #{policy.qsRank}</span>
            )}
          </div>

          <!-- Policy Badge -->
          <div class="mb-3">
            <span class={`inline-flex items-center gap-1.5 text-xs px-2.5 py-1 rounded-full border ${getPolicyBadgeBg(policy.overallPolicy)}`}>
              <span class={`w-1.5 h-1.5 rounded-full ${getPolicyColor(policy.overallPolicy)}`}></span>
              {translate(locale, `policies.detail.${policy.overallPolicy === 'case_by_case' ? 'caseByCase' : policy.overallPolicy}`)}
            </span>
          </div>

          <!-- Tools Summary -->
          <div class="flex flex-wrap gap-2 mb-3 min-h-[1.5rem]">
            {policy.allowedTools && policy.allowedTools.length > 0 && (
              <div class="flex items-center gap-1">
                <span class="w-2 h-2 rounded-full bg-green-400 flex-shrink-0"></span>
                <span class="text-xs text-green-700">
                  Allowed: {policy.allowedTools.slice(0, 2).join(', ')}
                  {policy.allowedTools.length > 2 && ` +${policy.allowedTools.length - 2}`}
                </span>
              </div>
            )}
            {policy.prohibitedTools && policy.prohibitedTools.length > 0 && (
              <div class="flex items-center gap-1">
                <span class="w-2 h-2 rounded-full bg-red-400 flex-shrink-0"></span>
                <span class="text-xs text-red-700">
                  Prohibited: {policy.prohibitedTools.slice(0, 2).join(', ')}
                </span>
              </div>
            )}
          </div>

          <div class="flex items-center justify-between text-xs text-gray-400">
            <span>Updated: {policy.lastUpdated}</span>
            <span class="text-primary-600 font-medium">View Details →</span>
          </div>
        </article>
      ))}
    </div>

    <!-- Empty State -->
    <div id="emptyState" class="hidden text-center py-12">
      <svg class="w-16 h-16 mx-auto text-gray-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <h3 class="text-lg font-semibold text-gray-900 mb-2">No results found</h3>
      <p class="text-gray-600">Try adjusting your filters or search terms</p>
    </div>

    <!-- Stats Summary -->
    {policies.length > 0 && (
      <div class="mt-8 p-6 bg-gray-50 rounded-xl">
        <h3 class="font-semibold mb-4">Policy Distribution</h3>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div class="text-center">
            <div class="text-2xl font-bold text-green-600">{policies.filter((p: UniversityPolicy) => p.overallPolicy === 'allowed').length}</div>
            <div class="text-sm text-gray-600">Allowed</div>
          </div>
          <div class="text-center">
            <div class="text-2xl font-bold text-yellow-600">{policies.filter((p: UniversityPolicy) => p.overallPolicy === 'restricted').length}</div>
            <div class="text-sm text-gray-600">Restricted</div>
          </div>
          <div class="text-center">
            <div class="text-2xl font-bold text-red-600">{policies.filter((p: UniversityPolicy) => p.overallPolicy === 'prohibited').length}</div>
            <div class="text-sm text-gray-600">Prohibited</div>
          </div>
          <div class="text-center">
            <div class="text-2xl font-bold text-blue-600">{policies.filter((p: UniversityPolicy) => p.overallPolicy === 'case_by_case').length}</div>
            <div class="text-sm text-gray-600">Case by Case</div>
          </div>
        </div>
      </div>
    )}
  </div>

  <script is:inline>
    const searchInput = document.getElementById('searchInput');
    const countryFilter = document.getElementById('countryFilter');
    const regionFilter = document.getElementById('regionFilter');
    const policyFilter = document.getElementById('policyFilter');
    const cards = document.querySelectorAll('.policy-card');
    const emptyState = document.getElementById('emptyState');
    const visibleCountEl = document.getElementById('visibleCount');
    const quickFilters = document.querySelectorAll('.quick-filter');

    function filterPolicies() {
      const searchTerm = searchInput?.value.toLowerCase().trim() || '';
      const country = countryFilter?.value || '';
      const region = regionFilter?.value || '';
      const policyType = policyFilter?.value || '';
      let visibleCount = 0;

      cards.forEach(card => {
        const el = card;
        const nameEn = (el.dataset.name || '').toLowerCase();
        const nameZh = (el.dataset.nameZh || '').toLowerCase();
        const cardCountry = el.dataset.country || '';
        const cardRegion = el.dataset.region || '';
        const cardPolicy = el.dataset.policy || '';

        const matchesSearch = !searchTerm || nameEn.includes(searchTerm) || nameZh.includes(searchTerm) || cardCountry.includes(searchTerm);
        const matchesCountry = !country || cardCountry === country;
        const matchesRegion = !region || cardRegion === region;
        const matchesPolicy = !policyType || cardPolicy === policyType;

        if (matchesSearch && matchesCountry && matchesRegion && matchesPolicy) {
          el.style.display = '';
          visibleCount++;
        } else {
          el.style.display = 'none';
        }
      });

      if (visibleCountEl) visibleCountEl.textContent = visibleCount;
      if (emptyState) emptyState.classList.toggle('hidden', visibleCount > 0);
    }

    searchInput?.addEventListener('input', filterPolicies);
    countryFilter?.addEventListener('change', filterPolicies);
    regionFilter?.addEventListener('change', filterPolicies);
    policyFilter?.addEventListener('change', filterPolicies);

    quickFilters.forEach(btn => {
      btn.addEventListener('click', () => {
        const country = btn.dataset.country;
        const policy = btn.dataset.policy;
        if (country) countryFilter.value = country;
        if (policy) policyFilter.value = policy;
        filterPolicies();
      });
    });
  </script>
</Layout>
