---
export const prerender = false;

import Layout from '@/layouts/Layout.astro';
import { promptTemplates, categoryInfo, getPromptTemplateById, type PromptTemplate } from '@/data/promptTemplates';
import { type Locale, t as translate, getLocaleFromUrl } from '@/i18n';
import FavoriteButton from '@/components/favorites/FavoriteButton';
import ShareButton from '@/components/common/ShareButton';
import CommentSection from '@/components/user/CommentSection';

const locale: Locale = getLocaleFromUrl(Astro.url);

const { id } = Astro.params;
const template = getPromptTemplateById(id || '');

// 404 if not found
if (!template) {
  return Astro.redirect('/prompts');
}

// Get related templates (same category, excluding current)
const relatedTemplates = promptTemplates
  .filter(t => t.category === template.category && t.id !== template.id)
  .slice(0, 3);

// Tool display names
const toolNames: Record<string, string> = {
  'chatgpt': 'ChatGPT',
  'claude': 'Claude',
  'gemini': 'Gemini',
  'kimi': 'Kimi',
};

// JSON-LD structured data
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  "name": template.title,
  "description": template.description,
  "genre": template.category,
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": template.rating.toString(),
    "ratingCount": template.ratingCount.toString()
  }
};
---

<Layout
  title={`${template.title} - Prompt模板`}
  description={template.description}
  jsonLd={jsonLd}
  locale={locale}
>
  <!-- Breadcrumb -->
  <div class="bg-gray-50 border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <nav class="flex text-sm">
        <a href="/prompts" class="text-gray-500 hover:text-gray-700">Prompt模板</a>
        <span class="mx-2 text-gray-400">/</span>
        <a href={`/prompts?category=${template.category}`} class={`${
          template.category === 'application' ? 'text-purple-600' :
          template.category === 'thesis' ? 'text-blue-600' :
          template.category === 'job' ? 'text-green-600' :
          template.category === 'daily' ? 'text-orange-600' :
          'text-red-600'
        } hover:underline`}>
          {categoryInfo[template.category].name}
        </a>
        <span class="mx-2 text-gray-400">/</span>
        <span class="text-gray-900 truncate max-w-[200px]">{template.title}</span>
      </nav>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="grid lg:grid-cols-3 gap-8">
      <!-- Main Content -->
      <div class="lg:col-span-2">
        <!-- Header -->
        <div class="bg-white rounded-xl border border-gray-200 p-6 mb-6">
          <div class="flex items-start justify-between mb-4">
            <div class="flex items-center gap-3">
              <span class={`badge text-sm ${
                template.category === 'application' ? 'bg-purple-100 text-purple-700' :
                template.category === 'thesis' ? 'bg-blue-100 text-blue-700' :
                template.category === 'job' ? 'bg-green-100 text-green-700' :
                template.category === 'daily' ? 'bg-orange-100 text-orange-700' :
                'bg-red-100 text-red-700'
              }`}>
                {categoryInfo[template.category].name}
              </span>
              {template.toolId && (
                <a href={`/tools?category=${template.toolId}`} class="badge bg-gray-100 text-gray-600 hover:bg-gray-200 transition-colors">
                  {toolNames[template.toolId] || template.toolId}
                </a>
              )}
            </div>
            <div class="flex items-center gap-2 text-sm text-gray-500">
              <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
              <span class="font-medium">{template.rating.toFixed(1)}</span>
              <span>({template.ratingCount} 评分)</span>
            </div>
          </div>

          <div class="flex items-center justify-between mb-3">
            <h1 class="text-2xl md:text-3xl font-bold text-gray-900">
              {template.title}
            </h1>
            <div class="flex items-center gap-2">
              <FavoriteButton client:load targetType="prompt" targetId={template.id} locale={locale} />
              <ShareButton client:load title={template.title} description={template.description} />
            </div>
          </div>
          <p class="text-gray-600 text-lg">
            {template.description}
          </p>

          <!-- Tags -->
          <div class="flex flex-wrap gap-2 mt-4">
            {template.tags.map(tag => (
              <a href={`/prompts?q=${encodeURIComponent(tag)}`} class="tag hover:bg-primary-100 hover:text-primary-700 transition-colors">
                {tag}
              </a>
            ))}
          </div>

          <!-- Usage Stats -->
          <div class="flex items-center gap-6 mt-6 pt-6 border-t border-gray-100 text-sm text-gray-500">
            <span class="flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
              </svg>
              已使用 {template.usageCount.toLocaleString()} 次
            </span>
            <span class="flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              更新于 {template.updatedAt}
            </span>
          </div>
        </div>

        <!-- Prompt Content -->
        <div class="bg-white rounded-xl border border-gray-200 overflow-hidden mb-6">
          <div class="flex items-center justify-between px-6 py-4 bg-gray-50 border-b border-gray-200">
            <h2 class="font-semibold text-gray-900">Prompt 内容</h2>
            <button
              id="copy-main-btn"
              class="btn-primary flex items-center gap-2"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
              </svg>
              复制 Prompt
            </button>
          </div>
          <div class="p-6">
            <pre class="whitespace-pre-wrap text-sm text-gray-700 font-mono leading-relaxed bg-gray-50 p-4 rounded-lg overflow-x-auto">{template.content}</pre>
          </div>
        </div>

        <!-- Instructions -->
        <div class="bg-white rounded-xl border border-gray-200 p-6 mb-6">
          <h2 class="font-semibold text-gray-900 mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            使用说明
          </h2>
          <div class="prose prose-gray max-w-none">
            <p class="text-gray-700 whitespace-pre-line">{template.instructions}</p>
          </div>
        </div>

        <!-- Use Cases -->
        <div class="bg-gradient-to-r from-primary-50 to-blue-50 rounded-xl border border-primary-100 p-6">
          <h2 class="font-semibold text-gray-900 mb-3 flex items-center gap-2">
            <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
            </svg>
            适用场景
          </h2>
          <p class="text-gray-700">{template.useCase}</p>
        </div>

        <!-- Comments Section -->
        <div class="bg-white rounded-xl border border-gray-200 p-6 mt-6">
          <CommentSection client:load targetType="prompt" targetId={template.id} locale={locale} />
        </div>
      </div>

      <!-- Sidebar -->
      <div class="lg:col-span-1">
        <!-- Actions Card -->
        <div class="bg-white rounded-xl border border-gray-200 p-6 mb-6 sticky top-24">
          <h3 class="font-semibold text-gray-900 mb-4">快捷操作</h3>

          <!-- Copy Button -->
          <button
            id="copy-sidebar-btn"
            class="w-full btn-primary flex items-center justify-center gap-2 mb-4"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
            一键复制
          </button>

          <!-- Rating -->
          <div class="mb-4 pb-4 border-b border-gray-100">
            <label class="text-sm text-gray-600 mb-2 block">对这个模板评分</label>
            <div class="flex items-center gap-1" id="rating-stars">
              {[1, 2, 3, 4, 5].map(star => (
                <button
                  class="rating-star-btn text-gray-300 hover:text-yellow-400 transition-colors"
                  data-star={star}
                >
                  <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                </button>
              ))}
            </div>
            <p class="text-xs text-gray-500 mt-2" id="rating-feedback"></p>
          </div>

          <!-- Favorite -->
          <button
            id="favorite-btn"
            class="w-full flex items-center justify-center gap-2 py-2 px-4 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition-colors mb-4"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
            </svg>
            收藏模板
          </button>

          <!-- Share -->
          <button
            id="share-btn"
            class="w-full flex items-center justify-center gap-2 py-2 px-4 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition-colors"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
            </svg>
            分享
          </button>
        </div>

        <!-- Related Tools - Jump to Tool -->
        {template.toolId && (
          <div class="bg-white rounded-xl border border-gray-200 p-6 mb-6">
            <h3 class="font-semibold text-gray-900 mb-4">关联工具</h3>
            <a
              href={`/tools/${template.toolId}`}
              class="flex items-center gap-3 p-3 rounded-lg border border-gray-200 hover:border-primary-300 hover:bg-primary-50 transition-colors mb-3"
            >
              <div class="w-12 h-12 bg-gradient-to-br from-primary-500 to-blue-500 rounded-lg flex items-center justify-center text-white font-bold">
                {(toolNames[template.toolId] || template.toolId).charAt(0)}
              </div>
              <div>
                <h4 class="font-medium text-gray-900">{toolNames[template.toolId] || template.toolId}</h4>
                <p class="text-sm text-gray-500">查看详情</p>
              </div>
            </a>
            <a
              href={`/tools/${template.toolId}`}
              class="w-full flex items-center justify-center gap-2 py-3 px-4 bg-gradient-to-r from-primary-500 to-blue-500 text-white rounded-lg hover:from-primary-600 hover:to-blue-600 transition-all font-medium shadow-sm"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
              跳转到 {toolNames[template.toolId] || template.toolId}
            </a>
          </div>
        )}

        <!-- Related Templates -->
        {relatedTemplates.length > 0 && (
          <div class="bg-white rounded-xl border border-gray-200 p-6">
            <h3 class="font-semibold text-gray-900 mb-4">同分类模板</h3>
            <div class="space-y-3">
              {relatedTemplates.map(related => (
                <a
                  href={`/prompts/${related.id}`}
                  class="block p-3 rounded-lg border border-gray-200 hover:border-primary-300 hover:bg-primary-50 transition-colors"
                >
                  <h4 class="font-medium text-gray-900 text-sm line-clamp-1">{related.title}</h4>
                  <div class="flex items-center gap-2 mt-1 text-xs text-gray-500">
                    <span class="flex items-center gap-1">
                      <svg class="w-3 h-3 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                      </svg>
                      {related.rating.toFixed(1)}
                    </span>
                    <span>已用 {related.usageCount.toLocaleString()}</span>
                  </div>
                </a>
              ))}
            </div>
            <a
              href={`/prompts?category=${template.category}`}
              class="block text-center text-sm text-primary-600 hover:text-primary-700 mt-4 font-medium"
            >
              查看更多 {categoryInfo[template.category].name} 模板 →
            </a>
          </div>
        )}
      </div>
    </div>
  </div>
</Layout>

<script define:vars={{ template }}>
  const content = template.content;

  // Copy functionality
  function copyToClipboard(text, btn) {
    navigator.clipboard.writeText(text).then(() => {
      const originalHTML = btn.innerHTML;
      btn.innerHTML = `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> 已复制!`;
      btn.classList.add('bg-green-500', 'text-white', 'border-green-500');
      setTimeout(() => {
        btn.innerHTML = originalHTML;
        btn.classList.remove('bg-green-500', 'text-white', 'border-green-500');
      }, 2000);
    }).catch(err => {
      console.error('Failed to copy:', err);
      alert('复制失败，请手动复制内容');
    });
  }

  // Main copy buttons
  document.getElementById('copy-main-btn')?.addEventListener('click', function() {
    copyToClipboard(content, this);
  });

  document.getElementById('copy-sidebar-btn')?.addEventListener('click', function() {
    copyToClipboard(content, this);
  });

  // Rating functionality
  let hasRated = false;
  document.querySelectorAll('.rating-star-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      if (hasRated) return;
      const star = parseInt(this.getAttribute('data-star'));

      // Highlight stars up to selected
      document.querySelectorAll('.rating-star-btn').forEach((s, i) => {
        if (i < star) {
          s.classList.add('text-yellow-400');
          s.classList.remove('text-gray-300');
        }
      });

      // Show feedback
      const feedback = document.getElementById('rating-feedback');
      if (feedback) {
        const messages = ['感谢你的反馈!', '谢谢评分!', '感谢你的支持!'];
        feedback.textContent = messages[Math.floor(Math.random() * messages.length)];
      }

      hasRated = true;
    });

    btn.addEventListener('mouseenter', function() {
      if (hasRated) return;
      const star = parseInt(this.getAttribute('data-star'));
      document.querySelectorAll('.rating-star-btn').forEach((s, i) => {
        if (i < star) {
          s.classList.add('text-yellow-400');
          s.classList.remove('text-gray-300');
        }
      });
    });

    btn.addEventListener('mouseleave', function() {
      if (hasRated) return;
      document.querySelectorAll('.rating-star-btn').forEach(s => {
        s.classList.remove('text-yellow-400');
        s.classList.add('text-gray-300');
      });
    });
  });

  // Favorite functionality
  document.getElementById('favorite-btn')?.addEventListener('click', function() {
    const icon = this.querySelector('svg');
    if (icon.getAttribute('fill') === 'none') {
      icon.setAttribute('fill', 'currentColor');
      icon.classList.add('text-red-500');
      this.classList.add('bg-red-50', 'border-red-200');
    } else {
      icon.setAttribute('fill', 'none');
      icon.classList.remove('text-red-500');
      this.classList.remove('bg-red-50', 'border-red-200');
    }
  });

  // Share functionality
  document.getElementById('share-btn')?.addEventListener('click', async function() {
    const url = window.location.href;
    const title = template.title;

    if (navigator.share) {
      try {
        await navigator.share({ title, text: template.description, url });
      } catch (err) {
        if (err.name !== 'AbortError') {
          console.error('Share failed:', err);
        }
      }
    } else {
      // Fallback: copy to clipboard
      navigator.clipboard.writeText(url).then(() => {
        const originalHTML = this.innerHTML;
        this.innerHTML = `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> 链接已复制!`;
        setTimeout(() => {
          this.innerHTML = originalHTML;
        }, 2000);
      });
    }
  });
</script>

<style>
  .line-clamp-1 {
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
