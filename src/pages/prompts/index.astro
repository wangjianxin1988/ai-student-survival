---
export const prerender = false;

import Layout from '@/layouts/Layout.astro';
import { promptTemplates, categoryInfo, type PromptTemplate } from '@/data/promptTemplates';
import { type Locale, t as translate, getLocaleFromUrl } from '@/i18n';

const locale: Locale = getLocaleFromUrl(Astro.url);

// Get query params
const category = Astro.url.searchParams.get('category') || '';
const toolFilter = Astro.url.searchParams.get('tool') || '';
const searchQuery = Astro.url.searchParams.get('q') || '';
const sortBy = Astro.url.searchParams.get('sort') || 'rating'; // rating, usageCount, newest

// Filter templates
let filteredTemplates = [...promptTemplates];

// Category filter
if (category && category !== 'all') {
  filteredTemplates = filteredTemplates.filter(t => t.category === category);
}

// Tool filter
if (toolFilter) {
  filteredTemplates = filteredTemplates.filter(t => t.toolId === toolFilter);
}

// Search filter
if (searchQuery) {
  const query = searchQuery.toLowerCase();
  filteredTemplates = filteredTemplates.filter(t =>
    t.title.toLowerCase().includes(query) ||
    t.description.toLowerCase().includes(query) ||
    t.tags.some(tag => tag.toLowerCase().includes(query)) ||
    t.content.toLowerCase().includes(query)
  );
}

// Sort templates
switch (sortBy) {
  case 'rating':
    filteredTemplates.sort((a, b) => b.rating - a.rating);
    break;
  case 'usageCount':
    filteredTemplates.sort((a, b) => b.usageCount - a.usageCount);
    break;
  case 'newest':
    filteredTemplates.sort((a, b) => new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime());
    break;
  default:
    filteredTemplates.sort((a, b) => b.rating - a.rating);
}

// Available tools for filter
const availableTools = [...new Set(promptTemplates.map(t => t.toolId).filter(Boolean))] as string[];

// Categories for filter
const categories = [
  { value: 'all', key: 'prompts.categories.all', label: '全部' },
  { value: 'application', key: 'prompts.categories.application', label: '申请' },
  { value: 'thesis', key: 'prompts.categories.thesis', label: '论文' },
  { value: 'job', key: 'prompts.categories.job', label: '工作' },
  { value: 'daily', key: 'prompts.categories.daily', label: '日常' },
  { value: 'research', key: 'prompts.categories.research', label: '研究' },
];

const sortOptions = [
  { value: 'rating', key: 'prompts.sortBy.rating', label: '评分最高' },
  { value: 'usageCount', key: 'prompts.sortBy.usageCount', label: '使用最多' },
  { value: 'newest', key: 'prompts.sortBy.newest', label: '最新' },
];

// Tool display names
const toolNames: Record<string, string> = {
  'chatgpt': 'ChatGPT',
  'claude': 'Claude',
  'gemini': 'Gemini',
  'kimi': 'Kimi',
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "留学生AI Prompt模板库",
  "description": "精选留学生常用的AI提示词模板，覆盖申请、论文、工作、日常等多个场景，帮助你快速上手AI工具",
  "numberOfItems": filteredTemplates.length,
  "itemListElement": filteredTemplates.map((template, index) => ({
    "@type": "CreativeWork",
    "position": index + 1,
    "name": template.title,
    "description": template.description,
    "genre": template.category,
  })),
};

// FAQ items for Layout JSON-LD injection
const faqItems = [
  {
    question: "这些Prompt模板是免费的吗？",
    answer: "是的，所有Prompt模板完全免费使用。你可以一键复制并直接使用，也可以根据个人需求进行定制修改。"
  },
  {
    question: "Prompt模板支持哪些AI工具？",
    answer: "我们的模板覆盖主流AI工具，包括ChatGPT、Claude、Gemini、Kimi等。详情页会标注推荐使用的工具。"
  },
  {
    question: "如何选择适合自己的Prompt模板？",
    answer: "建议按场景分类筛选：申请类用Application、论文用Thesis、工作用Job、日常用Daily、研究用Research。也可以通过搜索功能找到相关模板。"
  },
  {
    question: "可以自定义Prompt模板吗？",
    answer: "当然可以，所有模板仅供参考。你可以在复制后根据自己的具体需求修改占位符或调整指令，以获得最佳效果。"
  },
  {
    question: "如何提高Prompt的使用效果？",
    answer: "建议：1) 根据AI输出持续优化提示词 2) 结合具体场景添加更多背景信息 3) 批判性评估AI输出结果 4) 参考模板推荐的工具使用效果更佳。"
  }
];
---

<Layout
  title={translate(locale, 'prompts.title')}
  description={translate(locale, 'prompts.description')}
  jsonLd={jsonLd}
  faqItems={faqItems}
  locale={locale}
>
  <!-- Header -->
  <div class="bg-gradient-to-r from-primary-600 to-primary-700 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <h1 class="text-3xl md:text-4xl font-bold mb-3">{translate(locale, 'prompts.title')}</h1>
      <p class="text-primary-100 text-lg max-w-2xl">
        {translate(locale, 'prompts.subtitle') || '精选40+高质量Prompt模板，覆盖申请文书、学术论文、求职面试、日常沟通等多个场景，一键复制使用'}
      </p>
      <div class="mt-4 flex flex-wrap gap-3">
        <span class="bg-white/20 px-3 py-1 rounded-full text-sm">
          {promptTemplates.length} 个模板
        </span>
        <span class="bg-white/20 px-3 py-1 rounded-full text-sm">
          5 大分类
        </span>
        <span class="bg-white/20 px-3 py-1 rounded-full text-sm">
          持续更新
        </span>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Search and Filter Bar -->
    <div class="bg-white rounded-xl border border-gray-200 p-4 mb-6 shadow-sm">
      <div class="flex flex-col lg:flex-row gap-4">
        <!-- Search -->
        <form method="get" class="flex-1" id="search-form">
          <div class="relative">
            <input
              type="text"
              name="q"
              value={searchQuery}
              placeholder="搜索模板标题、内容或标签..."
              class="w-full pl-10 pr-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500"
            />
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input type="hidden" name="category" value={category} />
            <input type="hidden" name="tool" value={toolFilter} />
            <input type="hidden" name="sort" value={sortBy} />
          </div>
        </form>

        <!-- Sort -->
        <div class="flex items-center gap-2">
          <label class="text-sm text-gray-600 whitespace-nowrap">排序:</label>
          <select
            name="sort"
            class="px-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-sm"
            onchange="document.getElementById('search-form').sort.value = this.value; document.getElementById('search-form').submit();"
          >
            {sortOptions.map(opt => (
              <option value={opt.value} selected={sortBy === opt.value}>
                {opt.label}
              </option>
            ))}
          </select>
        </div>
      </div>

      <!-- Category and Tool Filters -->
      <div class="flex flex-wrap gap-4 mt-4 pt-4 border-t border-gray-100">
        <!-- Category Filter -->
        <div class="flex-1 min-w-[200px]">
          <label class="text-xs text-gray-500 mb-2 block">分类</label>
          <div class="flex flex-wrap gap-2">
            {categories.map(cat => (
              <a
                href={`/prompts?category=${cat.value}&tool=${toolFilter}&q=${searchQuery}&sort=${sortBy}`}
                class={`px-3 py-1.5 rounded-full text-sm font-medium transition-colors ${
                  category === cat.value || (cat.value === 'all' && !category)
                    ? 'bg-primary-600 text-white'
                    : 'bg-gray-100 text-gray-700 hover:bg-gray-200'
                }`}
              >
                {cat.label}
              </a>
            ))}
          </div>
        </div>

        <!-- Tool Filter -->
        <div class="min-w-[200px]">
          <label class="text-xs text-gray-500 mb-2 block">关联工具</label>
          <div class="flex flex-wrap gap-2">
            <a
              href={`/prompts?category=${category || 'all'}&tool=&q=${searchQuery}&sort=${sortBy}`}
              class={`px-3 py-1.5 rounded-full text-sm font-medium transition-colors ${
                !toolFilter ? 'bg-primary-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'
              }`}
            >
              全部
            </a>
            {availableTools.map(tool => (
              <a
                href={`/prompts?category=${category || 'all'}&tool=${tool}&q=${searchQuery}&sort=${sortBy}`}
                class={`px-3 py-1.5 rounded-full text-sm font-medium transition-colors ${
                  toolFilter === tool ? 'bg-primary-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'
                }`}
              >
                {toolNames[tool] || tool}
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Active Filters Display -->
    {(category || toolFilter || searchQuery) && (
      <div class="flex items-center gap-2 mb-4 text-sm">
        <span class="text-gray-500">当前筛选:</span>
        {category && (
          <span class="inline-flex items-center gap-1 bg-primary-100 text-primary-700 px-2 py-1 rounded-full">
            {categories.find(c => c.value === category)?.label}
            <a href={`/prompts?category=all&tool=${toolFilter}&q=${searchQuery}&sort=${sortBy}`} class="ml-1 hover:text-primary-900">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </a>
          </span>
        )}
        {toolFilter && (
          <span class="inline-flex items-center gap-1 bg-green-100 text-green-700 px-2 py-1 rounded-full">
            {toolNames[toolFilter] || toolFilter}
            <a href={`/prompts?category=${category || 'all'}&tool=&q=${searchQuery}&sort=${sortBy}`} class="ml-1 hover:text-green-900">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </a>
          </span>
        )}
        {searchQuery && (
          <span class="inline-flex items-center gap-1 bg-orange-100 text-orange-700 px-2 py-1 rounded-full">
            搜索: {searchQuery}
            <a href={`/prompts?category=${category || 'all'}&tool=${toolFilter}&q=&sort=${sortBy}`} class="ml-1 hover:text-orange-900">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </a>
          </span>
        )}
        <a href="/prompts" class="text-primary-600 hover:text-primary-700 ml-2">
          清除全部
        </a>
      </div>
    )}

    <!-- Results Count -->
    <div class="flex items-center justify-between mb-6">
      <p class="text-gray-600">
        显示 <span class="font-semibold text-gray-900">{filteredTemplates.length}</span> 个模板
        {filteredTemplates.length !== promptTemplates.length && (
          <span class="text-gray-400"> / 共 {promptTemplates.length} 个</span>
        )}
      </p>
    </div>

    <!-- Template Grid -->
    {filteredTemplates.length > 0 ? (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {filteredTemplates.map((template, index) => (
          <>
            {index > 0 && index % 6 === 0 && (
              <div class="col-span-full">
                <a href={index % 2 === 0 ? 'https://wap.redotpay.com/en/invite/affiliates-2?utm_id=thp9sj&utm_source=union&utm_uid=16062&utm_s=83f435b475fa9740d21e75f619566991ebe88480' : 'https://onekey.so/r/5R2CVW'} target="_blank" rel="noopener noreferrer" class="block rounded-xl overflow-hidden hover:shadow-md transition-all group" data-ad="virtual-card">
                  <div class={`p-4 sm:p-5 ${index % 2 === 0 ? 'bg-gradient-to-r from-blue-500 to-indigo-600' : 'bg-gradient-to-r from-emerald-500 to-teal-600'}`}>
                    <div class="flex items-center gap-3">
                      <span class="text-3xl">{index % 2 === 0 ? '💳' : '🔑'}</span>
                      <div class="flex-1">
                        <div class="flex items-center gap-2 mb-1">
                          <span class="text-xs px-2 py-0.5 rounded-full bg-white/90 font-medium text-gray-700">{index % 2 === 0 ? 'RedotPay' : 'OneKey'}</span>
                          <span class="text-xs text-white/70">推荐</span>
                        </div>
                        <h3 class="text-white font-semibold text-lg">{index % 2 === 0 ? '需要虚拟卡支付AI工具？' : '留学生必备虚拟卡'}</h3>
                      </div>
                      <span class={`shrink-0 px-4 py-2 rounded-lg text-white text-sm font-medium ${index % 2 === 0 ? 'bg-blue-700' : 'bg-emerald-700'} transition-colors`}>立即开通 →</span>
                    </div>
                    <p class="text-white/80 text-sm mt-2 ml-11">{index % 2 === 0 ? 'RedotPay - USDT充值，130+国家4400万商户消费，无年费' : 'OneKey - USDT充值，完美支持ChatGPT/OpenAI订阅'}</p>
                  </div>
                </a>
              </div>
            )}
          <article class="card overflow-hidden group flex flex-col" data-template-id={template.id}>
            <!-- Card Header -->
            <div class="p-5 border-b border-gray-100">
              <div class="flex items-start justify-between mb-3">
                <div class="flex items-center gap-2">
                  <span class={`badge ${
                    template.category === 'application' ? 'bg-purple-100 text-purple-700' :
                    template.category === 'thesis' ? 'bg-blue-100 text-blue-700' :
                    template.category === 'job' ? 'bg-green-100 text-green-700' :
                    template.category === 'daily' ? 'bg-orange-100 text-orange-700' :
                    'bg-red-100 text-red-700'
                  }`}>
                    {categoryInfo[template.category].name}
                  </span>
                  {template.toolId && (
                    <span class="badge bg-gray-100 text-gray-600">
                      {toolNames[template.toolId] || template.toolId}
                    </span>
                  )}
                </div>
                <button
                  class="copy-btn text-gray-400 hover:text-primary-600 transition-colors p-1"
                  data-template-id={template.id}
                  title="复制Prompt"
                  aria-label="复制模板"
                >
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                  </svg>
                </button>
              </div>
              <h3 class="text-lg font-semibold group-hover:text-primary-600 transition-colors line-clamp-2">
                <a href={`/prompts/${template.id}`} class="hover:text-primary-600">
                  {template.title}
                </a>
              </h3>
              <p class="text-gray-600 text-sm mt-2 line-clamp-2">{template.description}</p>
            </div>

            <!-- Preview Content -->
            <div class="p-5 bg-gray-50 flex-1">
              <div class="text-sm text-gray-700 font-mono whitespace-pre-wrap line-clamp-4 opacity-80">
                {template.content.substring(0, 180)}...
              </div>
            </div>

            <!-- Card Footer -->
            <div class="p-5 bg-white border-t border-gray-100">
              <!-- Tags -->
              <div class="flex flex-wrap gap-1 mb-3">
                {template.tags.slice(0, 3).map(tag => (
                  <span class="tag text-xs">{tag}</span>
                ))}
                {template.tags.length > 3 && (
                  <span class="tag text-xs">+{template.tags.length - 3}</span>
                )}
              </div>

              <!-- Stats and Actions -->
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-3 text-sm text-gray-500">
                  <span class="flex items-center gap-1">
                    <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                    {template.rating.toFixed(1)}
                  </span>
                  <span class="flex items-center gap-1">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                    </svg>
                    {template.usageCount.toLocaleString()}
                  </span>
                </div>
                <a
                  href={`/prompts/${template.id}`}
                  class="text-sm font-medium text-primary-600 hover:text-primary-700 transition-colors flex items-center gap-1"
                >
                  查看详情
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </a>
              </div>
            </div>
          </article>
          </>
        ))}
      </div>
    ) : (
      <!-- Empty State -->
      <div class="text-center py-16 bg-white rounded-xl border border-gray-200">
        <svg class="w-20 h-20 mx-auto text-gray-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <h3 class="text-xl font-semibold text-gray-900 mb-2">没有找到匹配的模板</h3>
        <p class="text-gray-600 mb-6">尝试调整筛选条件或清除搜索关键词</p>
        <a href="/prompts" class="btn-primary inline-flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
          </svg>
          清除筛选
        </a>
      </div>
    )}

    <!-- Tips Section -->
    <div class="mt-12 bg-gradient-to-r from-primary-50 to-blue-50 rounded-2xl p-6 md:p-8">
      <h2 class="text-xl font-bold text-gray-900 mb-4">使用技巧</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="flex gap-3">
          <div class="flex-shrink-0 w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900 mb-1">复制并定制</h3>
            <p class="text-sm text-gray-600">点击复制按钮，一键复制模板内容，然后根据你的具体需求修改占位符</p>
          </div>
        </div>
        <div class="flex gap-3">
          <div class="flex-shrink-0 w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900 mb-1">结合AI工具</h3>
            <p class="text-sm text-gray-600">根据模板推荐的工具使用效果更佳，如ChatGPT适合通用任务，Claude适合长文本</p>
          </div>
        </div>
        <div class="flex gap-3">
          <div class="flex-shrink-0 w-10 h-10 bg-orange-100 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900 mb-1">持续迭代</h3>
            <p class="text-sm text-gray-600">好的Prompt需要不断优化，根据AI输出调整提示词，找到最适合你的表达方式</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script define:vars={{ promptTemplates: promptTemplates.filter(t => {
  let show = true;
  if (category && category !== 'all') show = show && t.category === category;
  if (toolFilter) show = show && t.toolId === toolFilter;
  if (searchQuery) {
    const q = searchQuery.toLowerCase();
    show = show && (t.title.toLowerCase().includes(q) || t.description.toLowerCase().includes(q) || t.tags.some(tag => tag.toLowerCase().includes(q)));
  }
  return show;
}) }}>
  // Copy button handlers
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      const templateId = btn.getAttribute('data-template-id');
      const template = promptTemplates.find(t => t.id === templateId);
      if (!template) return;

      navigator.clipboard.writeText(template.content).then(() => {
        const originalHTML = btn.innerHTML;
        btn.innerHTML = `<svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>`;
        btn.classList.add('text-green-500');
        setTimeout(() => {
          btn.innerHTML = originalHTML;
          btn.classList.remove('text-green-500');
        }, 2000);
      }).catch(err => {
        console.error('Failed to copy:', err);
        alert('复制失败，请手动复制内容');
      });
    });
  });

  // Form auto-submit for search
  const searchInput = document.querySelector('input[name="q"]');
  let searchTimeout;
  searchInput?.addEventListener('input', () => {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(() => {
      // Small delay for UX
    }, 500);
  });
</script>

