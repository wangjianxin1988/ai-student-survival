---
import Layout from '@/layouts/Layout.astro';
import ContactForm from '@/components/common/ContactDeveloper';

export const prerender = false;

const locale = Astro.url.pathname.startsWith('/en/') ? 'en' : 'zh';
---

<Layout
  title="联系开发者"
  description="有问题或建议？欢迎联系我们"
>
  <div class="min-h-[calc(100vh-200px)] py-12 px-4">
    <div class="max-w-2xl mx-auto">
      <ContactForm locale={locale} client:load />
    </div>
  </div>
</Layout>
